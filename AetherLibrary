        valueText.TextColor3 = theme.Text
        valueText.TextSize = 9
        valueText.TextStrokeTransparency = 0.85
        valueText.TextTransparency = 0
        
        local function opcToggle(value)
            if value then
                self:CreateAnimation(box, 0.45, {BackgroundTransparency = 0})
                self:CreateAnimation(optionButton, 0.45, {ImageTransparency = (config.Option and 0.6) or 1})
                self:CreateAnimation(valueFrame, 0.45, {BackgroundTransparency = 0})
                self:CreateAnimation(sliderName, 0.45, {TextTransparency = 0.2})
                self:CreateAnimation(valueText, 0.45, {TextStrokeTransparency = 0.85, TextTransparency = 0})
            else
                self:CreateAnimation(valueText, 0.45, {TextStrokeTransparency = 1, TextTransparency = 1})
                self:CreateAnimation(sliderName, 0.45, {TextTransparency = 1})
                self:CreateAnimation(valueFrame, 0.45, {BackgroundTransparency = 1})
                self:CreateAnimation(box, 0.45, {BackgroundTransparency = 1})
                self:CreateAnimation(optionButton, 0.45, {ImageTransparency = 1})
            end
        end
        
        opcToggle(event:GetAttribute('V'))
        
        local isHold = false
        
        local function update(input)
            local sizeScale = math.clamp((input.Position.X - valueFrame.AbsolutePosition.X) / valueFrame.AbsoluteSize.X, 0, 1)
            local main = ((config.Max - config.Min) * sizeScale) + config.Min
            local value = self:Rounding(main, config.Round)
            local normalized = (value - config.Min) / (config.Max - config.Min)
            
            TweenService:Create(box, TweenInfo.new(0.2), {Size = UDim2.new(normalized, 0, 1, 0)}):Play()
            config.Default = value
            valueText.Text = string.format('%s%s', tostring(config.Default), tostring(config.Type))
            config.Callback(value)
        end
        
        valueFrame.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                isHold = true
                update(input)
            end
        end)
        
        valueFrame.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                if UserInputService.TouchEnabled then
                    if not self:IsMouseOverFrame(valueFrame) then
                        isHold = false
                    end
                else
                    isHold = false
                end
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if isHold then
                if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                    if UserInputService.TouchEnabled then
                        if not self:IsMouseOverFrame(valueFrame) then
                            isHold = false
                        else
                            update(input)
                        end
                    else
                        update(input)
                    end
                end
            end
        end)
        
        local response = self:CreateResponse({
            Rename = function(newName) sliderName.Text = newName end,
            GetValue = function() return config.Default end,
            Signal = event.Event:Connect(opcToggle),
            SetValue = function(v)
                local isSame = v == config.Default
                config.Default = v
                TweenService:Create(box, TweenInfo.new(0.2), {Size = UDim2.new((config.Default - config.Min) / (config.Max - config.Min), 0, 1, 0)}):Play()
                valueText.Text = string.format('%s%s', tostring(config.Default), tostring(config.Type))
                if not isSame then
                    config.Callback(v)
                end
            end,
            Flag = config.Flag and config.Flag .. "Slider",
            Option = (config.Option and function()
                -- Create option menu (similar to toggle option)
                return nil
            end) or nil,
        })
        
        if config.Flag then
            self.Config.WFlags[window][config.Flag .. "Slider"] = response
        end
        
        return response
    end
    
