function Aether:Loader(loaderConfig)
    loaderConfig = loaderConfig or {}
    loaderConfig.Name = loaderConfig.Name or "AETHER"
    loaderConfig.Duration = loaderConfig.Duration or 3.5
    loaderConfig.Scale = loaderConfig.Scale or 3
    
    local blur = Instance.new('BlurEffect')
    local loader = Instance.new("ScreenGui")
    local center = Instance.new("Frame")
    local texts = Instance.new("Frame")
    local layout = Instance.new("UIListLayout")
    local blackFrame = Instance.new("Frame")
    local theme = self:GetTheme()
    
    loader.Name = self:RandomString()
    loader.Parent = CoreGui
    loader.IgnoreGuiInset = true
    loader.ZIndexBehavior = Enum.ZIndexBehavior.Global
    
    center.Name = self:RandomString()
    center.Parent = loader
    center.AnchorPoint = Vector2.new(0.5, 0.5)
    center.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    center.BackgroundTransparency = 1
    center.BorderColor3 = Color3.fromRGB(0, 0, 0)
    center.BorderSizePixel = 0
    center.Position = UDim2.new(0.5, 0, 0.5, 0)
    
    texts.Name = self:RandomString()
    texts.Parent = loader
    texts.AnchorPoint = Vector2.new(0.5, 0.5)
    texts.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    texts.BackgroundTransparency = 1
    texts.BorderColor3 = Color3.fromRGB(0, 0, 0)
    texts.BorderSizePixel = 0
    texts.Position = UDim2.new(0.5, 0, 0.5, 0)
    texts.Size = UDim2.new(1, 0, 0, 200)
    
    layout.Parent = texts
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.VerticalAlignment = Enum.VerticalAlignment.Center
    layout.Padding = UDim.new(0, loaderConfig.Scale * 5)
    
    blackFrame.Name = self:RandomString()
    blackFrame.Parent = loader
    blackFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    blackFrame.BackgroundTransparency = 1
    blackFrame.BorderColor3 = Color3.fromRGB(0, 0, 0)
    blackFrame.BorderSizePixel = 0
    blackFrame.Size = UDim2.new(1, 0, 1, 0)
    
    blur.Size = 0
    blur.Parent = game:GetService('Lighting')
    
    self:CreateAnimation(blur, 1, {Size = 60})
    self:CreateAnimation(blackFrame, 0.5, {BackgroundTransparency = 0.7}).Completed:Wait()
    task.wait(0.5)
    
    local uText = {Y = 14}
    
    local function createText(textChar)
        local lit = Instance.new("Frame")
        local ascii = Instance.new("TextLabel")
        local gradient = Instance.new("UIGradient")
        local scale = Instance.new("UIScale")
        
        lit.Name = self:RandomString()
        lit.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        lit.BackgroundTransparency = 1
        lit.BorderColor3 = Color3.fromRGB(0, 0, 0)
        lit.BorderSizePixel = 0
        lit.Size = UDim2.new(0, 56, 0, 100)
        lit.ZIndex = 8
        
        ascii.Name = self:RandomString()
        ascii.Parent = lit
        ascii.AnchorPoint = Vector2.new(0.5, 0.5)
        ascii.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        ascii.BackgroundTransparency = 1
        ascii.BorderColor3 = Color3.fromRGB(0, 0, 0)
        ascii.BorderSizePixel = 0
        ascii.Position = UDim2.new(0.5, 0, 0.5, 0)
        ascii.Size = UDim2.new(0, 28, 0, 50)
        ascii.ZIndex = 8
        ascii.Font = Enum.Font.GothamBold
        ascii.Text = textChar
        ascii.TextColor3 = theme.Text
        ascii.TextSize = 50
        ascii.TextWrapped = true
        
        local textSize = self:GetTextSize(ascii.Text, ascii.TextSize, Enum.Font.GothamBold)
        ascii.Size = UDim2.new(0, textSize.X + 100, 0, 50)
        lit.Size = UDim2.new(0, (textSize.X * 2.5) + (uText[textChar] or 0), 0, 100)
        
        gradient.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0.00, theme.Main),
            ColorSequenceKeypoint.new(1.00, theme.MainDark)
        }
        gradient.Rotation = 88
        gradient.Parent = ascii
        
        scale.Parent = ascii
        scale.Scale = loaderConfig.Scale
        
        return lit, ascii
    end
    
    local posText = {}
    local isFirst = true
    
    string.gsub(loaderConfig.Name, '.', function(char)
        local lit, ascii = createText(char)
        lit.Parent = texts
        ascii.TextTransparency = 1
        
        if not isFirst then
            ascii.Position = UDim2.new(0.5, 0, 0.5, 200)
        end
        
        table.insert(posText, {Frame = lit, Text = ascii})
        isFirst = false
    end)
    
    local startText = Instance.new("TextLabel")
    local startGradient = Instance.new("UIGradient")
    local startScale = Instance.new("UIScale")
    
    startText.Name = self:RandomString()
    startText.Parent = loader
    startText.AnchorPoint = Vector2.new(0.5, 0.5)
    startText.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    startText.BackgroundTransparency = 1
    startText.BorderColor3 = Color3.fromRGB(0, 0, 0)
    startText.BorderSizePixel = 0
    startText.Position = UDim2.new(0.5, 0, 0.5, 0)
    startText.Size = UDim2.new(0, 28, 0, 50)
    startText.ZIndex = 8
    startText.Font = Enum.Font.GothamBold
    startText.Text = loaderConfig.Name:sub(1, 1)
    startText.TextColor3 = theme.Text
    startText.TextSize = 50
    startText.TextWrapped = true
    startText.TextTransparency = 1
    
    local textSize = self:GetTextSize(startText.Text, startText.TextSize, Enum.Font.GothamBold)
    startText.Size = UDim2.new(0, textSize.X + 100, 0, 50)
    
    startGradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0.00, theme.Main),
        ColorSequenceKeypoint.new(1.00, theme.MainDark)
    }
    startGradient.Rotation = 88
    startGradient.Parent = startText
    
    startScale.Parent = startText
    startScale.Scale = loaderConfig.Scale * 4
    
    self:CreateAnimation(startText, 0.45, {TextTransparency = 0})
    self:CreateAnimation(startScale, 0.5, {Scale = loaderConfig.Scale})
    task.wait(0.45)
    
    self:CreateAnimation(startText, 0.35, {
        Position = UDim2.fromOffset(posText[1].Frame.AbsolutePosition.X + (posText[1].Frame.AbsoluteSize.X / 2), 
                                    posText[1].Frame.AbsolutePosition.Y + (posText[1].Frame.AbsoluteSize.Y / 2) + math.abs(loader.AbsolutePosition.Y))
    })
    task.wait(0.5)
    
    for i, data in ipairs(posText) do
        if i > 1 then
            self:CreateAnimation(data.Text, 0.65, {
                Position = UDim2.new(0.5, 0, 0.5, 0),
                TextTransparency = 0
            })
        end
    end
    
    task.wait((loaderConfig.Duration - 0.5) + 0.65)
    
    self:CreateAnimation(startText, 1.5, {TextTransparency = 1})
    for _, data in ipairs(posText) do
        self:CreateAnimation(data.Text, 1.5, {TextTransparency = 1})
    end
    
    self:CreateAnimation(blur, 1.5, {Size = 0})
    self:CreateAnimation(blackFrame, 1.5, {BackgroundTransparency = 1})
    task.wait(1.65)
    
    loader:Destroy()
end

