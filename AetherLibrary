        keybind.BackgroundTransparency = 1
        keybind.BorderColor3 = Color3.fromRGB(0, 0, 0)
        keybind.BorderSizePixel = 0
        keybind.Size = UDim2.new(1, -25, 0, 17)
        keybind.ZIndex = zIndex + 1
        self:AddDragBlacklist(keybind)
        
        keybindName.Name = self:RandomString()
        keybindName.Parent = keybind
        keybindName.AnchorPoint = Vector2.new(0, 0.5)
        keybindName.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        keybindName.BackgroundTransparency = 1
        keybindName.BorderColor3 = Color3.fromRGB(0, 0, 0)
        keybindName.BorderSizePixel = 0
        keybindName.Position = UDim2.new(0, 0, 0.5, 0)
        keybindName.Size = UDim2.new(1, 0, 0.8, 0)
        keybindName.ZIndex = zIndex + 2
        keybindName.FontFace = self.Config.FontSemiBold
        keybindName.Text = config.Name
        keybindName.TextColor3 = theme.Text
        keybindName.TextSize = 13
        keybindName.TextTransparency = 0.2
        keybindName.TextXAlignment = Enum.TextXAlignment.Left
        self:ProtectText(keybindName, config.Name)
        
        valueFrame.Name = self:RandomString()
        valueFrame.Parent = keybind
        valueFrame.AnchorPoint = Vector2.new(1, 0.5)
        valueFrame.BackgroundColor3 = theme.BackgroundDark
        valueFrame.BorderColor3 = Color3.fromRGB(0, 0, 0)
        valueFrame.BorderSizePixel = 0
        valueFrame.Position = UDim2.new(1, -3, 0.5, 0)
        valueFrame.Size = UDim2.new(0, 75, 0.85, 0)
        valueFrame.ZIndex = zIndex + 2
        
        uiCorner.CornerRadius = UDim.new(0, 2)
        uiCorner.Parent = valueFrame
        
        optionButton.Name = self:RandomString()
        optionButton.Parent = valueFrame
        optionButton.AnchorPoint = Vector2.new(0, 0.5)
        optionButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        optionButton.BackgroundTransparency = 1
        optionButton.BorderColor3 = Color3.fromRGB(0, 0, 0)
        optionButton.BorderSizePixel = 0
        optionButton.Position = UDim2.new(0, -20, 0.5, 0)
        optionButton.Size = UDim2.new(0, 13, 0, 13)
        optionButton.SizeConstraint = Enum.SizeConstraint.RelativeYY
        optionButton.Image = "http://www.roblox.com/asset/?id=14007344336"
        optionButton.ImageTransparency = 0.6
        optionButton.Visible = config.Option or false
        
        valueText.Name = self:RandomString()
        valueText.Parent = valueFrame
        valueText.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        valueText.BackgroundTransparency = 1
        valueText.BorderColor3 = Color3.fromRGB(0, 0, 0)
        valueText.BorderSizePixel = 0
        valueText.Size = UDim2.new(1, 0, 1, 0)
        valueText.ZIndex = zIndex + 3
        valueText.FontFace = self.Config.FontSemiBold
        valueText.Text = getItem(config.Default)
        valueText.TextColor3 = theme.Text
        valueText.TextSize = 9
        valueText.TextStrokeTransparency = 0.85
        valueText.TextTransparency = 0.4
        
        local isBinding = false
        self:NewInput(valueFrame, function()
            if isBinding then return end
            valueText.Text = "..."
            local selected = nil
            while not selected do
                local key = UserInputService.InputBegan:Wait()
                if key.KeyCode ~= Enum.KeyCode.Unknown then
                    selected = key.KeyCode
                else
                    if key.UserInputType == Enum.UserInputType.MouseButton1 then
                        selected = "MouseLeft"
                    elseif key.UserInputType == Enum.UserInputType.MouseButton2 then
                        selected = "MouseRight"
                    end
                end
            end
            config.Default = selected
            valueText.Text = getItem(selected)
            isBinding = false
            config.Callback(typeof(selected) == "string" and selected or selected.Name)
        end)
        
        local function opcToggle(value)
            if value then
                self:CreateAnimation(keybindName, 0.45, {TextTransparency = 0.2})
                self:CreateAnimation(valueFrame, 0.45, {BackgroundTransparency = 0})
                self:CreateAnimation(valueText, 0.45, {TextStrokeTransparency = 0.85, TextTransparency = 0.4})
                self:CreateAnimation(optionButton, 0.45, {ImageTransparency = (config.Option and 0.6) or 1})
            else
                self:CreateAnimation(keybindName, 0.45, {TextTransparency = 1})
                self:CreateAnimation(valueFrame, 0.45, {BackgroundTransparency = 1})
                self:CreateAnimation(valueText, 0.45, {TextStrokeTransparency = 1, TextTransparency = 1})
                self:CreateAnimation(optionButton, 0.45, {ImageTransparency = 1})
            end
        end
        
        opcToggle(event:GetAttribute('V'))
        
        local response = self:CreateResponse({
            Rename = function(newName)
                keybindName.Text = newName
                self:ProtectText(keybindName, newName)
            end,
            GetValue = function() return config.Default end,
            Signal = event.Event:Connect(opcToggle),
            SetValue = function(def)
                local isSame = config.Default == def
                config.Default = def
                valueText.Text = getItem(config.Default)
                if not isSame then
                    config.Callback(config.Default)
                end
            end,
            Flag = config.Flag and config.Flag .. "Keybind",
            Option = (config.Option and function() return nil end) or nil,
        })
        
        if config.Flag then
            self.Config.WFlags[window][config.Flag .. "Keybind"] = response
        end
        
        return response
    end
    
    return elements
end

