            self:CreateAnimation(mouseMovement, 0.35, {Position = UDim2.new(codeH, 0, 1 - codeV, 0)})
            self:CreateAnimation(colorOptSlide, 0.35, {Position = UDim2.new(1 - transparency, 0, 0.5, 0)})
