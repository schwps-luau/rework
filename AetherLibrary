    menuFrame.BorderSizePixel = 0
    menuFrame.Position = UDim2.new(0, 0, 0, 50)
    menuFrame.Size = UDim2.new(1, 0, 1, -82)
    
    bottom.Name = self:RandomString()
    bottom.Parent = mainFrame
    bottom.Active = true
    bottom.AnchorPoint = Vector2.new(0, 1)
    bottom.BackgroundColor3 = theme.BackgroundTertiary
    bottom.BorderColor3 = Color3.fromRGB(0, 0, 0)
    bottom.BorderSizePixel = 0
    bottom.Position = UDim2.new(0, 0, 1, 0)
    bottom.Size = UDim2.new(1, 0, 0, 25)
    bottom.ZIndex = 2
    
    bottomLine.Name = self:RandomString()
    bottomLine.Parent = bottom
    bottomLine.BackgroundColor3 = theme.Border
