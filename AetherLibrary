        menuConfig = menuConfig or {}
        menuConfig.Name = menuConfig.Name or "EXAMPLE"
        menuConfig.Icon = menuConfig.Icon or "eye"
        menuConfig.AutoFill = (menuConfig.AutoFill == nil and true) or false
        
