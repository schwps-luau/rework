            else
                self:CreateAnimation(valueIcon, 0.45, {
                    ImageTransparency = 1,
                    ImageColor3 = theme.Text,
                    Size = UDim2.new(0.7, 0, 0.7, 0),
                    Rotation = 15
                })
            end
        end
        
        local function opcToggle(value)
            if value then
                self:CreateAnimation(valueIcon, 0.45, {ImageTransparency = 1})
                self:CreateAnimation(optionButton, 0.45, {ImageTransparency = (config.Option and 0.6) or 1})
                toggleImg(config.Default)
                self:CreateAnimation(valueFrame, 0.45, {BackgroundTransparency = 0})
                self:CreateAnimation(toggleName, 0.45, {TextTransparency = 0.2})
            else
                self:CreateAnimation(toggleName, 0.45, {TextTransparency = 1})
                self:CreateAnimation(valueFrame, 0.45, {BackgroundTransparency = 1})
                self:CreateAnimation(valueIcon, 0.45, {ImageTransparency = 1})
                self:CreateAnimation(optionButton, 0.45, {ImageTransparency = 1})
            end
        end
        
        opcToggle(event:GetAttribute('V'))
        toggleImg(config.Default)
        
        self:CreateHover(valueFrame, function(b)
            if not config.Default then
                if b then
                    self:CreateAnimation(valueIcon, 0.45, {
