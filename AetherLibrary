-- Get current theme colors
function Aether:GetTheme()
    return Aether.Themes[Aether.Config.CurrentTheme] or Aether.Themes.Default
end

-- Apply theme to all windows
function Aether:ApplyTheme(themeName)
    if not Aether.Themes[themeName] then return end
    
    Aether.Config.CurrentTheme = themeName
    local theme = Aether:GetTheme()
    
    -- Update global colors
    Aether.Colors = {
        Black = theme.BackgroundDark,
        Main = theme.Main,
        Background = theme.Background,
        BackgroundSecondary = theme.BackgroundSecondary,
        Text = theme.Text,
        Border = theme.Border,
        Danger = theme.Danger,
        Success = theme.Success,
    }
    
    -- Refresh all windows if they exist
    for _, window in pairs(Aether.Config.Windows) do
        if window.RefreshTheme then
            window:RefreshTheme(theme)
        end
    end
end

-- Add new theme dynamically
function Aether:AddTheme(name, colors)
    Aether.Themes[name] = colors
end

-- Get all theme names
function Aether:GetThemeNames()
    local names = {}
    for name, _ in pairs(Aether.Themes) do
        table.insert(names, name)
    end
    return names
end

