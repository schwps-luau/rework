            end,
            SetData = function(values)
                config.Values = values
                refreshDropdown()
            end,
            Flag = config.Flag and config.Flag .. "Dropdown",
        })
        
        if config.Flag then
            self.Config.WFlags[window][config.Flag .. "Dropdown"] = response
        end
        
        return response
    end
    
    return elements
