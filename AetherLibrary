    function window:RefreshTheme(newTheme)
        theme = newTheme
        
        -- Update all theme-dependent colors
        mainFrame.BackgroundColor3 = theme.Background
        header.BackgroundColor3 = theme.BackgroundTertiary
        headerLine.BackgroundColor3 = theme.Border
        headerText.TextColor3 = theme.Text
        bottom.BackgroundColor3 = theme.BackgroundTertiary
        bottomLine.BackgroundColor3 = theme.Border
        userName.TextColor3 = theme.Text
        expireDays.TextColor3 = theme.Text
        userIconStroke.Color = theme.Border
        
        -- Update all existing elements (recursive)
        local function updateElementColors(element)
            if element:IsA("TextLabel") or element:IsA("TextButton") then
                if element.TextColor3 ~= theme.Main and element.TextColor3 ~= theme.Danger then
                    element.TextColor3 = theme.Text
                end
            elseif element:IsA("Frame") then
                if element.BackgroundColor3 == self.Colors.Background or element.BackgroundColor3 == self.Colors.BackgroundSecondary then
                    element.BackgroundColor3 = theme.Background
                end
            end
        end
        
        -- Apply recursively
        local function traverse(instance)
            updateElementColors(instance)
            for _, child in ipairs(instance:GetChildren()) do
                traverse(child)
            end
        end
        
        traverse(gui)
    end
    
