function Aether:IsMobile()
    return UserInputService.TouchEnabled
end

function Aether:RandomString(len)
    len = len or 20
    local str = ""
    for i = 1, len do
        local rand = math.random(1, #self.Config.Ascii)
        str = str .. self.Config.Ascii:sub(rand, rand)
    end
    return str
end

function Aether:GetTextSize(text, fontSize, font)
    return TextService:GetTextSize(text, fontSize, font or Enum.Font.GothamMedium, Vector2.new(math.huge, math.huge))
end

function Aether:IsMouseOverFrame(frame)
    local absPos, absSize = frame.AbsolutePosition, frame.AbsoluteSize
    return Mouse.X >= absPos.X and Mouse.X <= absPos.X + absSize.X and
           Mouse.Y >= absPos.Y and Mouse.Y <= absPos.Y + absSize.Y
end

function Aether:GetIcon(name)
    return self.Icons[name] or ""
end

function Aether:SetIcon(name, value)
    self.Icons[name] = value
end

function Aether:Rounding(num, decimalPlaces)
    local mult = 10 ^ (decimalPlaces or 0)
    return math.floor(num * mult + 0.5) / mult
end

function Aether:CreateAnimation(instance, time, style, properties)
    if not properties then
        if typeof(style) == 'table' then
            properties = style
            style = nil
        end
    end
    
    local tween = TweenService:Create(instance, TweenInfo.new(time or 1, style or Enum.EasingStyle.Quint), properties)
    tween:Play()
    return tween
end

function Aether:NewInput(frame, callback)
    local button = Instance.new('TextButton', frame)
    button.ZIndex = frame.ZIndex + 10
    button.Size = UDim2.fromScale(1, 1)
    button.BackgroundTransparency = 1
    button.TextTransparency = 1
    
    if callback then
        button.MouseButton1Click:Connect(callback)
    end
    
    return button
end

function Aether:Drag(inputFrame, moveFrame, speed)
    local dragToggle = false
    local dragStart = nil
    local startPos = nil
    
    local function updateInput(input)
        local delta = input.Position - dragStart
        local position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
                                   startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        self:CreateAnimation(moveFrame, speed, nil, {Position = position})
    end
    
    inputFrame.InputBegan:Connect(function(input)
        if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and #self.Config.DragBlacklist <= 0 then
            dragToggle = true
            dragStart = input.Position
            startPos = moveFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragToggle = false
                end
            end)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch and #self.Config.DragBlacklist <= 0 then
            if dragToggle then
                updateInput(input)
            end
        else
            if #self.Config.DragBlacklist > 0 then
                dragToggle = false
            end
        end
    end)
end

function Aether:ScrollSignal(scroll, layout, type)
    if type == 'X' then
        layout:GetPropertyChangedSignal('AbsoluteContentSize'):Connect(function()
            scroll.CanvasSize = UDim2.fromOffset(layout.AbsoluteContentSize.X, 0)
        end)
    else
        layout:GetPropertyChangedSignal('AbsoluteContentSize'):Connect(function()
            scroll.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y)
        end)
    end
end

function Aether:CreateResponse(args)
    local main = {}
    for i, v in next, args do
        if typeof(v) == 'function' then
            main[i] = function(self, ...)
                return v(...)
            end
        else
            main[i] = v
        end
    end
    return main
end

function Aether:GetWindowFromElement(element)
    for _, window in next, self.Config.Windows do
        if element:IsDescendantOf(window) then
            return window
        end
    end
end

function Aether:CreateHover(element, callback)
    element.MouseEnter:Connect(function()
        callback(true)
    end)
    element.MouseLeave:Connect(function()
        callback(false)
    end)
end

function Aether:AddDragBlacklist(frame)
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            if not table.find(self.Config.DragBlacklist, frame) then
                table.insert(self.Config.DragBlacklist, frame)
            end
        end
    end)
    
    frame.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            local index = table.find(self.Config.DragBlacklist, frame)
            if index then
                table.remove(self.Config.DragBlacklist, index)
            end
        end
    end)
end

function Aether:ProtectText(label, text)
    label.RichText = true
    local protected = string.gsub(text, '.', function(char)
        if not string.find(char, "[<>()\"']") then
            return string.format('<font %s="%s">%s</font>', self:RandomString(5), self:RandomString(5), char)
        end
        return char
    end)
    label.Text = protected
end

