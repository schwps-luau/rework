        bindEvent.Name = self:RandomString()
        
        if not menuConfig.AutoFill then
            self:ScrollSignal(rightScroll, rightLayout, 'Y')
            self:ScrollSignal(centerScroll, centerLayout, 'Y')
            self:ScrollSignal(leftScroll, leftLayout, 'Y')
        else
            rightScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
            leftScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
            centerScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
        end
        
        window.Signal.Event:Connect(function(bool)
            if bool then
                self:CreateAnimation(menuButton, 0.5, {BackgroundTransparency = (menuContent.Visible and 0) or 1})
                self:CreateAnimation(uiStroke, 0.5, {Transparency = 0.95})
                self:CreateAnimation(leftScroll, 0.3, {Position = UDim2.new(0.175, 0, 0.5, 0)})
