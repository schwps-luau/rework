                Refresh = function()
                    for _, child in ipairs(scrollFrame:GetChildren()) do
                        if child:IsA('TextButton') then
                            child:Destroy()
                        end
                    end
                    
                    local selectedMem
                    for _, value in ipairs(listboxConfig.Values) do
                        local button = newButton()
                        button.Text = string.rep(" ", 2) .. tostring(value)
                        button.Parent = scrollFrame
                        
                        if listboxConfig.Multi then
                            if (typeof(listboxConfig.Default) == 'table' and (listboxConfig.Default[value] or table.find(listboxConfig.Default, value))) or listboxConfig.Default == value then
                                listboxConfig.Default[value] = true
                                button.TextColor3 = theme.Main
                                button.TextTransparency = 0
                            else
                                button.TextColor3 = theme.TextSecondary
                                button.TextTransparency = 0.5
                                listboxConfig.Default[value] = false
                            end
                            
                            self:CreateHover(button, function(bool)
                                if not listboxConfig.Default[value] then
                                    self:CreateAnimation(button, 0.25, {TextTransparency = bool and 0 or 0.5})
                                end
                            end)
                            
                            button.MouseButton1Click:Connect(function()
                                listboxConfig.Default[value] = not listboxConfig.Default[value]
                                
                                if listboxConfig.Default[value] then
                                    button.TextColor3 = theme.Main
                                    button.TextTransparency = 0
                                else
                                    button.TextColor3 = theme.TextSecondary
                                    button.TextTransparency = 0.5
                                end
                                
                                listboxConfig.Callback(listboxConfig.Default)
                            end)
                        else
                            if value == listboxConfig.Default then
                                selectedMem = button
                                listboxConfig.Default = value
                                button.TextColor3 = theme.Main
                                button.TextTransparency = 0
                            else
                                button.TextColor3 = theme.TextSecondary
                                button.TextTransparency = 0.5
                            end
                            
                            self:CreateHover(button, function(bool)
                                if listboxConfig.Default ~= value then
                                    self:CreateAnimation(button, 0.25, {TextTransparency = bool and 0 or 0.5})
                                end
                            end)
                            
                            button.MouseButton1Click:Connect(function()
                                if selectedMem then
                                    selectedMem.TextColor3 = theme.TextSecondary
                                    selectedMem.TextTransparency = 0.5
                                end
                                
                                button.TextTransparency = 0
                                button.TextColor3 = theme.Main
                                selectedMem = button
                                listboxConfig.Default = value
                                listboxConfig.Callback(value)
                            end)
                        end
                    end
                    
                    listboxConfig.Callback(listboxConfig.Default)
                end,
                SetValues = function(values) listboxConfig.Values = values end,
                SetDefault = function(default) listboxConfig.Default = default end,
                GetValue = function() return listboxConfig.Default end,
                Flag = listboxConfig.Flag and listboxConfig.Flag .. "ListBox",
                SetValue = function(value)
                    listboxConfig.Default = value
                    res:Refresh()
                    listboxConfig.Callback(listboxConfig.Default)
                end,
                Option = (listboxConfig.Option and function() return nil end) or nil,
            })
            
            res:Refresh()
            
            if listboxConfig.Flag then
                self.Config.WFlags[gui][listboxConfig.Flag .. "ListBox"] = res
            end
            
            return res
        end
        
