                self:CreateAnimation(colorPickBox, 0.5, {BackgroundColor3 = Color3.fromHSV(code, 1, 1)})
                hexCodeText.Text = "#" .. tostring(color:ToHex())
                oldCode = code
            end
        end
    end)
    
    colorOpc.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isPressM1 = true
            while (UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or isPressM1) do
                task.wait()
                local t = math.clamp((Mouse.X - colorOpc.AbsolutePosition.X) / colorOpc.AbsoluteSize.X, 0, 1)
                self:CreateAnimation(colorOptSlide, 0.35, {Position = UDim2.new(t, 0, 0.5, 0)})
                hexCodeText.Text = "#" .. tostring(colorBox.BackgroundColor3:ToHex())
                transparency = 1 - t
            end
        end
    end)
    
    colorPickBox.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isPressM1 = true
            while (UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or isPressM1) do
                task.wait()
                local posX = colorPickBox.AbsolutePosition.X
                local scaleX = posX + colorPickBox.AbsoluteSize.X
                local value = math.clamp(Mouse.X, posX, scaleX)
                local posY = colorPickBox.AbsolutePosition.Y
                local scaleY = posY + colorPickBox.AbsoluteSize.Y
                local vals = math.clamp(Mouse.Y, posY, scaleY)
                codeH = (value - posX) / (scaleX - posX)
                codeV = 1 - ((vals - posY) / (scaleY - posY))
                self:CreateAnimation(colorBox, 0.5, {BackgroundColor3 = Color3.fromHSV(oldCode, codeH, codeV)})
                self:CreateAnimation(colorOpc, 0.35, {BackgroundColor3 = Color3.fromHSV(oldCode, codeH, codeV)})
                hexCodeText.Text = "#" .. tostring(Color3.fromHSV(oldCode, codeH, codeV):ToHex())
                self:CreateAnimation(mouseMovement, 0.2, nil, {Position = UDim2.new(codeH, 0, 1 - codeV, 0)})
            end
        end
    end)
    
    return {
        set_opc = function(v) transparency = v end,
    }
end

