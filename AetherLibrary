        icon.SizeConstraint = Enum.SizeConstraint.RelativeYY
        icon.ZIndex = 5
        icon.Image = self:GetIcon(menuConfig.Icon)
        icon.ImageColor3 = theme.Main
        icon.ScaleType = Enum.ScaleType.Crop
        
        iconCorner.CornerRadius = UDim.new(1, 0)
        iconCorner.Parent = icon
        
        menuName.Name = self:RandomString()
        menuName.Parent = menuButton
        menuName.AnchorPoint = Vector2.new(0, 0.5)
        menuName.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        menuName.BackgroundTransparency = 1
        menuName.BorderColor3 = Color3.fromRGB(0, 0, 0)
        menuName.BorderSizePixel = 0
        menuName.Position = UDim2.new(0, 28, 0.5, 0)
