        centerScroll.Active = true
        centerScroll.AnchorPoint = Vector2.new(0.5, 0.5)
        centerScroll.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        centerScroll.BackgroundTransparency = 1
        centerScroll.BorderColor3 = Color3.fromRGB(0, 0, 0)
        centerScroll.BorderSizePixel = 0
        centerScroll.ClipsDescendants = false
        centerScroll.Position = UDim2.new(0.5, 0, 0.5, 0)
        centerScroll.Size = UDim2.new(0.32, 0, 1, -5)
        centerScroll.ScrollBarThickness = 0
        
        centerLayout.Parent = centerScroll
        centerLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        centerLayout.SortOrder = Enum.SortOrder.LayoutOrder
        centerLayout.Padding = UDim.new(0, 5)
        centerLayout.VerticalFlex = (menuConfig.AutoFill and Enum.UIFlexAlignment.Fill) or Enum.UIFlexAlignment.None
        
        rightScroll.Name = self:RandomString()
