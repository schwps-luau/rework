        local dropdownOpen = false
        local dropdownThread
        
        local function toggleDropdown(open)
            if open then
                if dropdownThread then
                    task.cancel(dropdownThread)
                end
                
                dropdownThread = task.spawn(function()
                    while true do
                        task.wait()
                        local baseSize = dropdownLayout.AbsoluteContentSize.Y + 10
                        dropdownFrame.Position = UDim2.fromOffset(valueFrame.AbsolutePosition.X, valueFrame.AbsolutePosition.Y + (valueFrame.AbsoluteSize.Y * 2))
