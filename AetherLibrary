            notify.Name = self:RandomString()
            notify.Parent = layout
            notify.BackgroundColor3 = theme.Background
            notify.BackgroundTransparency = 1
            notify.BorderColor3 = Color3.fromRGB(0, 0, 0)
            notify.BorderSizePixel = 0
            notify.Size = UDim2.new(0, 0, 0, 0)
            
            notifyBlock.Name = self:RandomString()
            notifyBlock.Parent = notify
            notifyBlock.AnchorPoint = Vector2.new(0.5, 0)
            notifyBlock.BackgroundColor3 = theme.Background
            notifyBlock.BackgroundTransparency = 1
            notifyBlock.BorderColor3 = Color3.fromRGB(0, 0, 0)
            notifyBlock.BorderSizePixel = 0
            notifyBlock.Position = UDim2.new(0.5, 0, -1, 0)
            notifyBlock.Size = UDim2.new(1, 0, 1, -12)
            notifyBlock.ClipsDescendants = true
            notifyBlock.ZIndex = 54
            
            uiCorner.CornerRadius = UDim.new(0, 3)
            uiCorner.Parent = notifyBlock
            
            uiStroke.Thickness = 1
            uiStroke.Transparency = 1
            uiStroke.Parent = notifyBlock
            
            icon.Name = self:RandomString()
            icon.Parent = notifyBlock
            icon.BackgroundColor3 = theme.Main
            icon.BackgroundTransparency = 1
            icon.BorderColor3 = Color3.fromRGB(0, 0, 0)
            icon.BorderSizePixel = 0
            icon.Position = UDim2.new(0, 7, 0, 7)
            icon.Size = UDim2.new(0, 18, 0, 18)
            icon.Image = self:GetIcon(config.Icon)
            icon.ImageColor3 = theme.Main
            icon.ImageTransparency = 1
            icon.ZIndex = 55
            
            headerText.Name = self:RandomString()
            headerText.Parent = notifyBlock
            headerText.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            headerText.BackgroundTransparency = 1
            headerText.BorderColor3 = Color3.fromRGB(0, 0, 0)
            headerText.BorderSizePixel = 0
            headerText.Position = UDim2.new(0, 30, 0, 7)
            headerText.Size = UDim2.new(1, 0, 0, 15)
            headerText.ZIndex = 55
            headerText.FontFace = self.Config.FontSemiBold
            headerText.Text = config.Title
            headerText.TextColor3 = theme.Main
            headerText.TextSize = 13
            headerText.TextTransparency = 1
            headerText.TextXAlignment = Enum.TextXAlignment.Left
            
            bodyText.Name = self:RandomString()
            bodyText.Parent = notifyBlock
            bodyText.AnchorPoint = Vector2.new(0, 1)
            bodyText.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            bodyText.BackgroundTransparency = 1
            bodyText.BorderColor3 = Color3.fromRGB(0, 0, 0)
            bodyText.BorderSizePixel = 0
            bodyText.Position = UDim2.new(0, 10, 1, 0)
            bodyText.Size = UDim2.new(1, -15, 1, -29)
            bodyText.ZIndex = 55
            bodyText.FontFace = self.Config.FontSemiBold
            bodyText.Text = config.Content or ""
            bodyText.TextColor3 = theme.TextSecondary
            bodyText.TextSize = 12
            bodyText.TextTransparency = 1
            bodyText.TextWrapped = true
            bodyText.TextXAlignment = Enum.TextXAlignment.Left
            bodyText.TextYAlignment = Enum.TextYAlignment.Top
            
            local function updateScale()
                local titleScale = self:GetTextSize(headerText.Text, headerText.TextSize, Enum.Font.GothamBold)
                local contentScale = self:GetTextSize(bodyText.Text, bodyText.TextSize, Enum.Font.GothamMedium)
                local xScale = (titleScale.X > contentScale.X and titleScale.X) or contentScale.X
                local yScale = (titleScale.Y > contentScale.Y and titleScale.Y) or contentScale.Y
                notify.Size = UDim2.new(0, xScale + 25, 0, yScale + 50)
                self:CreateAnimation(notifyBlock, 0.35, {Position = UDim2.new(0.5, 0, 0, 0)})
            end
            
            task.delay(0.1, function()
                self:CreateAnimation(notifyBlock, 0.25, {BackgroundTransparency = 0.1})
                self:CreateAnimation(uiStroke, 0.25, {Thickness = 2.5, Transparency = 0.9})
                self:CreateAnimation(icon, 0.25, {ImageTransparency = 0})
                self:CreateAnimation(headerText, 0.25, {TextTransparency = 0.2})
                self:CreateAnimation(bodyText, 0.25, {TextTransparency = 0.3})
            end)
            
            updateScale()
            
            task.delay(config.Duration + 0.25, function()
                self:CreateAnimation(notifyBlock, 0.35, {Position = UDim2.new(0.5, 0, 1, 0)})
                self:CreateAnimation(notifyBlock, 0.25, {BackgroundTransparency = 1})
                self:CreateAnimation(uiStroke, 0.25, {Thickness = 1, Transparency = 1})
                self:CreateAnimation(icon, 0.25, {ImageTransparency = 1})
                self:CreateAnimation(headerText, 0.25, {TextTransparency = 1})
                self:CreateAnimation(bodyText, 0.25, {TextTransparency = 1})
                
                task.delay(0.35, function()
                    self:CreateAnimation(notify, 0.5, {Size = UDim2.new(0, 0, 0, 0)})
                    task.wait(0.5)
                    notify:Destroy()
                end)
            end)
        end,
    })
    
    self.__NOTIFIER_CACHE = res
    return res
end

