                    scroll.ScrollBarThickness = 0
                    
                    layout.Parent = scroll
                    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
                    layout.SortOrder = Enum.SortOrder.LayoutOrder
                    layout.Padding = UDim.new(0, 5)
                    
                    spaceBox.Name = self:RandomString()
                    spaceBox.Parent = scroll
                    spaceBox.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                    spaceBox.BorderColor3 = Color3.fromRGB(0, 0, 0)
                    spaceBox.BorderSizePixel = 0
                    spaceBox.Size = UDim2.new(0, 0, 0, 3)
                    
                    local spawnThread
                    local function toggleExt(bool)
                        if bool then
                            bindable:SetAttribute('V', true)
                            bindable:Fire(true)
                            
                            local size = math.clamp(layout.AbsoluteContentSize.Y + 15, 0, 200)
                            extFrame.Position = UDim2.fromOffset(btn.AbsolutePosition.X + 100, btn.AbsolutePosition.Y + (size / 2))
                            self:CreateAnimation(extFrame, 0.45, {Size = UDim2.new(0, 200, 0, size)})
                            self:CreateAnimation(shadow, 0.45, {ImageTransparency = 0.75})
                            self:CreateAnimation(stroke, 0.45, {Transparency = 0})
                            
                            if spawnThread then
                                task.cancel(spawnThread)
                                spawnThread = nil
                            end
                            
                            spawnThread = task.spawn(function()
                                while true do
                                    task.wait(0.1)
                                    local size = math.clamp(layout.AbsoluteContentSize.Y + 15, 0, 200)
                                    local pos = UDim2.fromOffset(btn.AbsolutePosition.X + 100, btn.AbsolutePosition.Y + (size / 2))
                                    self:CreateAnimation(extFrame, 0.35, {Position = pos})
                                end
                            end)
                        else
                            if spawnThread then
                                task.cancel(spawnThread)
                                spawnThread = nil
                            end
                            
                            bindable:SetAttribute('V', false)
                            bindable:Fire(false)
                            self:CreateAnimation(extFrame, 0.45, {Size = UDim2.new(0, 200, 0, 0)})
                            self:CreateAnimation(shadow, 0.45, {ImageTransparency = 1})
                            self:CreateAnimation(stroke, 0.45, {Transparency = 1})
                        end
                    end
                    
                    bindable:SetAttribute('V', false)
                    toggleExt(false)
                    
                    btn.MouseButton1Click:Connect(function()
                        toggleExt(true)
                    end)
                    
                    UserInputService.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
                            if not self:IsMouseOverFrame(extFrame) and not self.Config.GlobalEnvironment.IS_HOLD_COLOR_PICKER then
                                toggleExt(false)
                            end
                        end
                    end)
                    
                    return self:CreateElements(scroll, scroll.ZIndex, bindable)
                end
                return createOptionMenu(optionButton)
            end) or nil,
        })
        
        if config.Flag then
            self.Config.WFlags[window][config.Flag .. "Toggle"] = response
        end
        
        return response
    end
    
