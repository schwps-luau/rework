        NumberSequenceKeypoint.new(0.00, 0.00),
        NumberSequenceKeypoint.new(1.00, 1.00)
    }
    bottomGradient.Parent = bottomShadow
    
    bottomShadowCorner.CornerRadius = UDim.new(0, 5)
    bottomShadowCorner.Parent = bottomShadow
    
    self:Drag(mainFrame, mainFrame, 0.1)
    
    -- Toggle UI function
    local function toggleUI(bool)
        window.Signal:Fire(bool)
        
        if bool then
            for _, menu in next, window.Menus do
                if menu.ValueSelect then
                    menu.ValueSelect(false)
                end
            end
            
            if window.MenuSelected then
                window.MenuSelected.ValueSelect(true)
            end
            
            self:CreateAnimation(mainFrame, 0.15, {Size = windowConfig.Scale, BackgroundTransparency = 0})
            self:CreateAnimation(header, 0.5, {BackgroundTransparency = 0})
            self:CreateAnimation(headerLine, 0.5, {BackgroundTransparency = 0})
            self:CreateAnimation(bottom, 0.5, {BackgroundTransparency = 0})
            self:CreateAnimation(bottomLine, 0.5, {BackgroundTransparency = 0})
            self:CreateAnimation(headerLineShadow, 0.5, {BackgroundTransparency = 0.5})
            self:CreateAnimation(bottomShadow, 0.5, {BackgroundTransparency = 0.5})
            self:CreateAnimation(headerText, 0.35, {TextStrokeTransparency = 0.64, TextTransparency = 0})
            self:CreateAnimation(userIcon, 0.45, {ImageTransparency = 0, Position = UDim2.new(1, -10, 0.5, 0)})
            self:CreateAnimation(userName, 0.35, {TextTransparency = 0, Position = UDim2.new(1, -40, 0, 3)})
            self:CreateAnimation(expireDays, 0.5, {TextTransparency = 0, Position = UDim2.new(1, -40, 0, 16)})
            self:CreateAnimation(userIconStroke, 0.35, {Thickness = 2.5, Transparency = 0.9})
            self:CreateAnimation(dropShadow, 0.35, {ImageTransparency = 0.75})
        else
            table.clear(self.Config.DragBlacklist)
            
            for _, menu in next, window.Menus do
                if menu.ValueSelect then
                    menu.ValueSelect(false)
                end
            end
            
            self:CreateAnimation(userIconStroke, 0.35, {Thickness = 0, Transparency = 1})
            self:CreateAnimation(userIcon, 0.35, {ImageTransparency = 1, Position = UDim2.new(1, -10, 0.5, 0)})
            self:CreateAnimation(userName, 0.35, {TextTransparency = 1, Position = UDim2.new(1, -40, 0, 3)})
            self:CreateAnimation(expireDays, 0.1, {TextTransparency = 1, Position = UDim2.new(1, -40, 0, 16)})
            self:CreateAnimation(headerText, 0.35, {TextStrokeTransparency = 1, TextTransparency = 1})
            self:CreateAnimation(bottomShadow, 0.5, {BackgroundTransparency = 1})
            self:CreateAnimation(headerLineShadow, 0.5, {BackgroundTransparency = 1})
            self:CreateAnimation(mainFrame, 0.75, {BackgroundTransparency = 1})
            self:CreateAnimation(header, 0.5, {BackgroundTransparency = 1})
            self:CreateAnimation(headerLine, 0.5, {BackgroundTransparency = 1})
            self:CreateAnimation(bottom, 0.5, {BackgroundTransparency = 1})
            self:CreateAnimation(bottomLine, 0.5, {BackgroundTransparency = 1})
            self:CreateAnimation(dropShadow, 0.35, {ImageTransparency = 1})
        end
    end
    
    -- Setup GUI parent
    gui.Name = self:RandomString()
    gui.Parent = CoreGui
    gui.ResetOnSpawn = false
    gui.IgnoreGuiInset = true
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Global
    
    table.insert(self.Config.Windows, gui)
    
    -- Keybind
    UserInputService.InputBegan:Connect(function(input, isTyping)
        if not isTyping then
            if input.KeyCode == windowConfig.Keybind or input.KeyCode.Name == windowConfig.Keybind then
                window.Toggle = not window.Toggle
                toggleUI(window.Toggle)
            end
        end
    end)
    
    -- Window methods
    function window:SetUsername(name)
        userName.Text = name or Client.DisplayName
    end
    
    function window:SetProfile(icon)
        userIcon.Image = icon or Players:GetUserThumbnailAsync(Client.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size180x180)
    end
    
    function window:SetExpire(str)
        expireDays.Text = string.format("<font transparency=\"0.5\">expires:</font> <font color=\"#f53174\">%s</font>", str)
    end
    
    function window:GetFlags()
        return self.Config.WFlags[gui]
    end
    
    function window:RefreshTheme(newTheme)
        theme = newTheme
        mainFrame.BackgroundColor3 = theme.Background
        header.BackgroundColor3 = theme.BackgroundTertiary
        headerLine.BackgroundColor3 = theme.Border
        headerText.TextColor3 = theme.Text
        bottom.BackgroundColor3 = theme.BackgroundTertiary
        bottomLine.BackgroundColor3 = theme.Border
        userName.TextColor3 = theme.Text
        expireDays.TextColor3 = theme.Text
        userIconStroke.Color = theme.Border
    end
    
    -- Add Menu function
