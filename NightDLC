local Library = {
    Accent = Color3.fromRGB(180, 50, 180),
    ToggleKey = Enum.KeyCode.RightShift,
    _Config = {
        WindowWidth = 240,
        ModuleHeight = 38,
        Spacing = 10,
        StartY = 220,
        Transparency = 0.5, 
        FontBold = Enum.Font.GothamBold, 
        FontMedium = Enum.Font.GothamMedium
    },
    _Visible = true,
    _CurrentX = 20,
    _Initialized = false,
    _Keybinds = {},
    _Modules = {},
    _SearchActive = false
}

local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Lighting = game:GetService("Lighting")

-- Эффект размытия
local MenuBlur = Instance.new("BlurEffect", Lighting)
MenuBlur.Size = 18
MenuBlur.Enabled = true

local function SafeTween(obj, goal)
    if not obj then return end
    TweenService:Create(obj, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), goal):Play()
end

local function MakeDraggable(obj)
    local dragging, dragInput, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = obj.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

function Library:InitGlobal()
    if self._Initialized then return end
    self._Initialized = true
    
    local HUD = Instance.new("ScreenGui", CoreGui)
    HUD.Name = "Night_Core_UI"
    HUD.ResetOnSpawn = false
    self.MainGui = HUD

    -- ПОИСК (Ctrl + F)
    local SearchFrame = Instance.new("Frame", HUD)
    SearchFrame.Name = "SearchUI"
    SearchFrame.Size = UDim2.new(0, 250, 0, 40)
    SearchFrame.Position = UDim2.new(0.5, -125, 0.85, 0)
    SearchFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 18)
    SearchFrame.BackgroundTransparency = 0.2
    SearchFrame.Visible = false
    Instance.new("UICorner", SearchFrame)
    Instance.new("UIStroke", SearchFrame).Color = Color3.fromRGB(65, 65, 70)
    
    local SearchInput = Instance.new("TextBox", SearchFrame)
    SearchInput.Size = UDim2.new(1, -20, 1, 0)
    SearchInput.Position = UDim2.new(0, 10, 0, 0)
    SearchInput.BackgroundTransparency = 1
    SearchInput.PlaceholderText = "Поиск: Ctrl + F"
    SearchInput.Text = ""
    SearchInput.Font = self._Config.FontMedium
    SearchInput.TextSize = 14
    SearchInput.TextColor3 = Color3.new(1, 1, 1)

    SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
        local query = SearchInput.Text:lower()
        for _, mod in pairs(self._Modules) do
            mod.Frame.Visible = mod.Name:lower():find(query) ~= nil
        end
    end)

    UserInputService.InputBegan:Connect(function(i, g)
        if not g and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and i.KeyCode == Enum.KeyCode.F then
            self._SearchActive = not self._SearchActive
            SearchFrame.Visible = self._SearchActive
            if self._SearchActive then 
                SearchInput:CaptureFocus() 
            else 
                SearchInput:ReleaseFocus()
                SearchInput.Text = "" 
            end
        end
    end)
end

function Library:CreateWindow(name)
    self:InitGlobal()
    local cfg = self._Config

    local Main = Instance.new("Frame", self.MainGui)
    Main.Name = name
    Main.Size = UDim2.new(0, cfg.WindowWidth, 0, 40)
    Main.Position = UDim2.new(0, self._CurrentX, 0, cfg.StartY)
    Main.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    Main.BackgroundTransparency = cfg.Transparency
    Instance.new("UICorner", Main)
    Instance.new("UIStroke", Main).Color = Color3.fromRGB(60, 60, 65)
    
    self._CurrentX = self._CurrentX + cfg.WindowWidth + cfg.Spacing
    MakeDraggable(Main)

    local Header = Instance.new("TextLabel", Main)
    Header.Size = UDim2.new(1, 0, 0, 40)
    Header.Text = name
    Header.Font = cfg.FontBold
    Header.TextColor3 = Color3.new(1, 1, 1)
    Header.BackgroundTransparency = 1
    Header.TextSize = 15
    
    local Scroll = Instance.new("ScrollingFrame", Main)
    Scroll.Position = UDim2.new(0, 0, 0, 40)
    Scroll.Size = UDim2.new(1, 0, 0, 0)
    Scroll.BackgroundTransparency = 1
    Scroll.ScrollBarThickness = 0
    local Layout = Instance.new("UIListLayout", Scroll)
    Layout.Padding = UDim.new(0, 2)
    Layout.HorizontalAlignment = "Center"

    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local h = math.min(Layout.AbsoluteContentSize.Y + 10, 550)
        Scroll.Size = UDim2.new(1, 0, 0, h)
        Main.Size = UDim2.new(0, cfg.WindowWidth, 0, h + 45)
    end)

    local Window = {}
    function Window:CreateModule(modName, callback)
        local Enabled, Opened = false, false
        local MFrame = Instance.new("Frame", Scroll)
        MFrame.Size = UDim2.new(1, -8, 0, cfg.ModuleHeight)
        MFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
        MFrame.BackgroundTransparency = 0.3
        MFrame.ClipsDescendants = true
        Instance.new("UICorner", MFrame, {CornerRadius = UDim.new(0, 4)})

        local MBtn = Instance.new("TextButton", MFrame)
        MBtn.Size = UDim2.new(1, 0, 0, cfg.ModuleHeight)
        MBtn.BackgroundTransparency = 1
        MBtn.Text = "  " .. modName
        MBtn.Font = cfg.FontMedium
        MBtn.TextSize = 13
        MBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
        MBtn.TextXAlignment = 0
        
        -- Три точки
        local Dots = Instance.new("TextLabel", MFrame)
        Dots.Size = UDim2.new(0, 20, 0, cfg.ModuleHeight)
        Dots.Position = UDim2.new(1, -25, 0, 0)
        Dots.BackgroundTransparency = 1
        Dots.Text = "..."
        Dots.Font = cfg.FontBold
        Dots.TextSize = 14
        Dots.TextColor3 = Color3.fromRGB(100, 100, 100)

        local Nodes = Instance.new("Frame", MFrame)
        Nodes.Position = UDim2.new(0, 0, 0, cfg.ModuleHeight)
        Nodes.Size = UDim2.new(1, 0, 0, 0)
        Nodes.BackgroundTransparency = 1
        local NLayout = Instance.new("UIListLayout", Nodes)
        NLayout.Padding = UDim.new(0, 4)
        NLayout.HorizontalAlignment = "Center"

        table.insert(Library._Modules, {Name = modName, Frame = MFrame})

        local function UpdateSize()
            local targetSize = Opened and (cfg.ModuleHeight + NLayout.AbsoluteContentSize.Y + 10) or cfg.ModuleHeight
            SafeTween(MFrame, {Size = UDim2.new(1, -8, 0, targetSize)})
        end
        NLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateSize)

        MBtn.MouseButton1Click:Connect(function()
            Enabled = not Enabled
            -- Плавное окрашивание фона в акцентный цвет
            SafeTween(MFrame, {BackgroundColor3 = Enabled and Library.Accent or Color3.fromRGB(25, 25, 30)})
            SafeTween(MBtn, {TextColor3 = Enabled and Color3.new(1, 1, 1) or Color3.fromRGB(180, 180, 180)})
            callback(Enabled)
        end)

        MBtn.MouseButton2Click:Connect(function()
            Opened = not Opened
            UpdateSize()
            SafeTween(Dots, {Rotation = Opened and 90 or 0})
        end)

        local Mod = {}
        function Mod:CreateSlider(n, min, max, def, cb)
            local f = Instance.new("Frame", Nodes); f.Size = UDim2.new(0.9, 0, 0, 32); f.BackgroundTransparency = 1
            local t = Instance.new("TextLabel", f); t.Size = UDim2.new(1, 0, 0, 16); t.Text = n .. ": " .. def; t.Font = cfg.FontMedium; t.TextSize = 11; t.TextColor3 = Color3.new(1, 1, 1); t.BackgroundTransparency = 1; t.TextXAlignment = 0
            local b = Instance.new("Frame", f); b.Size = UDim2.new(1, 0, 0, 4); b.Position = UDim2.new(0, 0, 0.75, 0); b.BackgroundColor3 = Color3.fromRGB(45, 45, 50); Instance.new("UICorner", b)
            local fill = Instance.new("Frame", b); fill.Size = UDim2.new((def-min)/(max-min), 0, 1, 0); fill.BackgroundColor3 = Color3.new(1, 1, 1); Instance.new("UICorner", fill)
            
            local function Update(input)
                local per = math.clamp((input.Position.X - b.AbsolutePosition.X) / b.AbsoluteSize.X, 0, 1)
                local val = math.floor(min + (max - min) * per)
                fill.Size = UDim2.new(per, 0, 1, 0); t.Text = n .. ": " .. val; cb(val)
            end
            
            local active = false
            b.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then active = true; Update(i) end end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then active = false end end)
            UserInputService.InputChanged:Connect(function(i) if active and i.UserInputType == Enum.UserInputType.MouseMovement then Update(i) end end)
            return Mod
        end

        function Mod:CreateButton(n, cb)
            local b = Instance.new("TextButton", Nodes); b.Size = UDim2.new(0.95, 0, 0, 26); b.BackgroundColor3 = Color3.fromRGB(40, 40, 45); b.Text = n; b.Font = cfg.FontMedium; b.TextColor3 = Color3.new(1, 1, 1); b.TextSize = 12; Instance.new("UICorner", b)
            b.MouseButton1Click:Connect(cb); return Mod
        end

        return Mod
    end
    return Window
end

-- Система скрытия/показа меню
UserInputService.InputBegan:Connect(function(i, g)
    if not g and i.KeyCode == Library.ToggleKey then
        Library._Visible = not Library._Visible
        MenuBlur.Enabled = Library._Visible
        if Library.MainGui then
            for _, v in pairs(Library.MainGui:GetChildren()) do
                if v:IsA("Frame") and v.Name ~= "SearchUI" then 
                    v.Visible = Library._Visible 
                end
            end
        end
    end
end)

return Library
