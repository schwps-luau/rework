local Library = {
    Categories = {},
    Modules = {},
    Accent = Color3.fromRGB(180, 50, 180),
    -- Глобальные настройки расположения
    _Config = {
        StartX = 20,
        CurrentX = 20,
        StartY = 80,
        Spacing = 200, -- Расстояние между окнами
        MaxPerRow = 5  -- Сколько окон в одном ряду перед переходом на новый
    }
}

local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local function Tween(obj, time, goal)
    TweenService:Create(obj, TweenInfo.new(time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), goal):Play()
end

-- [ ПЕРЕДЕЛАННЫЙ ВАТЕРМАРК - СТИЛЬ NIGHT ]
function Library:InitHUD()
    local HUD = Instance.new("ScreenGui", CoreGui)
    HUD.Name = "NightHUD"
    
    local Container = Instance.new("Frame", HUD)
    Container.Size = UDim2.new(0, 600, 0, 30)
    Container.Position = UDim2.new(0, 15, 0, 15)
    Container.BackgroundTransparency = 1

    local Layout = Instance.new("UIListLayout", Container)
    Layout.FillDirection = Enum.FillDirection.Horizontal
    Layout.Padding = UDim.new(0, 8)

    local function CreateBlock(text)
        local f = Instance.new("Frame", Container)
        f.BackgroundColor3 = Color3.fromRGB(10, 10, 12)
        f.BackgroundTransparency = 0 -- Полностью непрозрачный
        f.AutomaticSize = Enum.AutomaticSize.XY
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 4)
        
        local s = Instance.new("UIStroke", f)
        s.Color = Color3.fromRGB(40, 40, 45)
        s.Thickness = 1
        
        local p = Instance.new("UIPadding", f)
        p.PaddingLeft = UDim.new(0, 10); p.PaddingRight = UDim.new(0, 10)

        local l = Instance.new("TextLabel", f)
        l.Size = UDim2.new(0, 0, 0, 26)
        l.AutomaticSize = Enum.AutomaticSize.X
        l.Text = text
        l.RichText = true
        l.TextColor3 = Color3.fromRGB(255, 255, 255)
        l.Font = Enum.Font.GothamMedium
        l.TextSize = 13
        l.BackgroundTransparency = 1
        return l
    end

    local brand = CreateBlock("<font color='#B432B4'>N</font>ight <font color='#888888'>Alpha</font>")
    local stats = CreateBlock("0 <font color='#B432B4'>Fps</font> | 00:00:00")
    local pos = CreateBlock("0, 0, 0 | <font color='#B432B4'>0 Ping</font>")

    RunService.RenderStepped:Connect(function(dt)
        local fps = math.floor(1/dt)
        stats.Text = fps .. " <font color='#B432B4'>Fps</font> | " .. os.date("%X")
        
        local lp = game.Players.LocalPlayer
        if lp and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            local p = lp.Character.HumanoidRootPart.Position
            pos.Text = math.floor(p.X) .. ", " .. math.floor(p.Y) .. ", " .. math.floor(p.Z) .. " | <font color='#B432B4'>0 Ping</font>"
        end
    end)
end

-- [ ФУНКЦИЯ СОЗДАНИЯ ОКНА С АВТО-СЕТКОЙ ]
function Library:CreateWindow(categoryName)
    if not self.MainGui then
        self.MainGui = Instance.new("ScreenGui", CoreGui)
        self.MainGui.Name = "NightDLC_GUI"
        self:InitHUD()
    end

    -- Рассчитываем позицию для нового окна
    local xPos = self._Config.CurrentX
    local yPos = self._Config.StartY
    
    -- Сдвигаем CurrentX для следующего окна
    self._Config.CurrentX = self._Config.CurrentX + self._Config.Spacing
    
    -- Если окон слишком много в ряду, переходим на новый ряд
    if self._Config.CurrentX > (self._Config.Spacing * self._Config.MaxPerRow) then
        self._Config.CurrentX = self._Config.StartX
        self._Config.StartY = self._Config.StartY + 300 -- Сдвиг вниз (высота окна)
    end

    local Category = {}
    
    local Main = Instance.new("Frame", self.MainGui)
    Main.Name = categoryName
    Main.Size = UDim2.new(0, 180, 0, 38)
    Main.Position = UDim2.new(0, xPos, 0, yPos)
    Main.BackgroundColor3 = Color3.fromRGB(15, 15, 18)
    Main.BackgroundTransparency = 0 -- Непрозрачный
    Main.BorderSizePixel = 0
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 5)

    local Stroke = Instance.new("UIStroke", Main)
    Stroke.Color = Color3.fromRGB(40, 40, 45)
    Stroke.Thickness = 1.2

    local Header = Instance.new("TextLabel", Main)
    Header.Size = UDim2.new(1, 0, 1, 0)
    Header.Text = categoryName
    Header.TextColor3 = Color3.fromRGB(255, 255, 255)
    Header.Font = Enum.Font.GothamBold
    Header.TextSize = 14
    Header.BackgroundTransparency = 1

    local Container = Instance.new("Frame", Main)
    Container.Name = "Content"
    Container.Position = UDim2.new(0, 0, 1, 2)
    Container.Size = UDim2.new(1, 0, 0, 0)
    Container.BackgroundTransparency = 1
    
    local Layout = Instance.new("UIListLayout", Container)
    Layout.Padding = UDim.new(0, 1)

    -- Перетаскивание
    local dragStart, startPosFrame, dragging
    Main.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = i.Position; startPosFrame = Main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = i.Position - dragStart
            Main.Position = UDim2.new(startPosFrame.X.Scale, startPosFrame.X.Offset + delta.X, startPosFrame.Y.Scale, startPosFrame.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

    function Category:CreateModule(name, callback)
        local mod = {Enabled = false}
        
        local MFrame = Instance.new("Frame", Container)
        MFrame.Size = UDim2.new(1, 0, 0, 30)
        MFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 23)
        MFrame.BorderSizePixel = 0
        
        local MBtn = Instance.new("TextButton", MFrame)
        MBtn.Size = UDim2.new(1, 0, 1, 0)
        MBtn.BackgroundTransparency = 1
        MBtn.Text = "  " .. name
        MBtn.TextColor3 = Color3.fromRGB(160, 160, 160)
        MBtn.Font = Enum.Font.Gotham
        MBtn.TextSize = 13
        MBtn.TextXAlignment = 0
        MBtn.AutoButtonColor = false

        -- Индикатор включения (полоска справа)
        local Indicator = Instance.new("Frame", MFrame)
        Indicator.Size = UDim2.new(0, 2, 0, 0)
        Indicator.Position = UDim2.new(1, -2, 0.5, 0)
        Indicator.AnchorPoint = Vector2.new(0, 0.5)
        Indicator.BackgroundColor3 = Library.Accent
        Indicator.BorderSizePixel = 0

        MBtn.MouseButton1Click:Connect(function()
            mod.Enabled = not mod.Enabled
            local targetText = mod.Enabled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(160, 160, 160)
            local targetIndHeight = mod.Enabled and 20 or 0
            
            Tween(MBtn, 0.2, {TextColor3 = targetText})
            Tween(Indicator, 0.2, {Size = UDim2.new(0, 2, 0, targetIndHeight)})
            
            callback(mod.Enabled)
        end)

        Container.Size = UDim2.new(1, 0, 0, Layout.AbsoluteContentSize.Y)
        return mod
    end

    return Category
end

return Library
