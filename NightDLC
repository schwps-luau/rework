local Library = {
    Accent = Color3.fromRGB(180, 50, 180),
    ToggleKey = Enum.KeyCode.RightShift,
    _Config = {
        WindowWidth = 230,
        Spacing = 15,
        StartY = 300,
        Transparency = 0.5, 
        FontBold = Enum.Font.GothamBold, 
        FontBlack = Enum.Font.GothamBlack,
        FontMedium = Enum.Font.GothamMedium
    },
    _Visible = true,
    _CurrentX = 35,
    _Initialized = false,
    _Keybinds = {},
    _LastKBState = "",
    _Objects = {
        Accents = {},     -- Объекты, меняющие цвет
        Transparents = {}, -- Объекты, меняющие прозрачность
        WatermarkTitle = "Night DLC",
    }
}

-- [ ФУНКЦИИ УПРАВЛЕНИЯ (Взамен setmetatable) ] --

function Library:SetAccent(color)
    self.Accent = color
    for _, obj in pairs(self._Objects.Accents) do
        if obj:IsA("Frame") then 
            obj.BackgroundColor3 = color
        elseif obj:IsA("UIStroke") then 
            obj.Color = color
        elseif obj:IsA("TextLabel") or obj:IsA("TextButton") then 
            obj.TextColor3 = color 
        end
    end
end

function Library:SetTransparency(value)
    self._Config.Transparency = value
    for _, obj in pairs(self._Objects.Transparents) do
        if obj:IsA("Frame") or obj:IsA("ScrollingFrame") or obj:IsA("TextButton") then
            obj.BackgroundTransparency = value
        end
    end
end

function Library:SetWatermark(state)
    if self.MainGui and self.MainGui:FindFirstChild("HUD_Container") then
        self.MainGui.HUD_Container.Visible = state
    end
end

function Library:SetWatermarkText(text)
    if self._Objects.WatermarkTitle then
        self._Objects.WatermarkTitle.Text = text
    end
end

function Library:SetKeybindsVisible(state)
    if self.MainGui and self.MainGui:FindFirstChild("KeybindList") then
        self.MainGui.KeybindList.Visible = state
    end
end

-- [ ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ ] --

local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Stats = game:GetService("Stats")
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")

local function SafeTween(obj, goal)
    if not obj then return end
    TweenService:Create(obj, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), goal):Play()
end

local function MakeDraggable(obj)
    local dragging, dragInput, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = obj.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    obj.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging and dragInput then
            local delta = dragInput.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- [ ИНИЦИАЛИЗАЦИЯ И СОЗДАНИЕ UI ] --

function Library:InitHUD()
    local HUD = Instance.new("ScreenGui", CoreGui); HUD.Name = "NightHUD"; Library.MainGui = HUD
    
    local Container = Instance.new("Frame", HUD); Container.Name = "HUD_Container"
    Container.Size = UDim2.new(0, 600, 0, 100); Container.Position = UDim2.new(0, 20, 0, 20); Container.BackgroundTransparency = 1
    Instance.new("UIListLayout", Container).Padding = UDim.new(0, 8)

    local function CreateSection(parent, text)
        local f = Instance.new("Frame", parent); f.BackgroundColor3 = Color3.fromRGB(12, 12, 15); f.AutomaticSize = Enum.AutomaticSize.XY
        f.BackgroundTransparency = Library._Config.Transparency
        table.insert(Library._Objects.Transparents, f) -- Регистрируем для прозрачности
        
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 5); Instance.new("UIStroke", f).Color = Color3.fromRGB(65, 65, 70)
        local l = Instance.new("TextLabel", f); l.Size = UDim2.new(0, 0, 0, 26); l.AutomaticSize = Enum.AutomaticSize.X; l.RichText = true; l.Text = text; l.TextColor3 = Color3.fromRGB(255, 255, 255); l.Font = Library._Config.FontBold; l.TextSize = 13; l.BackgroundTransparency = 1
        Instance.new("UIPadding", f).PaddingLeft = UDim.new(0, 10); f.UIPadding.PaddingRight = UDim.new(0, 10)
        return l
    end

    local Row1 = Instance.new("Frame", Container); Row1.Size = UDim2.new(1, 0, 0, 28); Row1.BackgroundTransparency = 1
    Instance.new("UIListLayout", Row1).FillDirection = "Horizontal"; Row1.UIListLayout.Padding = UDim.new(0, 8)
    local Row2 = Row1:Clone(); Row2.Parent = Container

    Library._Objects.WatermarkTitle = CreateSection(Row1, "<font color='#B432B4'>N</font>ight DLC")
    CreateSection(Row1, "User: <font color='#B432B4'>" .. Players.LocalPlayer.DisplayName .. "</font>")
    
    local fpsStat = CreateSection(Row2, "0 Fps"); local pingStat = CreateSection(Row2, "0 Ms")
    
    local lastUpdate = 0
    RunService.RenderStepped:Connect(function(dt)
        if tick() - lastUpdate >= 0.5 then
            lastUpdate = tick()
            fpsStat.Text = math.floor(1/dt) .. " <font color='#B432B4'>Fps</font>"
            pingStat.Text = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) .. " <font color='#B432B4'>Ms</font>"
        end
    end)

    -- KEYBIND LIST
    local KBGui = Instance.new("Frame", HUD); KBGui.Name = "KeybindList"; KBGui.Size = UDim2.new(0, 180, 0, 32); KBGui.Position = UDim2.new(0, 20, 0, 350)
    KBGui.BackgroundColor3 = Color3.fromRGB(15, 15, 18); KBGui.BackgroundTransparency = Library._Config.Transparency; Instance.new("UICorner", KBGui); Instance.new("UIStroke", KBGui).Color = Color3.fromRGB(65, 65, 70)
    table.insert(Library._Objects.Transparents, KBGui)

    local KBLine = Instance.new("Frame", KBGui); KBLine.Size = UDim2.new(1, 0, 0, 2); KBLine.BackgroundColor3 = Library.Accent; KBLine.BorderSizePixel = 0; Instance.new("UICorner", KBLine)
    table.insert(Library._Objects.Accents, KBLine) -- Регистрируем для цвета

    local KBTitle = Instance.new("TextLabel", KBGui); KBTitle.Size = UDim2.new(1, 0, 0, 32); KBTitle.Text = "Keybinds"; KBTitle.Font = Library._Config.FontBlack; KBTitle.TextSize = 13; KBTitle.TextColor3 = Color3.fromRGB(255, 255, 255); KBTitle.BackgroundTransparency = 1
    local KBList = Instance.new("Frame", KBGui); KBList.Position = UDim2.new(0, 0, 0, 32); KBList.Size = UDim2.new(1, 0, 0, 0); KBList.BackgroundTransparency = 1
    Instance.new("UIListLayout", KBList).Padding = UDim.new(0, 2); Instance.new("UIPadding", KBList).PaddingLeft = UDim.new(0, 10); KBList.UIPadding.PaddingRight = UDim.new(0, 10)
    
    MakeDraggable(KBGui)

    RunService.RenderStepped:Connect(function()
        local state = ""
        for n, d in pairs(Library._Keybinds) do state = state .. n .. tostring(d.Enabled) .. (d.Key or "") end
        if Library._LastKBState ~= state then
            Library._LastKBState = state
            for _, v in pairs(KBList:GetChildren()) do if v:IsA("TextLabel") then v:Destroy() end end
            local count = 0
            for n, d in pairs(Library._Keybinds) do
                count = count + 1
                local l = Instance.new("TextLabel", KBList); l.Size = UDim2.new(1, 0, 0, 22); l.BackgroundTransparency = 1; l.RichText = true
                l.Text = string.format("%s <font color='#808080'>[%s]</font>", n, d.Key or "None")
                l.Font = Library._Config.FontBold; l.TextSize = 11; l.TextXAlignment = 0
                l.TextColor3 = d.Enabled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(140, 140, 140)
            end
            SafeTween(KBGui, {Size = UDim2.new(0, 180, 0, 35 + (count * 24))})
        end
    end)
end

function Library:CreateWindow(name)
    local cfg = self._Config
    if not self._Initialized then self:InitHUD(); self._Initialized = true end

    self.TotalWindows = self.TotalWindows + 1
    local Main = Instance.new("Frame", self.MainGui)
    Main.Name = name; Main.Size = UDim2.new(0, cfg.WindowWidth, 0, 40); Main.Position = UDim2.new(0, self._CurrentX, 0, cfg.StartY)
    Main.BackgroundColor3 = Color3.fromRGB(15, 15, 18); Main.BackgroundTransparency = cfg.Transparency
    table.insert(self._Objects.Transparents, Main)

    Instance.new("UICorner", Main); Instance.new("UIStroke", Main).Color = Color3.fromRGB(65, 65, 70)
    self._CurrentX = self._CurrentX + cfg.WindowWidth + cfg.Spacing

    local Header = Instance.new("TextLabel", Main); Header.Size = UDim2.new(1, 0, 0, 40); Header.Text = name; Header.Font = cfg.FontBlack; 
