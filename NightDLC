local Library = {
    Accent = Color3.fromRGB(180, 50, 180),
    ToggleKey = Enum.KeyCode.RightShift, -- Установлен RightShift
    _Config = {
        WindowWidth = 230,
        Spacing = 15,
        StartY = 220,
        MaxButtonsVisible = 12,
        TotalWindows = 5 
    },
    _Visible = true,
    _CurrentX = 0,
    _Initialized = false,
    _Keybinds = {} 
}

local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Stats = game:GetService("Stats")
local Players = game:GetService("Players")

local function Tween(obj, time, goal)
    if not obj then return end
    local info = TweenInfo.new(time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    TweenService:Create(obj, info, goal):Play()
end

local function GetPing()
    local network = Stats.Network
    if network and network:FindFirstChild("ServerStatsItem") and network.ServerStatsItem:FindFirstChild("Data Ping") then
        return math.floor(network.ServerStatsItem["Data Ping"]:GetValue())
    end
    return 0
end

function Library:InitKeybindList()
    local KBGui = Instance.new("Frame", self.MainGui)
    KBGui.Name = "KeybindList"
    KBGui.Size = UDim2.new(0, 180, 0, 30)
    KBGui.Position = UDim2.new(0, 20, 0, 350)
    KBGui.BackgroundColor3 = Color3.fromRGB(15, 15, 18)
    Instance.new("UICorner", KBGui).CornerRadius = UDim.new(0, 8)
    local s = Instance.new("UIStroke", KBGui)
    s.Color = Color3.fromRGB(65, 65, 70); s.Thickness = 2.5
    
    local Title = Instance.new("TextLabel", KBGui)
    Title.Size = UDim2.new(1, 0, 0, 30)
    Title.Text = "Keybinds"; Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.Font = Enum.Font.GothamBold; Title.TextSize = 14; Title.BackgroundTransparency = 1

    local List = Instance.new("Frame", KBGui)
    List.Name = "List"; List.Position = UDim2.new(0, 0, 0, 30); List.Size = UDim2.new(1, 0, 0, 0)
    List.BackgroundTransparency = 1
    Instance.new("UIListLayout", List).Padding = UDim.new(0, 5)

    RunService.RenderStepped:Connect(function()
        KBGui.Visible = self._Visible
        if not self._Visible then return end
        for _, child in pairs(List:GetChildren()) do if child:IsA("TextLabel") then child:Destroy() end end
        local count = 0
        for name, key in pairs(self._Keybinds) do
            count = count + 1
            local l = Instance.new("TextLabel", List)
            l.Size = UDim2.new(1, -20, 0, 20); l.BackgroundTransparency = 1; l.Text = "  " .. name .. ": " .. key
            l.TextColor3 = Color3.fromRGB(180, 180, 180); l.Font = Enum.Font.GothamMedium; l.TextSize = 12; l.TextXAlignment = 0
        end
        KBGui.Size = UDim2.new(0, 180, 0, 30 + (count * 25))
    end)
end

function Library:InitHUD()
    local HUD = Instance.new("ScreenGui", CoreGui)
    HUD.Name = "NightHUD_Final"
    self.MainGui = HUD
    local LayoutContainer = Instance.new("Frame", HUD)
    LayoutContainer.Size = UDim2.new(0, 600, 0, 100); LayoutContainer.Position = UDim2.new(0, 20, 0, 20); LayoutContainer.BackgroundTransparency = 1
    
    local function CreateRow()
        local r = Instance.new("Frame", LayoutContainer); r.Size = UDim2.new(1, 0, 0, 28); r.BackgroundTransparency = 1
        local l = Instance.new("UIListLayout", r); l.FillDirection = Enum.FillDirection.Horizontal; l.Padding = UDim.new(0, 8)
        return r
    end
    local Row1, Row2 = CreateRow(), CreateRow()
    Instance.new("UIListLayout", LayoutContainer).Padding = UDim.new(0, 8)

    local function CreateSection(parent, defaultText)
        local f = Instance.new("Frame", parent); f.BackgroundColor3 = Color3.fromRGB(12, 12, 15); f.AutomaticSize = Enum.AutomaticSize.XY
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 5)
        local s = Instance.new("UIStroke", f); s.Color = Color3.fromRGB(65, 65, 70); s.Thickness = 2 
        local l = Instance.new("TextLabel", f); l.Size = UDim2.new(0, 0, 0, 26); l.AutomaticSize = Enum.AutomaticSize.X; l.RichText = true; l.Text = defaultText; l.TextColor3 = Color3.fromRGB(255, 255, 255); l.Font = Enum.Font.GothamBold; l.TextSize = 13; l.BackgroundTransparency = 1
        Instance.new("UIPadding", f).PaddingLeft = UDim.new(0, 10); Instance.new("UIPadding", f).PaddingRight = UDim.new(0, 10)
        return l
    end

    local fpsStat = CreateSection(Row2, "0 Fps")
    local pingStat = CreateSection(Row2, "0 Ms")
    CreateSection(Row1, "<font color='#B432B4'>N</font>ight Alpha")
    CreateSection(Row1, "User: <font color='#B432B4'>" .. (Players.LocalPlayer and Players.LocalPlayer.DisplayName or "Player") .. "</font>")

    RunService.RenderStepped:Connect(function(dt)
        LayoutContainer.Visible = self._Visible
        if self._Visible then
            fpsStat.Text = math.floor(1/dt) .. " <font color='#B432B4'>Fps</font>"
            pingStat.Text = GetPing() .. " <font color='#B432B4'>Ms</font>"
        end
    end)
    self:InitKeybindList()
    UserInputService.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == self.ToggleKey then
            self._Visible = not self._Visible
            for _, win in pairs(self.MainGui:GetChildren()) do if win:IsA("Frame") then win.Visible = self._Visible end end
        end
    end)
end

function Library:CreateWindow(name)
    local cfg = self._Config 
    if not self._Initialized then
        self:InitHUD()
        local ScreenWidth = self.MainGui.AbsoluteSize.X > 0 and self.MainGui.AbsoluteSize.X or 1920
        local totalWidth = (cfg.WindowWidth * cfg.TotalWindows) + (cfg.Spacing * (cfg.TotalWindows - 1))
        self._CurrentX = (ScreenWidth / 2) - (totalWidth / 2)
        self._Initialized = true
    end
    local xPos = self._CurrentX
    self._CurrentX = self._CurrentX + cfg.WindowWidth + cfg.Spacing
    local Main = Instance.new("Frame", self.MainGui)
    Main.Name = name; Main.Size = UDim2.new(0, cfg.WindowWidth, 0, 50); Main.Position = UDim2.new(0, xPos, 0, cfg.StartY)
    Main.BackgroundColor3 = Color3.fromRGB(15, 15, 18)
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 10)
    local s = Instance.new("UIStroke", Main); s.Color = Color3.fromRGB(65, 65, 70); s.Thickness = 2.5 
    local Header = Instance.new("TextLabel", Main)
    Header.Size = UDim2.new(1, 0, 0, 50); Header.Text = name; Header.TextColor3 = Color3.fromRGB(255, 255, 255); Header.Font = Enum.Font.GothamBold; Header.TextSize = 16; Header.BackgroundTransparency = 1
    local Scroll = Instance.new("ScrollingFrame", Main)
    Scroll.Position = UDim2.new(0, 0, 0, 50); Scroll.Size = UDim2.new(1, 0, 0, 0); Scroll.BackgroundTransparency = 1; Scroll.ScrollBarThickness = 2; Scroll.ScrollBarImageColor3 = self.Accent; Scroll.CanvasSize = UDim2.new(0, 0, 0, 0); Scroll.ScrollingDirection = Enum.ScrollingDirection.Y
    local Layout = Instance.new("UIListLayout", Scroll); Layout.Padding = UDim.new(0, 7); Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    Instance.new("UIPadding", Scroll).PaddingTop = UDim.new(0, 5)
    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local h = math.min(Layout.AbsoluteContentSize.Y + 15, (38 + 7) * cfg.MaxButtonsVisible)
        Scroll.Size = UDim2.new(1, 0, 0, h); Scroll.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 15)
        Main.Size = UDim2.new(0, cfg.WindowWidth, 0, h + 60)
    end)
    local Category = {}
    function Category:CreateModule(modName, callback)
        local Enabled, Binding, CurrentKey = false, false, nil
        local MFrame = Instance.new("Frame", Scroll)
        MFrame.Size = UDim2.new(0, cfg.WindowWidth - 18, 0, 38); MFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
        Instance.new("UICorner", MFrame).CornerRadius = UDim.new(0, 8)
        local ms = Instance.new("UIStroke", MFrame); ms.Color = Color3.fromRGB(50, 50, 55); ms.Thickness = 1.2
        local MBtn = Instance.new("TextButton", MFrame)
        MBtn.Size = UDim2.new(1, 0, 1, 0); MBtn.BackgroundTransparency = 1; MBtn.Text = "  " .. modName; MBtn.TextColor3 = Color3.fromRGB(170, 170, 170); MBtn.Font = Enum.Font.GothamBold; MBtn.TextSize = 13; MBtn.TextXAlignment = 0
        local Ind = Instance.new("Frame", MFrame)
        Ind.Size = UDim2.new(0, 4, 0, 0); Ind.Position = UDim2.new(1, -10, 0.5, 0); Ind.AnchorPoint = Vector2.new(0, 0.5); Ind.BackgroundColor3 = self.Accent; Ind.BorderSizePixel = 0

        local function Toggle()
            Enabled = not Enabled
            local bCol = Enabled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(170, 170, 170)
            local fCol = Enabled and Color3.fromRGB(35, 25, 45) or Color3.fromRGB(22, 22, 26)
            local iSize = Enabled and UDim2.new(0, 4, 0, 22) or UDim2.new(0, 4, 0, 0)
            Tween(MBtn, 0.2, {TextColor3 = bCol})
            Tween(MFrame, 0.2, {BackgroundColor3 = fCol})
            Tween(Ind, 0.2, {Size = iSize})
            callback(Enabled)
        end

        MBtn.MouseButton1Click:Connect(function() if not Binding then Toggle() end end)
        MBtn.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton3 then Binding = true; MBtn.Text = "  " .. modName .. " [?]" end end)
        UserInputService.InputBegan:Connect(function(input, gpe)
            if Binding and input.UserInputType == Enum.UserInputType.Keyboard then
                if input.KeyCode ~= Enum.KeyCode.Escape then
                    CurrentKey = input.KeyCode
                    Library._Keybinds[modName] = input.KeyCode.Name
                else
                    CurrentKey = nil
                    Library._Keybinds[modName] = nil
                end
                Binding = false; MBtn.Text = "  " .. modName
            elseif not gpe and CurrentKey and input.KeyCode == CurrentKey then
                Toggle()
            end
        end)
        return {}
    end
    return Category
end

return Library
