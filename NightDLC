        for _, mod in pairs(self._Modules) do 
            mod.Frame.BackgroundTransparency = self.ModuleTransparency; mod.Frame.BackgroundColor3 = mod.Enabled and self.Accent or Color3.fromRGB(25, 25, 30) 
            for _, comp in pairs(mod.Components) do 
                if comp.Type == "Slider" then comp.Fill.BackgroundColor3 = self.Accent 
                elseif comp.Type == "Toggle" and comp.State then comp.Box.BackgroundColor3 = self.Accent 
                elseif comp.Type == "Selector" and comp.ActiveBtn then comp.ActiveBtn.BackgroundColor3 = self.Accent end 
            end 
