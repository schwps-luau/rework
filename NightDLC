local Library = {
    Categories = {},
    Modules = {},
    Accent = Color3.fromRGB(180, 50, 180),
    LastX = 50 -- Начальная позиция для авто-отступа
}

local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

local function Tween(obj, time, goal)
    TweenService:Create(obj, TweenInfo.new(time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), goal):Play()
end

-- [ ПЕРЕДЕЛАННЫЙ ВАТЕРМАРК (HUD) ]
function Library:InitHUD()
    local HUD = Instance.new("ScreenGui", CoreGui)
    local Container = Instance.new("Frame", HUD)
    Container.Size = UDim2.new(0, 500, 0, 30)
    Container.Position = UDim2.new(0, 15, 0, 15)
    Container.BackgroundTransparency = 1

    local Layout = Instance.new("UIListLayout", Container)
    Layout.FillDirection = Enum.FillDirection.Horizontal
    Layout.Padding = UDim.new(0, 6)

    local function CreateWidget(text)
        local f = Instance.new("Frame", Container)
        f.BackgroundColor3 = Color3.fromRGB(15, 15, 20)
        f.BackgroundTransparency = 0.05 -- Почти непрозрачный, как просил
        f.AutomaticSize = Enum.AutomaticSize.XY
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 4)
        Instance.new("UIStroke", f).Color = Color3.fromRGB(40, 40, 45) -- Тонкая обводка
        
        local p = Instance.new("UIPadding", f)
        p.PaddingLeft = UDim.new(0, 8); p.PaddingRight = UDim.new(0, 8)

        local l = Instance.new("TextLabel", f)
        l.Size = UDim2.new(0, 0, 0, 24)
        l.AutomaticSize = Enum.AutomaticSize.X
        l.Text = text
        l.RichText = true -- Для подсветки иконок
        l.TextColor3 = Color3.fromRGB(255, 255, 255)
        l.Font = Enum.Font.GothamMedium
        l.TextSize = 13
        l.BackgroundTransparency = 1
        return l
    end

    local brand = CreateWidget("<font color='#B432B4'>N</font> Alpha")
    local stats = CreateWidget("244 <font color='#B432B4'>Fps</font> | 10:39:51")
    local info = CreateWidget("125, 4, 157 | <font color='#B432B4'>0 Ping</font>")

    RunService.RenderStepped:Connect(function(dt)
        local fpsVal = math.floor(1/dt)
        stats.Text = fpsVal .. " <font color='#B432B4'>Fps</font> | " .. os.date("%X")
    end)
end

-- [ ОКНО С НЕПРОЗРАЧНЫМ ФРЕЙМОМ И ОТСТУПОМ ]
function Library:CreateWindow(categoryName)
    if not self.MainGui then
        self.MainGui = Instance.new("ScreenGui", CoreGui)
        self:InitHUD()
    end

    local Category = {}
    
    local Main = Instance.new("Frame", self.MainGui)
    Main.Name = categoryName
    Main.Size = UDim2.new(0, 185, 0, 38)
    -- Автоматический отступ (LastX увеличивается с каждым окном)
    Main.Position = UDim2.new(0, self.LastX, 0, 80)
    self.LastX = self.LastX + 200 -- Расстояние между окнами

    Main.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    Main.BackgroundTransparency = 0.05 -- Плотный фрейм
    Main.BorderSizePixel = 0
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 8)

    -- Обводка окна (Stroke) для стиля Найта
    local Stroke = Instance.new("UIStroke", Main)
    Stroke.Color = Color3.fromRGB(45, 45, 50)
    Stroke.Thickness = 1.2

    local Header = Instance.new("TextLabel", Main)
    Header.Size = UDim2.new(1, 0, 1, 0)
    Header.Text = categoryName
    Header.TextColor3 = Color3.fromRGB(255, 255, 255)
    Header.Font = Enum.Font.GothamBold
    Header.TextSize = 15
    Header.BackgroundTransparency = 1

    local Container = Instance.new("Frame", Main)
    Container.Position = UDim2.new(0, 0, 1, 5) -- Небольшой зазор под шапкой
    Container.Size = UDim2.new(1, 0, 0, 0)
    Container.BackgroundTransparency = 1
    
    local Layout = Instance.new("UIListLayout", Container)
    Layout.Padding = UDim.new(0, 2)

    -- Dragging
    local dragStart, startPosFrame, dragging
    Main.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = i.Position; startPosFrame = Main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = i.Position - dragStart
            Main.Position = UDim2.new(startPosFrame.X.Scale, startPosFrame.X.Offset + delta.X, startPosFrame.Y.Scale, startPosFrame.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

    function Category:CreateModule(name, callback)
        local mod = {Enabled = false, Expanded = false}
        
        local MFrame = Instance.new("Frame", Container)
        MFrame.Size = UDim2.new(1, 0, 0, 32)
        MFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
        MFrame.BackgroundTransparency = 0.1 -- Плотная подложка модуля
        Instance.new("UICorner", MFrame).CornerRadius = UDim.new(0, 5)

        local MBtn = Instance.new("TextButton", MFrame)
        MBtn.Size = UDim2.new(1, 0, 1, 0)
        MBtn.BackgroundTransparency = 1
        MBtn.Text = "  " .. name
        MBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
        MBtn.Font = Enum.Font.Gotham
        MBtn.TextSize = 13
        MBtn.TextXAlignment = 0
        MBtn.AutoButtonColor = false

        -- Элемент акцента (полоска сбоку как в Найте)
        local AccentBar = Instance.new("Frame", MFrame)
        AccentBar.Size = UDim2.new(0, 2, 0.7, 0)
        AccentBar.Position = UDim2.new(1, -5, 0.15, 0)
        AccentBar.BackgroundColor3 = self.Accent
        AccentBar.BackgroundTransparency = 1
        Instance.new("UICorner", AccentBar)

        MBtn.MouseButton1Click:Connect(function()
            mod.Enabled = not mod.Enabled
            local targetColor = mod.Enabled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(180, 180, 180)
            local targetBG = mod.Enabled and Color3.fromRGB(45, 35, 55) or Color3.fromRGB(25, 25, 30)
            
            Tween(MBtn, 0.2, {TextColor3 = targetColor})
            Tween(MFrame, 0.2, {BackgroundColor3 = targetBG})
            Tween(AccentBar, 0.2, {BackgroundTransparency = mod.Enabled and 0 or 1})
            
            callback(mod.Enabled)
        end)

        Container.Size = UDim2.new(1, 0, 0, Layout.AbsoluteContentSize.Y + 10)
        return mod
    end

    return Category
end

return Library