local function SafeTween(obj, goal, t)
    if not obj then return end
    local info = TweenInfo.new(t or 0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    local tween = TweenService:Create(obj, info, goal)
    tween:Play()
    return tween
end

local function MakeDraggable(frame, handle)
    local dragging, dragInput, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = frame.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

function Library:Notify(text)
    if not self.MainGui then return end
    local container = self.MainGui:FindFirstChild("NotifContainer") or Instance.new("Frame", self.MainGui)
    if container.Name ~= "NotifContainer" then
        container.Name = "NotifContainer"; container.Size = UDim2.new(0, 300, 1, 0); container.Position = UDim2.new(0.5, -150, 0, 0); container.BackgroundTransparency = 1
        local l = Instance.new("UIListLayout", container); l.VerticalAlignment = "Bottom"; l.HorizontalAlignment = "Center"; l.Padding = UDim.new(0, 8)
        Instance.new("UIPadding", container).PaddingBottom = UDim.new(0, 100)
    end

    local n = Instance.new("Frame", container); n.BackgroundColor3 = Color3.fromRGB(15, 15, 20); n.Size = UDim2.new(0, 0, 0, 28); n.ClipsDescendants = true
    Instance.new("UICorner", n).CornerRadius = UDim.new(0, 6)
    local icon = Instance.new("ImageLabel", n); icon.Size = UDim2.new(0, 16, 0, 16); icon.Position = UDim2.new(0, 8, 0.5, -8); icon.BackgroundTransparency = 1; icon.Image = "rbxassetid://11419713314"
    local t = Instance.new("TextLabel", n); t.Size = UDim2.new(1, -40, 1, 0); t.Position = UDim2.new(0, 32, 0, 0); t.Text = text; t.Font = self._Config.FontMedium; t.TextSize = 12; t.TextColor3 = Color3.new(1, 1, 1); t.BackgroundTransparency = 1; t.TextXAlignment = 0
    
    local s = TextService:GetTextSize(text, 12, t.Font, Vector2.new(1000, 1000))
    SafeTween(n, {Size = UDim2.new(0, s.X + 45, 0, 28)}, 0.3)

    local notifData = {Frame = n, Icon = icon}
    table.insert(self._ActiveNotifs, notifData)

    task.delay(3, function() 
        SafeTween(n, {Size = UDim2.new(0, 0, 0, 28), BackgroundTransparency = 1}, 0.3) 
        task.wait(0.3) 
        for i, v in ipairs(self._ActiveNotifs) do if v == notifData then table.remove(self._ActiveNotifs, i) break end end
        n:Destroy() 
    end)
end

function Library:ToggleMenu()
    self._Visible = not self._Visible
    local screenHeight = 2000 
    for i, win in pairs(self._Windows) do
        local targetY = self._Visible and self._Config.StartY or ((i % 2 == 0) and screenHeight or -screenHeight)
        SafeTween(win.Frame, {Position = UDim2.new(0, win.Frame.Position.X.Offset, 0, targetY)})
    end
    if self.SearchFrame then
        local targetSearchY = self._Visible and -30 or 150
        SafeTween(self.SearchFrame, {Position = UDim2.new(0.5, 0, 1, targetSearchY)})
    end
    if self.Tooltip then self.Tooltip.Frame.Visible = false end
    local b = Lighting:FindFirstChild("NightBlur")
    if b then b.Enabled = (self.Blur and self._Visible) end
end

