    UserInputService.InputBegan:Connect(function(i, g) 
        if i.KeyCode == self.ToggleKey then self:ToggleMenu() end 
        if g then return end 
        for name, data in pairs(self._Keybinds) do if data.Key and i.KeyCode == data.Key then data.Enabled = not data.Enabled; data.Callback(data.Enabled); self._RebuildKB() end end 
