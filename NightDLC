local Library = {
    Accent = Color3.fromRGB(180, 50, 180),
    _Config = {
        WindowWidth = 210,
        Spacing = 15,
        StartY = 160,
        MaxButtonsVisible = 12,
        TotalWindows = 5 
    },
    _CurrentX = 0,
    _Initialized = false
}

local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Stats = game:GetService("Stats")
local Players = game:GetService("Players")

local function Tween(obj, time, goal)
    TweenService:Create(obj, TweenInfo.new(time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), goal):Play()
end

local function GetPing()
    local network = Stats.Network
    if network and network:FindFirstChild("ServerStatsItem") and network.ServerStatsItem:FindFirstChild("Data Ping") then
        return math.floor(network.ServerStatsItem["Data Ping"]:GetValue())
    end
    return 0
end

-- [ HUD ]
function Library:InitHUD()
    local HUD = Instance.new("ScreenGui", CoreGui)
    HUD.Name = "NightHUD_Final"
    
    local LayoutContainer = Instance.new("Frame", HUD)
    LayoutContainer.Size = UDim2.new(0, 600, 0, 100)
    LayoutContainer.Position = UDim2.new(0, 20, 0, 20)
    LayoutContainer.BackgroundTransparency = 1
    
    local function CreateRow()
        local r = Instance.new("Frame", LayoutContainer)
        r.Size = UDim2.new(1, 0, 0, 28)
        r.BackgroundTransparency = 1
        local l = Instance.new("UIListLayout", r)
        l.FillDirection = Enum.FillDirection.Horizontal
        l.Padding = UDim.new(0, 8)
        return r
    end

    local Row1, Row2 = CreateRow(), CreateRow()
    Instance.new("UIListLayout", LayoutContainer).Padding = UDim.new(0, 8)

    local function CreateSection(parent, defaultText)
        local f = Instance.new("Frame", parent)
        f.BackgroundColor3 = Color3.fromRGB(12, 12, 15)
        f.AutomaticSize = Enum.AutomaticSize.XY
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 5)
        local s = Instance.new("UIStroke", f)
        s.Color = Color3.fromRGB(45, 45, 50); s.Thickness = 1.2
        
        local p = Instance.new("UIPadding", f)
        p.PaddingLeft = UDim.new(0, 10); p.PaddingRight = UDim.new(0, 10)
        local l = Instance.new("TextLabel", f)
        l.Size = UDim2.new(0, 0, 0, 26)
        l.AutomaticSize = Enum.AutomaticSize.X
        l.RichText = true; l.Text = defaultText
        l.TextColor3 = Color3.fromRGB(255, 255, 255)
        l.Font = Enum.Font.GothamBold; l.TextSize = 13; l.BackgroundTransparency = 1
        return l
    end

    local brand = CreateSection(Row1, "<font color='#B432B4'>N</font>ight Alpha")
    local user = CreateSection(Row1, "User: <font color='#B432B4'>" .. (Players.LocalPlayer and Players.LocalPlayer.DisplayName or "Player") .. "</font>")
    
    local fpsStat, pingStat, timeStat, coordsStat = CreateSection(Row2, "0 Fps"), CreateSection(Row2, "0 Ms"), CreateSection(Row2, "00:00:00"), CreateSection(Row2, "0, 0, 0")

    local lastFpsUpdate = 0
    RunService.RenderStepped:Connect(function(dt)
        lastFpsUpdate = lastFpsUpdate + dt
        if lastFpsUpdate >= 0.5 then
            fpsStat.Text = math.floor(1/dt) .. " <font color='#B432B4'>Fps</font>"
            lastFpsUpdate = 0
        end
        pingStat.Text = GetPing() .. " <font color='#B432B4'>Ms</font>"
        timeStat.Text = os.date("%X")
        local lp = Players.LocalPlayer
        if lp and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
            local pos = lp.Character.HumanoidRootPart.Position
            coordsStat.Text = string.format("%d, %d, %d", math.floor(pos.X), math.floor(pos.Y), math.floor(pos.Z))
        end
    end)
end

-- [ СОЗДАНИЕ ОКНА ]
function Library:CreateWindow(name)
    local cfg = Library._Config 

    if not self._Initialized then
        self.MainGui = Instance.new("ScreenGui", CoreGui)
        self:InitHUD()
        
        local ScreenWidth = self.MainGui.AbsoluteSize.X > 0 and self.MainGui.AbsoluteSize.X or 1920
        local totalWidth = (cfg.WindowWidth * cfg.TotalWindows) + (cfg.Spacing * (cfg.TotalWindows - 1))
        Library._CurrentX = (ScreenWidth / 2) - (totalWidth / 2)
        self._Initialized = true
    end

    local xPos = Library._CurrentX
    Library._CurrentX = Library._CurrentX + cfg.WindowWidth + cfg.Spacing

    local Main = Instance.new("Frame", self.MainGui)
    Main.Name = name
    Main.Size = UDim2.new(0, cfg.WindowWidth, 0, 50)
    Main.Position = UDim2.new(0, xPos, 0, cfg.StartY)
    Main.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 8)
    Instance.new("UIStroke", Main).Color = Color3.fromRGB(50, 50, 55)

    local Header = Instance.new("TextLabel", Main)
    Header.Size = UDim2.new(1, 0, 0, 45)
    Header.Text = name; Header.TextColor3 = Color3.fromRGB(255, 255, 255)
    Header.Font = Enum.Font.GothamBold; Header.TextSize = 14; Header.BackgroundTransparency = 1

    local Scroll = Instance.new("ScrollingFrame", Main)
    Scroll.Position = UDim2.new(0, 0, 0, 45)
    Scroll.Size = UDim2.new(1, 0, 0, 0)
    Scroll.BackgroundTransparency = 1
    Scroll.ScrollBarThickness = 1
    Scroll.ScrollBarImageColor3 = Library.Accent
    Scroll.ScrollingDirection = Enum.ScrollingDirection.Y
    Scroll.CanvasSize = UDim2.new(0, 0, 0, 0)
    
    local Layout = Instance.new("UIListLayout", Scroll)
    Layout.Padding = UDim.new(0, 5)
    Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local Padding = Instance.new("UIPadding", Scroll)
    Padding.PaddingTop = UDim.new(0, 2); Padding.PaddingBottom = UDim.new(0, 8)

    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local btnHeight = 34 + 5
        local currentHeight = Layout.AbsoluteContentSize.Y + 10
        local maxHeight = (btnHeight * cfg.MaxButtonsVisible)
        local finalHeight = math.min(currentHeight, maxHeight)
        Scroll.Size = UDim2.new(1, 0, 0, finalHeight)
        Scroll.CanvasSize = UDim2.new(0, 0, 0, currentHeight)
        Main.Size = UDim2.new(0, cfg.WindowWidth, 0, finalHeight + 55)
    end)

    -- Dragging
    local dragStart, startPos, dragging
    Main.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = i.Position; startPos = Main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = i.Position - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

    local Category = {}
    function Category:CreateModule(modName, callback)
        local Enabled = false
        local Binding = false
        local CurrentKey = nil
        
        local MFrame = Instance.new("Frame", Scroll)
        MFrame.Size = UDim2.new(0, cfg.WindowWidth - 16, 0, 34)
        MFrame.BackgroundColor3 = Color3.fromRGB(24, 24, 28)
        Instance.new("UICorner", MFrame).CornerRadius = UDim.new(0, 6)
        Instance.new("UIStroke", MFrame).Color = Color3.fromRGB(40, 40, 45)

        local MBtn = Instance.new("TextButton", MFrame)
        MBtn.Size = UDim2.new(1, 0, 1, 0)
        MBtn.BackgroundTransparency = 1
        MBtn.Text = "  " .. modName
        MBtn.TextColor3 = Color3.fromRGB(170, 170, 170)
        MBtn.Font = Enum.Font.GothamMedium; MBtn.TextSize = 13; MBtn.TextXAlignment = 0

        local Ind = Instance.new("Frame", MFrame)
        Ind.Size = UDim2.new(0, 3, 0, 0)
        Ind.Position = UDim2.new(1, -8, 0.5, 0)
        Ind.AnchorPoint = Vector2.new(0, 0.5)
        Ind.BackgroundColor3 = Library.Accent; Ind.BorderSizePixel = 0

        local function UpdateText()
            if Binding then
                MBtn.Text = "  " .. modName .. " [?]"
            elseif CurrentKey then
                MBtn.Text = "  " .. modName .. " [" .. CurrentKey.Name .. "]"
            else
                MBtn.Text = "  " .. modName
            end
        end

        local function Toggle()
            Enabled = not Enabled
            Tween(MBtn, 0.2, {TextColor3 = Enabled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(170, 170, 170)})
            Tween(MFrame, 0.2, {BackgroundColor3 = Enabled and Color3.fromRGB(30, 25, 40) or Color3.fromRGB(24, 24, 28)})
            Tween(Ind, 0.2, {Size = UDim2.new(0, 3, 0, Enabled and 20 or 0)})
            callback(Enabled)
        end

        MBtn.MouseButton1Click:Connect(Toggle)
        
        -- Кейбинд на колесико
        MBtn.MouseButton2Click:Connect(Toggle) -- Пкм тоже тоглит
        
        UserInputService.InputBegan:Connect(function(input, gpe)
            if gpe then return end
            
            -- Проверка нажатия колесика на кнопке
            if input.UserInputType == Enum.UserInputType.MouseButton3 then
                local mousePos = UserInputService:GetMouseLocation()
                local btnPos = MBtn.AbsolutePosition
                local btnSize = MBtn.AbsoluteSize
                
                if mousePos.X >= btnPos.X and mousePos.X <= btnPos.X + btnSize.X and
                   mousePos.Y >= btnPos.Y + 36 and mousePos.Y <= btnPos.Y + btnSize.Y + 36 then
                    Binding = true
                    UpdateText()
                end
            -- Обработка установки клавиши
            elseif Binding and input.UserInputType == Enum.UserInputType.Keyboard then
                if input.KeyCode == Enum.KeyCode.Escape then
                    CurrentKey = nil
                else
                    CurrentKey = input.KeyCode
                end
                Binding = false
                UpdateText()
            -- Работа самого кейбинда
            elseif CurrentKey and input.KeyCode == CurrentKey then
                Toggle()
            end
        end)

        return {}
    end
    return Category
end

return Library
