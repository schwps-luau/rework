local Library = {
    Accent = Color3.fromRGB(120, 100, 200),
    ToggleKey = Enum.KeyCode.RightShift,
    _Config = {
        WindowWidth = 240,
        StartY = 220,
        Spacing = 10,
        ModuleHeight = 38,
        Transparency = 0.6,
        Font = Enum.Font.GothamMedium,
        FontBold = Enum.Font.GothamBold
    },
    _Visible = true,
    _CurrentX = 15,
    _Initialized = false,
    _Objects = { Accents = {}, Transparency = {}, Modules = {} },
    MainGui = nil,
    _Blur = nil
}

local UIS = game:GetService("UserInputService")
local TS = game:GetService("TweenService")
local RS = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Stats = game:GetService("Stats")
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")

local function SafeTween(obj, goal)
    if not obj then return end
    TS:Create(obj, TweenInfo.new(0.2, Enum.EasingStyle.Quart), goal):Play()
end

function Library:InitHUD()
    local HUD = Instance.new("ScreenGui", CoreGui)
    HUD.Name = "NightV2_HUD"
    self.MainGui = HUD

    self._Blur = Instance.new("BlurEffect", Lighting)
    self._Blur.Size = 20; self._Blur.Enabled = self._Visible

    -- ВАТЕРМАРК (ЛЕВО ВЕРХ)
    local WM = Instance.new("Frame", HUD)
    WM.Size = UDim2.new(0, 300, 0, 70); WM.Position = UDim2.new(0, 15, 0, 15); WM.BackgroundTransparency = 1
    Instance.new("UIListLayout", WM).Padding = UDim.new(0, 5)

    local function CreatePill(label, text, parent)
        local f = Instance.new("Frame", parent)
        f.BackgroundColor3 = Color3.fromRGB(15, 15, 15); f.BackgroundTransparency = 0.3
        f.AutomaticSize = "XY"; Instance.new("UICorner", f).CornerRadius = UDim.new(0, 4)
        local p = Instance.new("UIPadding", f); p.PaddingLeft = UDim.new(0, 10); p.PaddingRight = UDim.new(0, 10)
        local l = Instance.new("TextLabel", f)
        l.Size = UDim2.new(0, 0, 0, 24); l.AutomaticSize = "X"; l.RichText = true
        l.Text = label == "TITLE" and "<font color='#7864C8'>Night</font> DLC" or string.format("<font color='#7864C8'>%s</font> <font color='#555555'>|</font> %s", label, text)
        l.TextColor3 = Color3.fromRGB(230, 230, 230); l.Font = self._Config.Font; l.TextSize = 13; l.BackgroundTransparency = 1
        return l
    end

    local R1 = Instance.new("Frame", WM); R1.AutomaticSize = "XY"; R1.BackgroundTransparency = 1
    Instance.new("UIListLayout", R1).FillDirection = "Horizontal"; R1.UIListLayout.Padding = UDim.new(0, 6)
    CreatePill("TITLE", "", R1)
    local fpsPill = CreatePill("FPS", "0", R1)
    local timePill = CreatePill("Time", "00:00:00", R1)

    local R2 = Instance.new("Frame", WM); R2.AutomaticSize = "XY"; R2.BackgroundTransparency = 1
    Instance.new("UIListLayout", R2).FillDirection = "Horizontal"; R2.UIListLayout.Padding = UDim.new(0, 6)
    local posPill = CreatePill("Pos", "0, 0, 0", R2)
    local pingPill = CreatePill("Ms", "0", R2)

    -- КЕЙБИНД ЛИСТ (ПРАВО ВЕРХ)
    local KBList = Instance.new("Frame", HUD)
    KBList.Size = UDim2.new(0, 160, 0, 0); KBList.AutomaticSize = "Y"
    KBList.Position = UDim2.new(1, -175, 0, 15)
    KBList.BackgroundColor3 = Color3.fromRGB(15, 15, 15); KBList.BackgroundTransparency = self._Config.Transparency
    Instance.new("UICorner", KBList)
    self._Objects.Transparency[KBList] = true

    local KBT = Instance.new("TextLabel", KBList)
    KBT.Size = UDim2.new(1, 0, 0, 30); KBT.Text = "HotKeys"; KBT.Font = self._Config.FontBold; KBT.TextColor3 = Color3.fromRGB(255, 255, 255); KBT.TextSize = 13; KBT.BackgroundTransparency = 1
    
    -- ПОИСК (SEARCH BAR)
    local SearchFrame = Instance.new("Frame", HUD)
    SearchFrame.Name = "SearchBar"
    SearchFrame.Size = UDim2.new(0, 180, 0, 32)
    SearchFrame.Position = UDim2.new(0.5, -90, 0.9, 0)
    SearchFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15); SearchFrame.BackgroundTransparency = self._Config.Transparency
    Instance.new("UICorner", SearchFrame)
    self._Objects.Transparency[SearchFrame] = true

    local SearchInput = Instance.new("TextBox", SearchFrame)
    SearchInput.Size = UDim2.new(1, -10, 1, 0); SearchInput.Position = UDim2.new(0, 5, 0, 0)
    SearchInput.BackgroundTransparency = 1; SearchInput.Text = ""; SearchInput.PlaceholderText = "Поиск: Ctrl + F"; SearchInput.TextColor3 = Color3.fromRGB(200, 200, 200); SearchInput.Font = self._Config.Font; SearchInput.TextSize = 12

    SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
        local query = SearchInput.Text:lower()
        for modName, frame in pairs(self._Objects.Modules) do
            frame.Visible = modName:lower():find(query) ~= nil
        end
    end)

    RS.RenderStepped:Connect(function(dt)
        timePill.Text = string.format("<font color='#7864C8'>Time</font> <font color='#555555'>|</font> %s", os.date("%H:%M:%S"))
        local lp = Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if lp then
            local p = lp.Position; posPill.Text = string.format("<font color='#7864C8'>Pos</font> <font color='#555555'>|</font> %d, %d, %d", p.X, p.Y, p.Z)
        end
        local ping = 0; pcall(function() ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) end)
        pingPill.Text = string.format("<font color='#7864C8'>Ms</font> <font color='#555555'>|</font> %d", ping)
        fpsPill.Text = string.format("<font color='#7864C8'>FPS</font> <font color='#555555'>|</font> %d", math.floor(1/dt))
    end)

    UIS.InputBegan:Connect(function(input, gpe)
        if not gpe and input.KeyCode == self.ToggleKey then
            self._Visible = not self._Visible; self._Blur.Enabled = self._Visible
            for _, v in pairs(HUD:GetChildren()) do if v.Name == "NightWindow" or v.Name == "SearchBar" then v.Visible = self._Visible end end
        end
    end)
end

function Library:CreateWindow(name)
    if not self._Initialized then self:InitHUD(); self._Initialized = true end
    local Main = Instance.new("Frame", self.MainGui); Main.Name = "NightWindow"
    Main.Size = UDim2.new(0, self._Config.WindowWidth, 0, 40); Main.Position = UDim2.new(0, self._CurrentX, 0, self._Config.StartY)
    Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15); Main.BackgroundTransparency = self._Config.Transparency; Main.ClipsDescendants = true
    Instance.new("UICorner", Main); self._Objects.Transparency[Main] = true
    self._CurrentX = self._CurrentX + self._Config.WindowWidth + self._Config.Spacing

    local Header = Instance.new("TextLabel", Main); Header.Size = UDim2.new(1, 0, 0, 45); Header.Text = name; Header.Font = self._Config.FontBold; Header.TextColor3 = Color3.fromRGB(255, 255, 255); Header.TextSize = 15; Header.BackgroundTransparency = 1
    local Scroll = Instance.new("ScrollingFrame", Main); Scroll.Position = UDim2.new(0, 0, 0, 45); Scroll.Size = UDim2.new(1, 0, 0, 0); Scroll.BackgroundTransparency = 1; Scroll.ScrollBarThickness = 0; Scroll.ClipsDescendants = true
    local Layout = Instance.new("UIListLayout", Scroll); Layout.Padding = UDim.new(0, 5); Layout.HorizontalAlignment = "Center"

    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local h = math.min(Layout.AbsoluteContentSize.Y + 10, 500)
        Scroll.Size = UDim2.new(1, 0, 0, h); Main.Size = UDim2.new(0, self._Config.WindowWidth, 0, h + 55)
    end)

    local Win = {}
    function Win:CreateModule(modName, callback)
        local Enabled, Opened = false, false
        local MFrame = Instance.new("Frame", Scroll)
        MFrame.Size = UDim2.new(1, -12, 0, Library._Config.ModuleHeight)
        MFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25); MFrame.BackgroundTransparency = Library._Config.Transparency
        MFrame.ClipsDescendants = true; Instance.new("UICorner", MFrame); Library._Objects.Transparency[MFrame] = true
        Library._Objects.Modules[modName] = MFrame

        local MBtn = Instance.new("TextButton", MFrame)
        MBtn.Size = UDim2.new(1, 0, 0, Library._Config.ModuleHeight)
        MBtn.BackgroundTransparency = 1; MBtn.Text = "  " .. modName; MBtn.Font = Library._Config.Font; MBtn.TextSize = 14; MBtn.TextColor3 = Color3.fromRGB(200, 200, 200); MBtn.TextXAlignment = "Left"
        
        local Ind = Instance.new("TextLabel", MFrame)
        Ind.Size = UDim2.new(0, 30, 0, Library._Config.ModuleHeight); Ind.Position = UDim2.new(1, -30, 0, 0); Ind.Text = "..."; Ind.Font = Enum.Font.GothamBold; Ind.TextSize = 14; Ind.TextColor3 = Color3.fromRGB(80, 80, 80); Ind.BackgroundTransparency = 1

        local Nodes = Instance.new("Frame", MFrame)
        Nodes.Position = UDim2.new(0, 0, 0, Library._Config.ModuleHeight); Nodes.Size = UDim2.new(1, 0, 0, 0); Nodes.BackgroundTransparency = 1
        local NL = Instance.new("UIListLayout", Nodes); NL.Padding = UDim.new(0, 8); NL.HorizontalAlignment = "Center"
        Instance.new("UIPadding", Nodes).PaddingTop = UDim.new(0, 5); Nodes.UIPadding.PaddingBottom = UDim.new(0, 12)

        local function Update()
            local cnt = 0; for _, v in pairs(Nodes:GetChildren()) do if v:IsA("Frame") or v:IsA("TextButton") then cnt = cnt + 1 end end
            local targetH = (Opened and cnt > 0) and (Library._Config.ModuleHeight + NL.AbsoluteContentSize.Y + 15) or Library._Config.ModuleHeight
            SafeTween(MFrame, {Size = UDim2.new(1, -12, 0, targetH)})
        end

        NL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(Update)
        
        MBtn.MouseButton1Click:Connect(function()
            Enabled = not Enabled
            SafeTween(MFrame, {BackgroundColor3 = Enabled and Library.Accent or Color3.fromRGB(25, 25, 25)})
            MBtn.TextColor3 = Enabled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 200, 200)
            callback(Enabled)
        end)
        MBtn.MouseButton2Click:Connect(function() Opened = not Opened; Update() end)

        local Mod = {}
        function Mod:CreateButton(n, cb)
            local b = Instance.new("TextButton", Nodes); b.Size = UDim2.new(0.92, 0, 0, 35); b.BackgroundColor3 = Color3.fromRGB(40, 40, 40); b.BackgroundTransparency = Library._Config.Transparency
            b.Text = n; b.Font = Library._Config.Font; b.TextColor3 = Color3.fromRGB(220, 220, 220); b.TextSize = 12; Instance.new("UICorner", b)
            Library._Objects.Transparency[b] = true
            b.MouseButton1Click:Connect(function() b.BackgroundColor3 = Library.Accent; task.wait(0.1); SafeTween(b, {BackgroundColor3 = Color3.fromRGB(40, 40, 40)}); cb() end)
            Update(); return Mod
        end
        
        function Mod:CreateToggle(n, def, cb)
            local ts = def
            local f = Instance.new("TextButton", Nodes); f.Size = UDim2.new(0.92, 0, 0, 30); f.BackgroundColor3 = Color3.fromRGB(35, 35, 35); f.BackgroundTransparency = Library._Config.Transparency; f.Text = "  " .. n; f.Font = Library._Config.Font; f.TextColor3 = Color3.fromRGB(200, 200, 200); f.TextSize = 12; f.TextXAlignment = "Left"; Instance.new("UICorner", f)
            local box = Instance.new("Frame", f); box.Size = UDim2.new(0, 16, 0, 16); box.Position = UDim2.new(1, -22, 0.5, -8); box.BackgroundColor3 = ts and Library.Accent or Color3.fromRGB(50, 50, 50); Instance.new("UICorner", box)
            Library._Objects.Transparency[f] = true; Library._Objects.Accents[box] = "Background"
            f.MouseButton1Click:Connect(function() ts = not ts; SafeTween(box, {BackgroundColor3 = ts and Library.Accent or Color3.fromRGB(50, 50, 50)}); cb(ts) end)
            Update(); return Mod
        end

        function Mod:CreateSlider(n, min, max, def, cb)
            local f = Instance.new("Frame", Nodes); f.Size = UDim2.new(0.92, 0, 0, 40); f.BackgroundTransparency = 1
            local t = Instance.new("TextLabel", f); t.Size = UDim2.new(0.5, 0, 0, 20); t.Text = n; t.Font = Library._Config.Font; t.TextSize = 12; t.TextColor3 = Color3.fromRGB(200, 200, 200); t.BackgroundTransparency = 1; t.TextXAlignment = "Left"
            local vb = Instance.new("TextLabel", f); vb.Size = UDim2.new(0, 40, 0, 20); vb.Position = UDim2.new(1, -40, 0, 0); vb.BackgroundColor3 = Color3.fromRGB(40, 40, 40); vb.BackgroundTransparency = Library._Config.Transparency; vb.Text = tostring(def); vb.TextColor3 = Library.Accent; vb.Font = Library._Config.Font; vb.TextSize = 11; Instance.new("UICorner", vb)
            Library._Objects.Accents[vb] = "Text"; Library._Objects.Transparency[vb] = true
            local bar = Instance.new("Frame", f); bar.Size = UDim2.new(1, 0, 0, 5); bar.Position = UDim2.new(0, 0, 0, 30); bar.BackgroundColor3 = Color3.fromRGB(50, 50, 50); Instance.new("UICorner", bar)
            local fill = Instance.new("Frame", bar); fill.Size = UDim2.new((def-min)/(max-min), 0, 1, 0); fill.BackgroundColor3 = Library.Accent; Instance.new("UICorner", fill)
            Library._Objects.Accents[fill] = "Background"
            bar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then local move = UIS.InputChanged:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseMovement then local per = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1); local v = math.floor(min + (max - min) * per); fill.Size = UDim2.new(per, 0, 1, 0); vb.Text = tostring(v); cb(v) end end) UIS.InputEnded:Connect(function(i2) if i2.UserInputType == Enum.UserInputType.MouseButton1 then move:Disconnect() end end) end end)
            Update(); return Mod
        end
        return Mod
    end
    return Win
end

return Library
