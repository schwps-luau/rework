function Library:CreateWindow(name) 
    self:InitHUD() 
    local Main = Instance.new("Frame", self.MainGui); Main.Size = UDim2.new(0, self._Config.WindowWidth, 0, 40); Main.Position = UDim2.new(0, self._CurrentX, 0, self._Config.StartY); Main.BackgroundColor3 = Color3.fromRGB(10, 10, 12); Instance.new("UICorner", Main).CornerRadius = self._Config.Rounding 
    local Header = Instance.new("TextLabel", Main); Header.Size = UDim2.new(1, 0, 0, 40); Header.Text = name; Header.Font = self._Config.FontBold; Header.TextColor3 = self.Accent; Header.BackgroundTransparency = 1; Header.TextSize = 14 
    local Scroll = Instance.new("ScrollingFrame", Main); Scroll.Position = UDim2.new(0, 0, 0, 40); Scroll.Size = UDim2.new(1, 0, 0, 0); Scroll.BackgroundTransparency = 1; Scroll.ScrollBarThickness = 0 
    local Layout = Instance.new("UIListLayout", Scroll); Layout.Padding = UDim.new(0, 4); Layout.HorizontalAlignment = "Center" 
    table.insert(self._Windows, {Frame = Main, Title = Header}); self._CurrentX = self._CurrentX + self._Config.WindowWidth + self._Config.Spacing 
    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() local h = math.min(Layout.AbsoluteContentSize.Y + 10, 500); Scroll.Size = UDim2.new(1, 0, 0, h); Main.Size = UDim2.new(0, self._Config.WindowWidth, 0, h + 45) end) 
    
    local Window = {} 
    function Window:CreateModule(modName, comment, callback) 
        local modData = {Name = modName, Comment = comment or "No description", Enabled = false, Opened = false, Components = {}, Frame = nil} 
        local MFrame = Instance.new("Frame", Scroll); MFrame.Size = UDim2.new(1, -12, 0, Library._Config.ModuleHeight); MFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 30); MFrame.ClipsDescendants = true; Instance.new("UICorner", MFrame); modData.Frame = MFrame 
        local MBtn = Instance.new("TextButton", MFrame); MBtn.Size = UDim2.new(1, 0, 0, Library._Config.ModuleHeight); MBtn.BackgroundTransparency = 1; MBtn.Text = "  " .. modName; MBtn.Font = Library._Config.FontMedium; MBtn.TextSize = 13; MBtn.TextColor3 = Color3.fromRGB(200, 200, 200); MBtn.TextXAlignment = 0 
        local Dots = Instance.new("TextLabel", MFrame); Dots.Size = UDim2.new(0, 20, 0, Library._Config.ModuleHeight); Dots.Position = UDim2.new(1, -25, 0, 0); Dots.BackgroundTransparency = 1; Dots.Text = "..."; Dots.TextColor3 = Color3.new(1, 1, 1); Dots.Font = Library._Config.FontBold; Dots.Visible = false 
        local Nodes = Instance.new("Frame", MFrame); Nodes.Position = UDim2.new(0, 0, 0, Library._Config.ModuleHeight); Nodes.Size = UDim2.new(1, 0, 0, 0); Nodes.BackgroundTransparency = 1; Instance.new("UIListLayout", Nodes).Padding = UDim.new(0, 6); Nodes.UIListLayout.HorizontalAlignment = "Center" 
        
        -- Логика Тултипа
        MBtn.MouseEnter:Connect(function() Library._HoveredModule = modData end)
        MBtn.MouseLeave:Connect(function() Library._HoveredModule = nil end)

        Library._Keybinds[modName] = {Enabled = false, Key = nil, Callback = function(v) modData.Enabled = v; callback(v) end} 
        MBtn.MouseButton1Click:Connect(function() modData.Enabled = not modData.Enabled; Library._Keybinds[modName].Enabled = modData.Enabled; callback(modData.Enabled); Library._RebuildKB() end) 
        MBtn.MouseButton2Click:Connect(function() if not Dots.Visible then return end modData.Opened = not modData.Opened; local targetH = modData.Opened and (Library._Config.ModuleHeight + Nodes.UIListLayout.AbsoluteContentSize.Y + 10) or Library._Config.ModuleHeight; SafeTween(MFrame, {Size = UDim2.new(1, -12, 0, targetH)}, 0.4) end) 
        MBtn.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton3 then MBtn.Text = "  " .. modName .. " [?]"; local conn; conn = UserInputService.InputBegan:Connect(function(i, g) if not g then Library._Keybinds[modName].Key = i.KeyCode; MBtn.Text = "  " .. modName; Library._RebuildKB(); conn:Disconnect() end end) end end) 
        table.insert(Library._Modules, modData); Nodes.ChildAdded:Connect(function() Dots.Visible = true end) 
        
        local Mod = {} 
        function Mod:CreateSlider(n, min, max, def, dec, cb) 
            local comp = {Type = "Slider"}; local f = Instance.new("Frame", Nodes); f.Size = UDim2.new(0.92, 0, 0, 42); f.BackgroundTransparency = 1; local vText = Instance.new("TextLabel", f); vText.Size = UDim2.new(1, 0, 0, 20); vText.Text = n .. ": " .. string.format("%."..dec.."f", def); vText.Font = Library._Config.FontMedium; vText.TextSize = 11; vText.TextColor3 = Color3.new(1,1,1); vText.BackgroundTransparency = 1; vText.TextXAlignment = 0; local sliderBtn = Instance.new("TextButton", f); sliderBtn.Size = UDim2.new(1, 0, 0, 14); sliderBtn.Position = UDim2.new(0, 0, 0, 22); sliderBtn.BackgroundTransparency = 1; sliderBtn.Text = ""; local bar = Instance.new("Frame", sliderBtn); bar.Size = UDim2.new(1, 0, 0, 6); bar.Position = UDim2.new(0, 0, 0.5, -3); bar.BackgroundColor3 = Color3.fromRGB(45, 45, 50); Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 3); local fill = Instance.new("Frame", bar); fill.Size = UDim2.new((def - min) / (max - min), 0, 1, 0); fill.BackgroundColor3 = Library.Accent; Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 3); comp.Fill = fill; table.insert(modData.Components, comp) 
            local function update(input) local sizeX = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1); local val = min + (max - min) * sizeX; fill.Size = UDim2.new(sizeX, 0, 1, 0); vText.Text = n .. ": " .. string.format("%."..dec.."f", val); cb(val) end 
            local dragging = false; sliderBtn.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; update(input) end end); UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end); UserInputService.InputChanged:Connect(function(input) if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then update(input) end end) 
            return Mod 
        end 
        function Mod:CreateToggle(n, cb) 
            local comp = {Type = "Toggle", State = false}; local b = Instance.new("TextButton", Nodes); b.Size = UDim2.new(0.95, 0, 0, 26); b.BackgroundTransparency = 1; b.Text = "  " .. n; b.Font = Library._Config.FontMedium; b.TextColor3 = Color3.new(1,1,1); b.TextSize = 12; b.TextXAlignment = 0; local box = Instance.new("Frame", b); box.Size = UDim2.new(0, 16, 0, 16); box.Position = UDim2.new(1, -20, 0.5, -8); box.BackgroundColor3 = Color3.fromRGB(40, 40, 45); Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4); comp.Box = box; table.insert(modData.Components, comp) 
            b.MouseButton1Click:Connect(function() comp.State = not comp.State; cb(comp.State); SafeTween(box, {BackgroundColor3 = comp.State and Library.Accent or Color3.fromRGB(40, 40, 45)}, 0.2) end) 
            return Mod 
        end
        return Mod 
    end 
    return Window 
end

return Library
