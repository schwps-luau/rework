        else
            TargetHUD.Visible = false
        end

        SearchFrame.BackgroundTransparency = self.Transparency 
        KBGui.BackgroundTransparency = self.Transparency; KBTitle.TextColor3 = self.Accent; KBGui.Visible = self.KeybindList 
        
        for _, item in pairs(self._WMModules) do item.Frame.Visible = self[item.Key]; item.Frame.BackgroundTransparency = self.Transparency end 
        m_title.Text = "NIGHT <font color='#" .. self.Accent:ToHex() .. "'>DLC</font>" 
        m_user.Text = "<font color='#" .. self.Accent:ToHex() .. "'>" .. LocalPlayer.DisplayName .. "</font>" 
        fpsTimer = fpsTimer + dt; if fpsTimer >= 0.5 then lastFps = math.floor(1/dt); fpsTimer = 0 end 
        m_fps.Text = lastFps .. " <font color='#"..self.Accent:ToHex().."'>fps</font>" 
        m_ping.Text = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) .. " <font color='#"..self.Accent:ToHex().."'>ms</font>" 
        m_time.Text = os.date("%X") 
