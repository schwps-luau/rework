local Library = {
    CurrentX = 20,
    CurrentY = 115, 
    Spacing = 195,
    Accent = Color3.fromRGB(180, 50, 180)
}

local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Stats = game:GetService("Stats")

local function Tween(obj, time, goal)
    TweenService:Create(obj, TweenInfo.new(time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), goal):Play()
end

-- [ ПЕРЕДЕЛАННЫЙ HUD: 2 ЭТАЖА + ФИКС FPS/PING + КООРДИНАТЫ ]
function Library:InitHUD()
    local HUD = Instance.new("ScreenGui", CoreGui)
    HUD.Name = "NightHUD_Final"
    
    local LayoutContainer = Instance.new("Frame", HUD)
    LayoutContainer.Size = UDim2.new(0, 800, 0, 80)
    LayoutContainer.Position = UDim2.new(0, 15, 0, 15)
    LayoutContainer.BackgroundTransparency = 1
    
    local MainLayout = Instance.new("UIListLayout", LayoutContainer)
    MainLayout.Padding = UDim.new(0, 6)

    local function CreateRow()
        local r = Instance.new("Frame", LayoutContainer)
        r.Size = UDim2.new(1, 0, 0, 28)
        r.BackgroundTransparency = 1
        local l = Instance.new("UIListLayout", r)
        l.FillDirection = Enum.FillDirection.Horizontal
        l.Padding = UDim.new(0, 6)
        return r
    end

    local Row1 = CreateRow() -- Первый этаж
    local Row2 = CreateRow() -- Второй этаж

    local function CreateSection(parent, text)
        local f = Instance.new("Frame", parent)
        f.BackgroundColor3 = Color3.fromRGB(12, 12, 15)
        f.AutomaticSize = Enum.AutomaticSize.XY
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 4)
        local s = Instance.new("UIStroke", f)
        s.Color = Color3.fromRGB(45, 45, 50)
        s.Thickness = 1
        
        local p = Instance.new("UIPadding", f)
        p.PaddingLeft = UDim.new(0, 10); p.PaddingRight = UDim.new(0, 10)

        local l = Instance.new("TextLabel", f)
        l.Size = UDim2.new(0, 0, 0, 26)
        l.AutomaticSize = Enum.AutomaticSize.X
        l.Text = text; l.RichText = true
        l.TextColor3 = Color3.fromRGB(255, 255, 255)
        l.Font = Enum.Font.GothamMedium; l.TextSize = 13; l.BackgroundTransparency = 1
        return l
    end

    -- Секции
    local brand = CreateSection(Row1, "<font color='#B432B4'>N</font>ight <font color='#888888'>Alpha</font>")
    local user = CreateSection(Row1, "User: <font color='#B432B4'>" .. game.Players.LocalPlayer.Name .. "</font>")
    
    local fpsStat = CreateSection(Row2, "60 <font color='#B432B4'>Fps</font>")
    local pingStat = CreateSection(Row2, "0 <font color='#B432B4'>Ms</font>")
    local coordsStat = CreateSection(Row2, "0, 0, 0")
    local timeStat = CreateSection(Row2, os.date("%X"))

    -- Обновление статов
    local lastUpdate = 0
    RunService.RenderStepped:Connect(function(dt)
        lastUpdate = lastUpdate + dt
        if lastUpdate >= 0.5 then -- Обновляем раз в полсекунды, чтобы не мельтешило
            lastUpdate = 0
            
            -- FPS
            fpsStat.Text = math.floor(1/dt) .. " <font color='#B432B4'>Fps</font>"
            
            -- Ping (Реальный сетевой пинг)
            local p = math.floor(Stats.Network.ServerTickTagAverage:GetValue())
            pingStat.Text = p .. " <font color='#B432B4'>Ms</font>"
            
            -- Time
            timeStat.Text = os.date("%X")
            
            -- Coords
            local lp = game.Players.LocalPlayer
            if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                local pos = lp.Character.HumanoidRootPart.Position
                coordsStat.Text = string.format("%d, %d, %d", math.floor(pos.X), math.floor(pos.Y), math.floor(pos.Z))
            end
        end
    end)
end

-- [ ФУНКЦИЯ ОКНА ]
function Library:CreateWindow(name)
    if not self.MainGui then
        self.MainGui = Instance.new("ScreenGui", CoreGui)
        self:InitHUD()
    end

    local xPos = self.CurrentX
    self.CurrentX = self.CurrentX + self.Spacing

    local Main = Instance.new("Frame", self.MainGui)
    Main.Name = name
    Main.Size = UDim2.new(0, 180, 0, 38)
    Main.Position = UDim2.new(0, xPos, 0, self.CurrentY)
    Main.BackgroundColor3 = Color3.fromRGB(15, 15, 18)
    Main.BackgroundTransparency = 0
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 5)
    Instance.new("UIStroke", Main).Color = Color3.fromRGB(45, 45, 50)

    local Header = Instance.new("TextLabel", Main)
    Header.Size = UDim2.new(1, 0, 1, 0)
    Header.Text = name; Header.TextColor3 = Color3.fromRGB(255, 255, 255)
    Header.Font = Enum.Font.GothamBold; Header.TextSize = 14; Header.BackgroundTransparency = 1

    local Content = Instance.new("Frame", Main)
    Content.Position = UDim2.new(0, 0, 1, 2)
    Content.Size = UDim2.new(1, 0, 0, 0)
    Content.BackgroundTransparency = 1
    local Layout = Instance.new("UIListLayout", Content)
    Layout.Padding = UDim.new(0, 1)

    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        Content.Size = UDim2.new(1, 0, 0, Layout.AbsoluteContentSize.Y)
    end)

    -- Перетаскивание
    local dragStart, startPos, dragging
    Main.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = i.Position; startPos = Main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = i.Position - dragStart
            Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

    local Category = {}
    function Category:CreateModule(modName, callback)
        local Enabled = false
        local MFrame = Instance.new("Frame", Content)
        MFrame.Size = UDim2.new(1, 0, 0, 30)
        MFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 23)
        MFrame.BorderSizePixel = 0
        
        local MBtn = Instance.new("TextButton", MFrame)
        MBtn.Size = UDim2.new(1, 0, 1, 0)
        MBtn.BackgroundTransparency = 1
        MBtn.Text = "  " .. modName
        MBtn.TextColor3 = Color3.fromRGB(160, 160, 160)
        MBtn.Font = Enum.Font.Gotham; MBtn.TextSize = 13; MBtn.TextXAlignment = 0
        MBtn.AutoButtonColor = false

        local Indicator = Instance.new("Frame", MFrame)
        Indicator.Size = UDim2.new(0, 2, 0, 0)
        Indicator.Position = UDim2.new(1, -2, 0.5, 0)
        Indicator.AnchorPoint = Vector2.new(0, 0.5)
        Indicator.BackgroundColor3 = Library.Accent
        Indicator.BorderSizePixel = 0

        MBtn.MouseButton1Click:Connect(function()
            Enabled = not Enabled
            Tween(MBtn, 0.2, {TextColor3 = Enabled and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(160, 160, 160)})
            Tween(Indicator, 0.2, {Size = UDim2.new(0, 2, 0, Enabled and 20 or 0)})
            callback(Enabled)
        end)
        return {}
    end
    return Category
end

return Library