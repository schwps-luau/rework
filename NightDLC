local Library = {
    Accent = Color3.fromRGB(180, 50, 180),
    ToggleKey = Enum.KeyCode.RightShift,
    _Config = {
        WindowWidth = 240,
        ModuleHeight = 38,
        Spacing = 10,
        StartY = 220,
        Transparency = 0.5, 
        FontBold = Enum.Font.GothamBold, 
        FontMedium = Enum.Font.GothamMedium,
        Rounding = UDim.new(0, 8)
    },
    _Visible = true,
    _CurrentX = 20,
    _Initialized = false,
    _Keybinds = {},
    _Modules = {},
    _LastKBState = ""
}

local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Stats = game:GetService("Stats")
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")

local LocalPlayer = Players.LocalPlayer

local MenuBlur = Instance.new("BlurEffect", Lighting)
MenuBlur.Size = 18; MenuBlur.Enabled = true

local function SafeTween(obj, goal)
    if not obj then return end
    TweenService:Create(obj, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), goal):Play()
end

local function MakeDraggable(obj)
    local dragging, dragInput, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = obj.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

function Library:CreateStyledFrame(parent, size, pos)
    local f = Instance.new("Frame", parent)
    f.Size = size or UDim2.new(0, 100, 0, 30); f.Position = pos or UDim2.new(0,0,0,0)
    f.BackgroundColor3 = Color3.fromRGB(10, 10, 12); f.BackgroundTransparency = self._Config.Transparency
    Instance.new("UICorner", f).CornerRadius = self._Config.Rounding
    return f
end

function Library:InitHUD()
    if self._Initialized then return end
    self._Initialized = true

    local HUD = Instance.new("ScreenGui", CoreGui); HUD.Name = "Night_Final_V4"; self.MainGui = HUD
    local MenuContainer = Instance.new("CanvasGroup", HUD)
    MenuContainer.Size = UDim2.new(1, 0, 1, 0); MenuContainer.BackgroundTransparency = 1; self.MenuContainer = MenuContainer

    -- ВАТЕРМАРК (ФИКСИРОВАН СЛЕВА СВЕРХУ)
    local WMMain = Instance.new("Frame", HUD)
    WMMain.Size = UDim2.new(0, 600, 0, 70); WMMain.Position = UDim2.new(0, 20, 0, 20); WMMain.BackgroundTransparency = 1
    
    local WMList = Instance.new("UIListLayout", WMMain)
    WMList.Padding = UDim.new(0, 6); WMList.SortOrder = Enum.SortOrder.LayoutOrder

    local function CreateFloor(order)
        local f = Instance.new("Frame", WMMain)
        f.Size = UDim2.new(1, 0, 0, 28); f.BackgroundTransparency = 1; f.LayoutOrder = order
        local l = Instance.new("UIListLayout", f)
        l.FillDirection = Enum.FillDirection.Horizontal; l.Padding = UDim.new(0, 6); l.SortOrder = Enum.SortOrder.LayoutOrder
        return f
    end

    local Floor1 = CreateFloor(1)
    local Floor2 = CreateFloor(2)

    local function CreateWMModule(parent, text, order)
        local f = self:CreateStyledFrame(parent, UDim2.new(0, 0, 1, 0))
        f.AutomaticSize = Enum.AutomaticSize.X; f.LayoutOrder = order
        Instance.new("UIPadding", f).PaddingLeft = UDim.new(0, 12); f.UIPadding.PaddingRight = UDim.new(0, 12)
        local l = Instance.new("TextLabel", f); l.Size = UDim2.new(1,0,1,0); l.Font = self._Config.FontBold; l.TextSize = 12; l.TextColor3 = Color3.new(1,1,1); l.BackgroundTransparency = 1; l.RichText = true; l.Text = text
        return l
    end

    -- РЯД 1: Заголовок, Ник, FPS, Время
    local m_title = CreateWMModule(Floor1, "NIGHT <font color='#" .. self.Accent:ToHex() .. "'>DLC</font>", 1)
    local m_user = CreateWMModule(Floor1, "<font color='#" .. self.Accent:ToHex() .. "'>" .. LocalPlayer.DisplayName .. "</font>", 2)
    local m_fps = CreateWMModule(Floor1, "0 <font color='#" .. self.Accent:ToHex() .. "'>fps</font>", 3)
    local m_time = CreateWMModule(Floor1, "00:00:00", 4)
    
    -- РЯД 2: Координаты, Пинг
    local m_pos = CreateWMModule(Floor2, "<font color='#" .. self.Accent:ToHex() .. "'>pos:</font> 0, 0, 0", 1)
    local m_ping = CreateWMModule(Floor2, "0 <font color='#" .. self.Accent:ToHex() .. "'>ms</font>", 2)

    local lastFps, fpsTimer = 0, 0
    RunService.RenderStepped:Connect(function(dt)
        fpsTimer = fpsTimer + dt
        if fpsTimer >= 0.8 then
            lastFps = math.floor(1/dt)
            m_fps.Text = string.format("%d <font color='#%s'>fps</font>", lastFps, self.Accent:ToHex())
            fpsTimer = 0
        end
        local p = LocalPlayer.Character and LocalPlayer.Character.PrimaryPart and LocalPlayer.Character.PrimaryPart.Position or Vector3.new(0,0,0)
        local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
        
        m_ping.Text = string.format("%d <font color='#%s'>ms</font>", ping, self.Accent:ToHex())
        m_pos.Text = string.format("<font color='#%s'>pos:</font> %.0f, %.0f, %.0f", self.Accent:ToHex(), p.X, p.Y, p.Z)
        m_time.Text = os.date("%X")
    end)

    -- КЕЙБИНД ЛИСТ (СПРАВА СВЕРХУ, ПЕРЕДВИЖНОЙ)
    local KBGui = self:CreateStyledFrame(HUD, UDim2.new(0, 180, 0, 32), UDim2.new(1, -200, 0, 20))
    MakeDraggable(KBGui)
    local KBTitle = Instance.new("TextLabel", KBGui); KBTitle.Size = UDim2.new(1, 0, 0, 32); KBTitle.Text = "Keybinds"; KBTitle.Font = self._Config.FontBold; KBTitle.TextSize = 13; KBTitle.TextColor3 = self.Accent; KBTitle.BackgroundTransparency = 1
    local KBList = Instance.new("Frame", KBGui); KBList.Position = UDim2.new(0, 0, 0, 32); KBList.Size = UDim2.new(1, 0, 0, 0); KBList.BackgroundTransparency = 1
    Instance.new("UIListLayout", KBList).Padding = UDim.new(0, 2); Instance.new("UIPadding", KBList).PaddingLeft = UDim.new(0, 10)

    RunService.RenderStepped:Connect(function()
        local state = ""
        for n, d in pairs(self._Keybinds) do if d.Key then state = state .. n .. tostring(d.Enabled) end end
        if self._LastKBState ~= state then
            self._LastKBState = state
            for _, v in pairs(KBList:GetChildren()) do if v:IsA("TextLabel") then v:Destroy() end end
            local count = 0
            for name, data in pairs(self._Keybinds) do
                if data.Key then
                    count = count + 1
                    local l = Instance.new("TextLabel", KBList); l.Size = UDim2.new(1, 0, 0, 20); l.BackgroundTransparency = 1
                    l.Text = string.format("[%s] %s", data.Key.Name, name); l.Font = self._Config.FontBold; l.TextSize = 11; l.TextXAlignment = 0
                    l.TextColor3 = data.Enabled and self.Accent or Color3.fromRGB(150, 150, 150)
                end
            end
            SafeTween(KBGui, {Size = UDim2.new(0, 180, 0, 35 + (count * 22))})
        end
    end)

    -- ПОИСК
    local SearchFrame = self:CreateStyledFrame(self.MenuContainer, UDim2.new(0, 200, 0, 35), UDim2.new(0.5, -100, 0.9, 0))
    local SearchInput = Instance.new("TextBox", SearchFrame); SearchInput.Size = UDim2.new(1, -10, 1, 0); SearchInput.Position = UDim2.new(0, 5, 0, 0); SearchInput.BackgroundTransparency = 1; SearchInput.PlaceholderText = "Search: Ctrl + F"; SearchInput.Text = ""; SearchInput.Font = self._Config.FontMedium; SearchInput.TextSize = 13; SearchInput.TextColor3 = Color3.new(1,1,1)
    self.SearchBox = SearchInput
    SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
        local q = SearchInput.Text:lower()
        for _, mod in pairs(self._Modules) do mod.Frame.Visible = mod.Name:lower():find(q) ~= nil end
    end)
end

function Library:CreateWindow(name)
    self:InitHUD()
    local cfg = self._Config
    local Main = self:CreateStyledFrame(self.MenuContainer, UDim2.new(0, cfg.WindowWidth, 0, 40), UDim2.new(0, self._CurrentX, 0, cfg.StartY))
    self._CurrentX = self._CurrentX + cfg.WindowWidth + cfg.Spacing
    MakeDraggable(Main)

    local Header = Instance.new("TextLabel", Main); Header.Size = UDim2.new(1, 0, 0, 40); Header.Text = name; Header.Font = cfg.FontBold; Header.TextColor3 = Color3.new(1,1,1); Header.BackgroundTransparency = 1; Header.TextSize = 14
    local Scroll = Instance.new("ScrollingFrame", Main); Scroll.Position = UDim2.new(0, 0, 0, 40); Scroll.Size = UDim2.new(1, 0, 0, 0); Scroll.BackgroundTransparency = 1; Scroll.ScrollBarThickness = 0
    local Layout = Instance.new("UIListLayout", Scroll); Layout.Padding = UDim.new(0, 4); Layout.HorizontalAlignment = "Center"

    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local h = math.min(Layout.AbsoluteContentSize.Y + 10, 500)
        Scroll.Size = UDim2.new(1, 0, 0, h); Main.Size = UDim2.new(0, cfg.WindowWidth, 0, h + 45)
    end)

    local Window = {}
    function Window:CreateModule(modName, callback)
        local Enabled, Opened, Binding, CurrentKey = false, false, false, nil
        local MFrame = Instance.new("Frame", Scroll); MFrame.Size = UDim2.new(1, -12, 0, cfg.ModuleHeight); MFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 25); MFrame.BackgroundTransparency = cfg.Transparency; MFrame.ClipsDescendants = true
        Instance.new("UICorner", MFrame).CornerRadius = cfg.Rounding
        
        local MBtn = Instance.new("TextButton", MFrame); MBtn.Size = UDim2.new(1, 0, 0, cfg.ModuleHeight); MBtn.BackgroundTransparency = 1; MBtn.Text = "  " .. modName; MBtn.Font = cfg.FontMedium; MBtn.TextSize = 13; MBtn.TextColor3 = Color3.fromRGB(200, 200, 200); MBtn.TextXAlignment = 0
        local Dots = Instance.new("TextLabel", MFrame); Dots.Size = UDim2.new(0, 20, 0, cfg.ModuleHeight); Dots.Position = UDim2.new(1, -25, 0, 0); Dots.BackgroundTransparency = 1; Dots.Text = "..."; Dots.Font = cfg.FontBold; Dots.TextSize = 14; Dots.TextColor3 = Color3.new(1,1,1); Dots.Visible = false
        local Nodes = Instance.new("Frame", MFrame); Nodes.Position = UDim2.new(0, 0, 0, cfg.ModuleHeight); Nodes.Size = UDim2.new(1, 0, 0, 0); Nodes.BackgroundTransparency = 1
        local NLayout = Instance.new("UIListLayout", Nodes); NLayout.Padding = UDim.new(0, 6); NLayout.HorizontalAlignment = "Center"

        table.insert(Library._Modules, {Name = modName, Frame = MFrame})
        Library._Keybinds[modName] = {Enabled = false, Key = nil}

        local function UpdateSize()
            local target = Opened and (cfg.ModuleHeight + NLayout.AbsoluteContentSize.Y + 10) or cfg.ModuleHeight
            SafeTween(MFrame, {Size = UDim2.new(1, -12, 0, target)})
        end
        NLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            Dots.Visible = #Nodes:GetChildren() > 1; UpdateSize()
        end)

        local function Toggle()
            Enabled = not Enabled
            SafeTween(MFrame, {BackgroundColor3 = Enabled and Library.Accent or Color3.fromRGB(20, 20, 25)})
            Library._Keybinds[modName].Enabled = Enabled
            callback(Enabled)
        end

        MBtn.MouseButton1Click:Connect(Toggle)
        MBtn.MouseButton2Click:Connect(function() if Dots.Visible then Opened = not Opened; UpdateSize(); SafeTween(Dots, {Rotation = Opened and 90 or 0}) end end)
        MBtn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton3 then Binding = true; MBtn.Text = "  " .. modName .. " [?]" end end)

        UserInputService.InputBegan:Connect(function(i, g)
            if Binding and not g then
                CurrentKey = i.KeyCode; Binding = false; MBtn.Text = "  " .. modName; Library._Keybinds[modName].Key = i.KeyCode
            elseif CurrentKey and i.KeyCode == CurrentKey and not g then Toggle() end
        end)

        local Mod = {}
        function Mod:CreateSlider(n, min, max, def, cb)
            local f = Instance.new("Frame", Nodes); f.Size = UDim2.new(0.9, 0, 0, 32); f.BackgroundTransparency = 1
            local t = Instance.new("TextLabel", f); t.Size = UDim2.new(1, 0, 0, 16); t.Text = n .. ": " .. def; t.Font = cfg.FontMedium; t.TextSize = 11; t.TextColor3 = Color3.new(1, 1, 1); t.BackgroundTransparency = 1; t.TextXAlignment = 0
            local b = Instance.new("Frame", f); b.Size = UDim2.new(1, 0, 0, 6); b.Position = UDim2.new(0, 0, 0.7, 0); b.BackgroundColor3 = Color3.new(0, 0, 0); Instance.new("UICorner", b)
            local fill = Instance.new("Frame", b); fill.Size = UDim2.new((def-min)/(max-min), 0, 1, 0); fill.BackgroundColor3 = Library.Accent; Instance.new("UICorner", fill)
            local function Upd(i)
                local per = math.clamp((i.Position.X - b.AbsolutePosition.X) / b.AbsoluteSize.X, 0, 1)
                local val = math.floor(min + (max - min) * per); fill.Size = UDim2.new(per, 0, 1, 0); t.Text = n .. ": " .. val; cb(val)
            end
            local d = false; b.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then d = true; Upd(i) end end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then d = false end end)
            UserInputService.InputChanged:Connect(function(i) if d and i.UserInputType == Enum.UserInputType.MouseMovement then Upd(i) end end)
            return Mod
        end

        function Mod:CreateToggle(n, cb)
            local s = false
            local b = Instance.new("TextButton", Nodes); b.Size = UDim2.new(0.95, 0, 0, 26); b.BackgroundColor3 = Color3.fromRGB(15, 15, 20); b.BackgroundTransparency = 0.5; b.Text = "  " .. n; b.Font = cfg.FontMedium; b.TextColor3 = Color3.new(1,1,1); b.TextSize = 12; b.TextXAlignment = 0; Instance.new("UICorner", b)
            local box = Instance.new("Frame", b); box.Size = UDim2.new(0, 16, 0, 16); box.Position = UDim2.new(1, -20, 0.5, 0); box.AnchorPoint = Vector2.new(0, 0.5); box.BackgroundColor3 = Color3.new(0,0,0); Instance.new("UICorner", box)
            b.MouseButton1Click:Connect(function() s = not s; SafeTween(box, {BackgroundColor3 = s and Library.Accent or Color3.new(0,0,0)}); cb(s) end)
            return Mod
        end

        function Mod:CreateButton(n, cb)
            local b = Instance.new("TextButton", Nodes); b.Size = UDim2.new(0.95, 0, 0, 26); b.BackgroundColor3 = Color3.fromRGB(30, 30, 35); b.BackgroundTransparency = 0.5; b.Text = n; b.Font = cfg.FontMedium; b.TextColor3 = Color3.new(1, 1, 1); b.TextSize = 12; Instance.new("UICorner", b)
            b.MouseButton1Click:Connect(cb); return Mod
        end

        function Mod:CreateSelector(n, list, cb)
            local f = Instance.new("Frame", Nodes); f.Size = UDim2.new(0.95, 0, 0, 40); f.BackgroundTransparency = 1
            local t = Instance.new("TextLabel", f); t.Size = UDim2.new(1, 0, 0, 14); t.Text = "  " .. n; t.Font = cfg.FontMedium; t.TextSize = 11; t.TextColor3 = Color3.fromRGB(180, 180, 180); t.BackgroundTransparency = 1; t.TextXAlignment = 0
            local c = Instance.new("Frame", f); c.Size = UDim2.new(1, 0, 0, 24); c.Position = UDim2.new(0, 0, 0, 16); c.BackgroundTransparency = 1
            local l = Instance.new("UIListLayout", c); l.FillDirection = "Horizontal"; l.Padding = UDim.new(0, 5)
            local active = nil
            for i, v in pairs(list) do
                local p = Instance.new("TextButton", c); p.Size = UDim2.new(0, 0, 1, 0); p.AutomaticSize = "X"; p.Text = v; p.Font = cfg.FontMedium; p.TextSize = 10; p.BackgroundColor3 = Color3.fromRGB(40, 40, 45); p.BackgroundTransparency = 0.5; p.TextColor3 = Color3.new(1,1,1)
                Instance.new("UICorner", p); Instance.new("UIPadding", p).PaddingLeft = UDim.new(0, 8); p.UIPadding.PaddingRight = UDim.new(0, 8)
                if i == 1 then active = p; p.BackgroundColor3 = Library.Accent; p.BackgroundTransparency = 0.2 end
                p.MouseButton1Click:Connect(function()
                    if active then active.BackgroundColor3 = Color3.fromRGB(40, 40, 45); active.BackgroundTransparency = 0.5 end
                    active = p; p.BackgroundColor3 = Library.Accent; p.BackgroundTransparency = 0.2; cb(v)
                end)
            end
            return Mod
        end
        return Mod
    end
    return Window
end

UserInputService.InputBegan:Connect(function(i, g)
    if not g then
        if i.KeyCode == Library.ToggleKey then
            Library._Visible = not Library._Visible
            MenuBlur.Enabled = Library._Visible
            local targetPos = Library._Visible and UDim2.new(0,0,0,0) or UDim2.new(0,0,1,0)
            SafeTween(Library.MenuContainer, {Position = targetPos, GroupTransparency = Library._Visible and 0 or 1})
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and i.KeyCode == Enum.KeyCode.F and Library._Visible then
            Library.SearchBox:CaptureFocus()
        end
    end
end)

return Library
