local Library = {
    Accent = Color3.fromRGB(180, 50, 180),
    ToggleKey = Enum.KeyCode.RightShift,
    _Config = {
        WindowWidth = 240,
        ModuleHeight = 38,
        Spacing = 10,
        StartY = 220,
        Transparency = 0.5, 
        FontBold = Enum.Font.GothamBold, 
        FontMedium = Enum.Font.GothamMedium,
        Rounding = UDim.new(0, 10)
    },
    _Visible = true,
    _CurrentX = 20,
    _Initialized = false,
    _Keybinds = {},
    _Modules = {},
}

local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")
local Stats = game:GetService("Stats")
local Lighting = game:GetService("Lighting")
local Players = game:GetService("Players")

local MenuBlur = Instance.new("BlurEffect", Lighting)
MenuBlur.Size = 18; MenuBlur.Enabled = true

local function SafeTween(obj, goal)
    if not obj then return end
    TweenService:Create(obj, TweenInfo.new(0.2, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), goal):Play()
end

-- Функция перетаскивания (оставил только для HUD элементов)
local function MakeDraggable(obj)
    local dragging, dragInput, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = input.Position; startPos = obj.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

-- Вспомогательная функция для создания стилизованного окна/элемента с прозрачностью
function Library:CreateStyledFrame(parent, size, pos)
    local f = Instance.new("Frame", parent)
    f.Size = size or UDim2.new(0, 100, 0, 30); f.Position = pos or UDim2.new(0,0,0,0)
    f.BackgroundColor3 = Color3.fromRGB(15, 15, 18); f.BackgroundTransparency = self._Config.Transparency
    Instance.new("UICorner", f).CornerRadius = self._Config.Rounding
    -- БЛЯДСКИЙ АУТЛАЙН УДАЛЕН
    return f
end

function Library:InitHUD()
    if self._Initialized then return end
    self._Initialized = true

    local HUD = Instance.new("ScreenGui", CoreGui); HUD.Name = "NightHUD_Final"; self.MainGui = HUD
    
    local MenuContainer = Instance.new("CanvasGroup", HUD)
    MenuContainer.Size = UDim2.new(1, 0, 1, 0); MenuContainer.BackgroundTransparency = 1; self.MenuContainer = MenuContainer

    -- 1. СЕГМЕНТИРОВАННЫЙ ВАТЕРМАРК (ФИКСИРОВАННЫЙ)
    local WMFrame = Instance.new("Frame", HUD)
    WMFrame.Size = UDim2.new(0, 260, 0, 50); WMFrame.Position = UDim2.new(0, 20, 0, 20)
    WMFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 12); WMFrame.BackgroundTransparency = 0.2
    Instance.new("UICorner", WMFrame).CornerRadius = UDim.new(0, 8); Instance.new("UIStroke", WMFrame).Color = self.Accent

    local function CreateSeparator(parent, pos)
        local f = Instance.new("Frame", parent); f.Size = UDim2.new(0, 1, 1, -10); f.Position = UDim2.new(0, pos, 0, 5); f.BackgroundColor3 = Color3.fromRGB(50, 50, 55); f.BorderSizePixel = 0
    end

    -- Logos / Alpha
    local mod_title = Instance.new("TextLabel", WMFrame)
    mod_title.Size = UDim2.new(0, 80, 0, 20); mod_title.Position = UDim2.new(0, 10, 0, 5)
    mod_title.BackgroundTransparency = 1; mod_title.Font = self._Config.FontBold; mod_title.TextSize = 13; mod_title.TextColor3 = Color3.new(1,1,1); mod_title.Text = "Night DLC"
    CreateSeparator(WMFrame, 95)

    -- FPS / Time
    local mod_fps = Instance.new("TextLabel", WMFrame)
    mod_fps.Size = UDim2.new(0, 70, 0, 20); mod_fps.Position = UDim2.new(0, 100, 0, 5)
    mod_fps.BackgroundTransparency = 1; mod_fps.Font = self._Config.FontMedium; mod_fps.TextSize = 11; mod_fps.TextColor3 = Color3.fromRGB(220, 220, 220); mod_fps.Text = "0 FPS"
    local mod_time = Instance.new("TextLabel", WMFrame)
    mod_time.Size = UDim2.new(0, 70, 0, 20); mod_time.Position = UDim2.new(0, 100, 0, 25)
    mod_time.BackgroundTransparency = 1; mod_time.Font = self._Config.FontMedium; mod_time.TextSize = 11; mod_time.TextColor3 = Color3.fromRGB(180, 180, 180); mod_time.Text = "00:00:00"
    CreateSeparator(WMFrame, 175)

    -- Coords / Ping
    local mod_coords = Instance.new("TextLabel", WMFrame)
    mod_coords.Size = UDim2.new(0, 70, 0, 20); mod_coords.Position = UDim2.new(0, 180, 0, 5)
    mod_coords.BackgroundTransparency = 1; mod_coords.Font = self._Config.FontMedium; mod_coords.TextSize = 10; mod_coords.TextColor3 = Color3.fromRGB(160, 160, 165); mod_coords.Text = "0, 0, 0"
    local mod_ping = Instance.new("TextLabel", WMFrame)
    mod_ping.Size = UDim2.new(0, 70, 0, 20); mod_ping.Position = UDim2.new(0, 180, 0, 25)
    mod_ping.BackgroundTransparency = 1; mod_ping.Font = self._Config.FontMedium; mod_ping.TextSize = 10; mod_ping.TextColor3 = Color3.fromRGB(140, 140, 145); mod_ping.Text = "0 ms"

    RunService.RenderStepped:Connect(function(dt)
        local pos = Players.LocalPlayer.Character and Players.LocalPlayer.Character.PrimaryPart.Position or Vector3.new(0,0,0)
        local time = os.date("%X")
        local fps = math.floor(1/dt)
        local ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())
        
        mod_fps.Text = fps .. " FPS"
        mod_time.Text = time
        mod_coords.Text = string.format("%.0f, %.0f, %.0f", pos.X, pos.Y, pos.Z)
        mod_ping.Text = ping .. " ms"
    end)

    -- 2. KEYBIND LIST (ДВИГАЕТСЯ)
    local KBGui = self:CreateStyledFrame(HUD, UDim2.new(0, 180, 0, 32), UDim2.new(0, 20, 0, 300))
    KBGui.Name = "KeybindList"; MakeDraggable(KBGui)
    
    local KBTitle = Instance.new("TextLabel", KBGui)
    KBTitle.Size = UDim2.new(1, 0, 0, 32); KBTitle.Text = "HotKeys"; KBTitle.Font = self._Config.FontBold; 
    KBTitle.TextSize = 13; KBTitle.TextColor3 = Color3.new(1, 1, 1); KBTitle.BackgroundTransparency = 1
    
    local KBList = Instance.new("Frame", KBGui)
    KBList.Position = UDim2.new(0, 0, 0, 32); KBList.Size = UDim2.new(1, 0, 0, 0); KBList.BackgroundTransparency = 1
    Instance.new("UIListLayout", KBList).Padding = UDim.new(0, 2)
    Instance.new("UIPadding", KBList).PaddingLeft = UDim.new(0, 10)

    RunService.RenderStepped:Connect(function()
        local state = ""
        for n, d in pairs(self._Keybinds) do state = state .. n .. tostring(d.Enabled) end
        if self._LastKBState ~= state then
            self._LastKBState = state
            for _, v in pairs(KBList:GetChildren()) do if v:IsA("TextLabel") then v:Destroy() end end
            local count = 0
            for n, d in pairs(self._Keybinds) do
                if d.Enabled then
                    count = count + 1
                    local l = Instance.new("TextLabel", KBList); l.Size = UDim2.new(1, 0, 0, 22); l.BackgroundTransparency = 1
                    l.Text = n; l.Font = self._Config.FontBold; l.TextSize = 11; l.TextColor3 = Color3.new(1, 1, 1); l.TextXAlignment = 0
                end
            end
            SafeTween(KBGui, {Size = UDim2.new(0, 180, 0, 35 + (count * 24))})
        end
    end)

    -- 3. ПОИСК (CTRL + F)
    local SearchFrame = self:CreateStyledFrame(self.MenuContainer, UDim2.new(0, 200, 0, 35), UDim2.new(0.5, -100, 0.9, 0))
    local SearchInput = Instance.new("TextBox", SearchFrame)
    SearchInput.Size = UDim2.new(1, -10, 1, 0); SearchInput.Position = UDim2.new(0, 5, 0, 0); SearchInput.BackgroundTransparency = 1
    -- ДОБАВЛЕНА НАДПИСЬ
    SearchInput.PlaceholderText = "Search: Ctrl + F"; SearchInput.Text = ""; SearchInput.Font = self._Config.FontMedium; SearchInput.TextSize = 13; SearchInput.TextColor3 = Color3.new(1,1,1)
    self.SearchInput = SearchInput

    SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
        local query = SearchInput.Text:lower()
        for _, mod in pairs(self._Modules) do mod.Frame.Visible = mod.Name:lower():find(query) ~= nil end
    end)

    UserInputService.InputBegan:Connect(function(i, g)
        if not g and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) and i.KeyCode == Enum.KeyCode.F and self._Visible then
            SearchInput:CaptureFocus()
        end
    end)
end

function Library:CreateWindow(name)
    self:InitHUD()
    local cfg = self._Config

    local Main = self:CreateStyledFrame(self.MenuContainer, UDim2.new(0, cfg.WindowWidth, 0, 40), UDim2.new(0, self._CurrentX, 0, cfg.StartY))
    -- ОКНА ЗАФИКСИРОВАНЫ
    self._CurrentX = self._CurrentX + cfg.WindowWidth + cfg.Spacing

    local Header = Instance.new("TextLabel", Main)
    Header.Size = UDim2.new(1, 0, 0, 40); Header.Text = name; Header.Font = cfg.FontBold; 
    Header.TextColor3 = Color3.new(1,1,1); Header.BackgroundTransparency = 1; Header.TextSize = 14
    
    local Scroll = Instance.new("ScrollingFrame", Main)
    Scroll.Position = UDim2.new(0, 0, 0, 40); Scroll.Size = UDim2.new(1, 0, 0, 0); Scroll.BackgroundTransparency = 1; Scroll.ScrollBarThickness = 0
    local Layout = Instance.new("UIListLayout", Scroll); Layout.Padding = UDim.new(0, 2); Layout.HorizontalAlignment = "Center"

    Layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        local h = math.min(Layout.AbsoluteContentSize.Y + 10, 500)
        Scroll.Size = UDim2.new(1, 0, 0, h); Main.Size = UDim2.new(0, cfg.WindowWidth, 0, h + 45)
    end)

    local Window = {}
    function Window:CreateModule(modName, callback)
        local Enabled, Opened, Binding, CurrentKey = false, false, false, nil
        local MFrame = Instance.new("Frame", Scroll)
        -- Кнопки не ущербные полностью черные
        MFrame.Size = UDim2.new(1, -8, 0, cfg.ModuleHeight); MFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0); MFrame.BackgroundTransparency = 0.6; MFrame.ClipsDescendants = true
        Instance.new("UICorner", MFrame).CornerRadius = cfg.Rounding

        local MBtn = Instance.new("TextButton", MFrame)
        MBtn.Size = UDim2.new(1, 0, 0, cfg.ModuleHeight); MBtn.BackgroundTransparency = 1; MBtn.Text = "  " .. modName; MBtn.Font = cfg.FontMedium; MBtn.TextSize = 13; MBtn.TextColor3 = Color3.fromRGB(220, 220, 220); MBtn.TextXAlignment = 0
        
        local Dots = Instance.new("TextLabel", MFrame)
        Dots.Size = UDim2.new(0, 20, 0, cfg.ModuleHeight); Dots.Position = UDim2.new(1, -25, 0, 0); Dots.BackgroundTransparency = 1; Dots.Text = "..."; Dots.Font = cfg.FontBold; Dots.TextSize = 14; Dots.TextColor3 = Color3.new(1,1,1)
        -- СКРЫТЫ ПО УМОЛЧАНИЮ
        Dots.Visible = false

        local Nodes = Instance.new("Frame", MFrame)
        Nodes.Position = UDim2.new(0, 0, 0, cfg.ModuleHeight); Nodes.Size = UDim2.new(1, 0, 0, 0); Nodes.BackgroundTransparency = 1
        local NLayout = Instance.new("UIListLayout", Nodes); NLayout.Padding = UDim.new(0, 4); NLayout.HorizontalAlignment = "Center"

        table.insert(Library._Modules, {Name = modName, Frame = MFrame})

        local function UpdateSize()
            local targetSize = Opened and (cfg.ModuleHeight + NLayout.AbsoluteContentSize.Y + 10) or cfg.ModuleHeight
            SafeTween(MFrame, {Size = UDim2.new(1, -8, 0, targetSize)})
        end
        NLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(UpdateSize)

        local function Toggle()
            Enabled = not Enabled
            SafeTween(MFrame, {BackgroundColor3 = Enabled and Library.Accent or Color3.fromRGB(0, 0, 0)})
            SafeTween(MFrame, {BackgroundTransparency = Enabled and Library._Config.Transparency or 0.6})
            Library._Keybinds[modName] = {Enabled = Enabled, Key = CurrentKey}
            callback(Enabled)
        end

        MBtn.MouseButton1Click:Connect(Toggle)
        MBtn.MouseButton2Click:Connect(function() Opened = not Opened; UpdateSize(); SafeTween(Dots, {Rotation = Opened and 90 or 0}) end)
        MBtn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton3 then Binding = true; MBtn.Text = "  [?]" end end)

        UserInputService.InputBegan:Connect(function(i, g)
            if Binding and not g then
                CurrentKey = i.KeyCode; Binding = false; MBtn.Text = "  " .. modName
            elseif CurrentKey and i.KeyCode == CurrentKey and not g then Toggle() end
        end)

        local Mod = {}
        function Mod:CreateSlider(n, min, max, def, cb)
            -- ВКЛЮЧАЕМ ТОЧКИ
            Dots.Visible = true
            local f = Instance.new("Frame", Nodes); f.Size = UDim2.new(0.9, 0, 0, 32); f.BackgroundTransparency = 1
            local t = Instance.new("TextLabel", f); t.Size = UDim2.new(1, 0, 0, 16); t.Text = n .. ": " .. def; t.Font = cfg.FontMedium; t.TextSize = 11; t.TextColor3 = Color3.new(1, 1, 1); t.BackgroundTransparency = 1; t.TextXAlignment = 0
            local b = Instance.new("Frame", f); b.Size = UDim2.new(1, 0, 0, 4); b.Position = UDim2.new(0, 0, 0.75, 0); b.BackgroundColor3 = Color3.new(0, 0, 0); b.BackgroundTransparency = 0.5; Instance.new("UICorner", b)
            
            -- АКЦЕНТНЫЙ СЛАЙДЕР
            local fill = Instance.new("Frame", b); fill.Size = UDim2.new((def-min)/(max-min), 0, 1, 0); fill.BackgroundColor3 = Library.Accent; Instance.new("UICorner", fill)
            
            local function Update(i)
                local per = math.clamp((i.Position.X - b.AbsolutePosition.X) / b.AbsoluteSize.X, 0, 1)
                local val = math.floor(min + (max - min) * per); fill.Size = UDim2.new(per, 0, 1, 0); t.Text = n .. ": " .. val; cb(val)
            end
            local drag = false
            b.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = true; Update(i) end end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end end)
            UserInputService.InputChanged:Connect(function(i) if drag and i.UserInputType == Enum.UserInputType.MouseMovement then Update(i) end end)
            return Mod
        end

        function Mod:CreateToggle(n, cb)
            Dots.Visible = true
            local s = false
            local b = Instance.new("TextButton", Nodes); b.Size = UDim2.new(0.95, 0, 0, 26); b.BackgroundColor3 = Color3.fromRGB(30, 30, 30); b.BackgroundTransparency = 0.4; b.Text = "  " .. n; b.Font = cfg.FontMedium; b.TextColor3 = Color3.new(1,1,1); b.TextSize = 12; b.TextXAlignment = 0; Instance.new("UICorner", b)
            local box = Instance.new("Frame", b); box.Size = UDim2.new(0, 14, 0, 14); box.Position = UDim2.new(1, -20, 0.5, 0); box.AnchorPoint = Vector2.new(0, 0.5); box.BackgroundColor3 = Color3.new(0,0,0); box.BackgroundTransparency = 0.5; Instance.new("UICorner", box)
            b.MouseButton1Click:Connect(function()
                s = not s; SafeTween(box, {BackgroundColor3 = s and Library.Accent or Color3.new(0,0,0)}); cb(s)
            end)
            return Mod
        end

        function Mod:CreateButton(n, cb)
            Dots.Visible = true
            local b = Instance.new("TextButton", Nodes); b.Size = UDim2.new(0.95, 0, 0, 26); b.BackgroundColor3 = Color3.fromRGB(40, 40, 40); b.BackgroundTransparency = 0.4; b.Text = n; b.Font = cfg.FontMedium; b.TextColor3 = Color3.new(1, 1, 1); b.TextSize = 12; Instance.new("UICorner", b)
            b.MouseButton1Click:Connect(cb); return Mod
        end

        -- НОВЫЙ СЕЛЕКТОР (ЧИПСЫ/ПИЛЮЛИ)
        function Mod:CreateSelector(n, options, cb)
            Dots.Visible = true
            local f = Instance.new("Frame", Nodes); f.Size = UDim2.new(0.95, 0, 0, 45); f.BackgroundTransparency = 1
            local t = Instance.new("TextLabel", f); t.Size = UDim2.new(1, 0, 0, 16); t.Text = n; t.Font = cfg.FontMedium; t.TextSize = 11; t.TextColor3 = Color3.new(1, 1, 1); t.BackgroundTransparency = 1; t.TextXAlignment = 0
            
            local c = Instance.new("Frame", f); c.Size = UDim2.new(1, 0, 0, 25); c.Position = UDim2.new(0, 0, 0, 18); c.BackgroundTransparency = 1
            Instance.new("UIListLayout", c).FillDirection = "Horizontal"; c.UIListLayout.Padding = UDim.new(0, 5); c.UIListLayout.HorizontalAlignment = "Center"

            local activePill = nil

            for i, opt in pairs(options) do
                local p = Instance.new("TextButton", c); p.Size = UDim2.new(0, 0, 1, 0); p.AutomaticSize = "X"; p.Text = opt; p.Font = cfg.FontMedium; p.TextSize = 10; p.BackgroundTransparency = self._Config.Transparency; p.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
                Instance.new("UICorner", p).CornerRadius = UDim.new(1, 0); Instance.new("UIPadding", p).PaddingLeft = UDim.new(0, 10); p.UIPadding.PaddingRight = UDim.new(0, 10)
                
                if i == 1 then activePill = p; p.BackgroundColor3 = self.Accent; p.TextColor3 = Color3.new(1,1,1) end

                p.MouseButton1Click:Connect(function()
                    if activePill then activePill.BackgroundColor3 = Color3.fromRGB(45, 45, 50); activePill.TextColor3 = Color3.new(200, 200, 200) end
                    activePill = p; p.BackgroundColor3 = self.Accent; p.TextColor3 = Color3.new(1,1,1)
                    cb(opt)
                end)
            end
            return Mod
        end

        return Mod
    end
    return Window
end

UserInputService.InputBegan:Connect(function(i, g)
    if not g and i.KeyCode == Library.ToggleKey then
        Library._Visible = not Library._Visible
        MenuBlur.Enabled = Library._Visible
        SafeTween(Library.MenuContainer, {GroupTransparency = Library._Visible and 0 or 1})
        if not Library._Visible then Library.SearchInput:ReleaseFocus() end
    end
end)

return Library
