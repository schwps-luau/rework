-- NightDLC Open Source Framework for Roblox
-- Style: 1:1 Reconstruction (Purple Accent, Glassmorphism)

local Library = {
    Categories = {},
    Modules = {},
    Accent = Color3.fromRGB(180, 50, 180),
    Font = Enum.Font.GothamMedium
}

local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui")

-- Вспомогательная функция анимации
local function Tween(obj, time, goal)
    TweenService:Create(obj, TweenInfo.new(time, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), goal):Play()
end

-- Инициализация HUD (Верхняя панель)
function Library:InitHUD()
    local HUD = Instance.new("ScreenGui", CoreGui)
    local Container = Instance.new("Frame", HUD)
    Container.Size = UDim2.new(0, 450, 0, 35)
    Container.Position = UDim2.new(0, 15, 0, 15)
    Container.BackgroundTransparency = 1

    local Layout = Instance.new("UIListLayout", Container)
    Layout.FillDirection = Enum.FillDirection.Horizontal
    Layout.Padding = UDim.new(0, 10)

    local function CreateWidget(icon, text)
        local f = Instance.new("Frame", Container)
        f.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
        f.BackgroundTransparency = 0.2
        f.AutomaticSize = Enum.AutomaticSize.XY
        Instance.new("UICorner", f).CornerRadius = UDim.new(0, 6)
        
        local p = Instance.new("UIPadding", f)
        p.PaddingLeft = UDim.new(0, 10); p.PaddingRight = UDim.new(0, 10)

        local l = Instance.new("TextLabel", f)
        l.Size = UDim2.new(0, 0, 0, 28)
        l.AutomaticSize = Enum.AutomaticSize.X
        l.Text = icon .. "  |  " .. text
        l.TextColor3 = Color3.fromRGB(255, 255, 255)
        l.Font = Enum.Font.GothamSemibold
        l.TextSize = 13
        l.BackgroundTransparency = 1
        return l
    end

    local fps = CreateWidget("⚡", "0 FPS")
    local ping = CreateWidget("📶", "0 Ping")
    local timeL = CreateWidget("🕒", "00:00:00")

    RunService.RenderStepped:Connect(function(dt)
        fps.Text = "⚡  |  " .. math.floor(1/dt) .. " FPS"
        timeL.Text = "🕒  |  " .. os.date("%X")
    end)
end

-- Создание окна категории
function Library:CreateWindow(categoryName, startPos)
    if not self.MainGui then
        self.MainGui = Instance.new("ScreenGui", CoreGui)
        self:InitHUD()
    end

    local Category = {Active = true}
    
    local Main = Instance.new("Frame", self.MainGui)
    Main.Name = categoryName
    Main.Size = UDim2.new(0, 190, 0, 40)
    Main.Position = startPos or UDim2.new(0.1, 0, 0.2, 0)
    Main.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
    Main.BackgroundTransparency = 0.25
    Main.BorderSizePixel = 0
    Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 10)

    local Header = Instance.new("TextLabel", Main)
    Header.Size = UDim2.new(1, 0, 0, 40)
    Header.Text = categoryName
    Header.TextColor3 = Color3.fromRGB(255, 255, 255)
    Header.Font = Enum.Font.GothamBold
    Header.TextSize = 16
    Header.BackgroundTransparency = 1

    local Container = Instance.new("Frame", Main)
    Container.Position = UDim2.new(0, 0, 0, 45)
    Container.Size = UDim2.new(1, 0, 0, 0)
    Container.BackgroundTransparency = 1
    
    local Layout = Instance.new("UIListLayout", Container)
    Layout.SortOrder = Enum.SortOrder.LayoutOrder
    Layout.Padding = UDim.new(0, 3)

    -- Перетаскивание
    local dragStart, startPosFrame, dragging
    Main.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; dragStart = i.Position; startPosFrame = Main.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = i.Position - dragStart
            Main.Position = UDim2.new(startPosFrame.X.Scale, startPosFrame.X.Offset + delta.X, startPosFrame.Y.Scale, startPosFrame.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)

    function Category:CreateModule(name, callback)
        local mod = {Enabled = false, Expanded = false}
        
        local MFrame = Instance.new("Frame", Container)
        MFrame.Size = UDim2.new(1, 0, 0, 34)
        MFrame.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
        MFrame.BackgroundTransparency = 0.4
        MFrame.BorderSizePixel = 0
        MFrame.ClipsDescendants = true
        Instance.new("UICorner", MFrame).CornerRadius = UDim.new(0, 6)

        local MBtn = Instance.new("TextButton", MFrame)
        MBtn.Size = UDim2.new(1, 0, 0, 34)
        MBtn.BackgroundTransparency = 1
        MBtn.Text = "  " .. name
        MBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
        MBtn.Font = Enum.Font.Gotham
        MBtn.TextSize = 14
        MBtn.TextXAlignment = Enum.TextXAlignment.Left
        MBtn.AutoButtonColor = false

        local SContainer = Instance.new("Frame", MFrame)
        SContainer.Position = UDim2.new(0, 0, 0, 34)
        SContainer.Size = UDim2.new(1, 0, 0, 0)
        SContainer.BackgroundTransparency = 1
        local SLayout = Instance.new("UIListLayout", SContainer)

        local function UpdateSize()
            local targetH = mod.Expanded and (34 + SLayout.AbsoluteContentSize.Y + 5) or 34
            Tween(MFrame, 0.3, {Size = UDim2.new(1, 0, 0, targetH)})
            task.wait(0.3)
            Container.Size = UDim2.new(1, 0, 0, Layout.AbsoluteContentSize.Y)
        end

        MBtn.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 then
                mod.Enabled = not mod.Enabled
                Tween(MBtn, 0.2, {TextColor3 = mod.Enabled and Library.Accent or Color3.fromRGB(180, 180, 180)})
                callback(mod.Enabled)
            elseif i.UserInputType == Enum.UserInputType.MouseButton2 then
                mod.Expanded = not mod.Expanded
                UpdateSize()
            end
        end)

        local ModFuncs = {}

        function ModFuncs:AddSlider(sName, min, max, def, cb)
            local SFrame = Instance.new("Frame", SContainer)
            SFrame.Size = UDim2.new(1, 0, 0, 35)
            SFrame.BackgroundTransparency = 1
            
            local L = Instance.new("TextLabel", SFrame)
            L.Size = UDim2.new(1, 0, 0, 20); L.Position = UDim2.new(0, 15, 0, 0)
            L.Text = sName .. ": " .. def; L.TextColor3 = Color3.fromRGB(140, 140, 140)
            L.Font = Enum.Font.Gotham; L.TextSize = 11; L.BackgroundTransparency = 1; L.TextXAlignment = 0

            local Bar = Instance.new("Frame", SFrame)
            Bar.Size = UDim2.new(0.85, 0, 0, 2); Bar.Position = UDim2.new(0.07, 0, 0.75, 0)
            Bar.BackgroundColor3 = Color3.fromRGB(50, 50, 55); Bar.BorderSizePixel = 0

            local Fill = Instance.new("Frame", Bar)
            Fill.Size = UDim2.new((def-min)/(max-min), 0, 1, 0); Fill.BackgroundColor3 = Library.Accent; Fill.BorderSizePixel = 0

            Bar.InputBegan:Connect(function(i)
                if i.UserInputType == Enum.UserInputType.MouseButton1 then
                    local connection = RunService.RenderStepped:Connect(function()
                        local mousePos = UserInputService:GetMouseLocation().X
                        local barPos = Bar.AbsolutePosition.X
                        local barSize = Bar.AbsoluteSize.X
                        local perc = math.clamp((mousePos - barPos) / barSize, 0, 1)
                        Fill.Size = UDim2.new(perc, 0, 1, 0)
                        local val = math.floor(min + (max-min)*perc)
                        L.Text = sName .. ": " .. val
                        cb(val)
                    end)
                    UserInputService.InputEnded:Connect(function(inp)
                        if inp.UserInputType == Enum.UserInputType.MouseButton1 then connection:Disconnect() end
                    end)
                end
            end)
            UpdateSize()
            return ModFuncs
        end

        function ModFuncs:AddToggle(tName, def, cb)
            local tState = def
            local TBtn = Instance.new("TextButton", SContainer)
            TBtn.Size = UDim2.new(1, 0, 0, 26); TBtn.BackgroundTransparency = 1
            TBtn.Text = "  > " .. tName; TBtn.Font = Enum.Font.Gotham; TBtn.TextSize = 12
            TBtn.TextColor3 = tState and Library.Accent or Color3.fromRGB(120, 120, 120)
            TBtn.TextXAlignment = 0

            TBtn.MouseButton1Click:Connect(function()
                tState = not tState
                TBtn.TextColor3 = tState and Library.Accent or Color3.fromRGB(120, 120, 120)
                cb(tState)
            end)
            UpdateSize()
            return ModFuncs
        end

        return ModFuncs
    end

    return Category
end

return Library