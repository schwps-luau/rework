local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer
local camera = workspace.CurrentCamera

local highlights = {}
local connections = {}
local cache = {}

local ESP = {
    Enabled = false,
    TeamCheck = false,
    VisibleCheck = false,
    WallCheck = false,
    ShowName = false,
    ShowHealth = false,
    ShowBox = false,
    ShowTracer = false,
    UseDisplayName = false,
    VisibleColor = Color3.fromRGB(255, 0, 0),
    InvisibleColor = Color3.fromRGB(128, 128, 128),
    HealthLowColor = Color3.fromRGB(255, 0, 0),
    HealthHighColor = Color3.fromRGB(0, 255, 0),
    HealthOutlineColor = Color3.fromRGB(0, 0, 0),
    NameColor = Color3.fromRGB(255, 255, 255),
    BoxColor = Color3.fromRGB(255, 255, 255),
    HighlightColor = Color3.fromRGB(255, 0, 0),
    TracerColor = Color3.fromRGB(255, 0, 0),
    TracerThickness = 1,
    BoxThickness = 1
}

local raycastParams = RaycastParams.new()
raycastParams.FilterType = Enum.RaycastFilterType.Blacklist

local function updateRaycastIgnore()
    local ignoreList = {localPlayer.Character, camera}
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= localPlayer and player.Character then
            table.insert(ignoreList, player.Character)
        end
    end
    raycastParams.FilterDescendantsInstances = ignoreList
end

local function isPartVisible(part)
    if not part or not part:IsA("BasePart") then return false end
    
    local cameraPosition = camera.CFrame.Position
    local direction = (part.Position - cameraPosition).Unit * 1000
    local rayResult = workspace:Raycast(cameraPosition, direction, raycastParams)
    
    if rayResult then
        local hitDistance = (rayResult.Position - cameraPosition).Magnitude
        local targetDistance = (part.Position - cameraPosition).Magnitude
        if hitDistance < targetDistance - 0.5 then
            return false
        end
    end
    
    return true
end

local function getCharacterType(character)
    if character:FindFirstChild("UpperTorso") and character:FindFirstChild("LowerTorso") then
        return "R15"
    end
    return "R6"
end

local function isPlayerOnScreen(player)
    local character = player.Character
    if not character then return false end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    if not rootPart then return false end
    
    local screenPos, onScreen = camera:WorldToViewportPoint(rootPart.Position)
    return onScreen
end

local function isPlayerVisible(player)
    local character = player.Character
    if not character then return false end
    
    local characterType = getCharacterType(character)
    local partsToCheck = {}
    
    if characterType == "R15" then
        partsToCheck = {
            "Head", "HumanoidRootPart", "UpperTorso", "LowerTorso",
            "LeftUpperArm", "LeftLowerArm", "LeftHand",
            "RightUpperArm", "RightLowerArm", "RightHand",
            "LeftUpperLeg", "LeftLowerLeg", "LeftFoot",
            "RightUpperLeg", "RightLowerLeg", "RightFoot"
        }
    else
        partsToCheck = {
            "Head", "HumanoidRootPart", "Torso",
            "Left Arm", "Right Arm", "Left Leg", "Right Leg"
        }
    end
    
    for _, partName in ipairs(partsToCheck) do
        local part = character:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            local screenPos, onScreen = camera:WorldToViewportPoint(part.Position)
            if onScreen and isPartVisible(part) then
                return true
            end
        end
    end
    
    return false
end

local function createDrawing(class, properties)
    local drawing = Drawing.new(class)
    for property, value in pairs(properties) do
        drawing[property] = value
    end
    return drawing
end

local function createEsp(player)
    local esp = {
        name = createDrawing("Text", {
            Color = ESP.NameColor,
            Outline = true,
            OutlineColor = Color3.fromRGB(0, 0, 0),
            Center = true,
            Size = 13,
            Visible = false
        }),
        healthOutline = createDrawing("Line", {
            Thickness = 2,
            Color = ESP.HealthOutlineColor,
            Visible = false
        }),
        health = createDrawing("Line", {
            Thickness = 2,
            Visible = false
        }),
        boxTop = createDrawing("Line", {
            Thickness = ESP.BoxThickness,
            Visible = false
        }),
        boxBottom = createDrawing("Line", {
            Thickness = ESP.BoxThickness,
            Visible = false
        }),
        boxLeft = createDrawing("Line", {
            Thickness = ESP.BoxThickness,
            Visible = false
        }),
        boxRight = createDrawing("Line", {
            Thickness = ESP.BoxThickness,
            Visible = false
        }),
        tracer = createDrawing("Line", {
            Thickness = ESP.TracerThickness,
            Color = ESP.TracerColor,
            Visible = false
        })
    }
    cache[player] = esp
end

local function isTeammate(player)
    if player.Team and localPlayer.Team then
        return player.Team == localPlayer.Team
    end
    return player.TeamColor == localPlayer.TeamColor
end

local function getColorByVisibility(colorIfVisible, colorIfInvisible, player)
    if ESP.VisibleCheck then
        return isPlayerVisible(player) and colorIfVisible or colorIfInvisible
    end
    return colorIfVisible
end

local function getHighlightColor(player)
    if ESP.VisibleCheck then
        return isPlayerVisible(player) and ESP.VisibleColor or ESP.InvisibleColor
    end
    return ESP.HighlightColor
end

local function getBoxColor(player)
    return getColorByVisibility(ESP.BoxColor, ESP.InvisibleColor, player)
end

local function getTracerColor(player)
    return getColorByVisibility(ESP.TracerColor, ESP.InvisibleColor, player)
end

local function getNameColor(player)
    return getColorByVisibility(ESP.NameColor, ESP.InvisibleColor, player)
end

local function getHealthColor(player, healthPercent)
    if ESP.VisibleCheck then
        return isPlayerVisible(player) and ESP.VisibleColor or ESP.InvisibleColor
    end
    return ESP.HealthLowColor:Lerp(ESP.HealthHighColor, healthPercent)
end

local function shouldShowPlayer(player)
    local character = player.Character
    if not character then return false end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    
    if ESP.TeamCheck and isTeammate(player) then
        return false
    end
    
    if ESP.WallCheck and not isPlayerVisible(player) then
        return false
    end
    
    return true
end

local function updateHighlight(player)
    local highlight = highlights[player]
    if not highlight then return end
    
    if not ESP.Enabled or not shouldShowPlayer(player) or ESP.ShowBox then
        highlight.Enabled = false
        return
    end
    
    highlight.Enabled = true
    local color = getHighlightColor(player)
    highlight.FillColor = color
    highlight.OutlineColor = color
end

local function updateName(player)
    local esp = cache[player]
    if not esp or not esp.name then return end
    
    if not ESP.Enabled or not ESP.ShowName or not shouldShowPlayer(player) then
        esp.name.Visible = false
        return
    end
    
    local character = player.Character
    if not character then
        esp.name.Visible = false
        return
    end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        esp.name.Visible = false
        return
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    if not rootPart then
        esp.name.Visible = false
        return
    end
    
    local hrp2D, onScreen = camera:WorldToViewportPoint(rootPart.Position)
    if not onScreen then
        esp.name.Visible = false
        return
    end
    
    esp.name.Visible = true
    esp.name.Color = getNameColor(player)
    esp.name.OutlineColor = Color3.fromRGB(0, 0, 0)
    
    if ESP.UseDisplayName then
        esp.name.Text = player.DisplayName or player.Name
    else
        esp.name.Text = player.Name
    end
    
    local charSize = (camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0)).Y - camera:WorldToViewportPoint(rootPart.Position + Vector3.new(0, 2.6, 0)).Y) / 2
    local boxPosition = Vector2.new(math.floor(hrp2D.X - charSize * 1.8 / 2), math.floor(hrp2D.Y - charSize * 1.6 / 2))
    esp.name.Position = Vector2.new(boxPosition.X + (charSize * 1.8 / 2), boxPosition.Y - 16)
end

local function updateHealth(player)
    local esp = cache[player]
    if not esp or not esp.health or not esp.healthOutline then return end
    
    if not ESP.Enabled or not ESP.ShowHealth or not shouldShowPlayer(player) then
        esp.health.Visible = false
        esp.healthOutline.Visible = false
        return
    end
    
    local character = player.Character
    if not character then
        esp.health.Visible = false
        esp.healthOutline.Visible = false
        return
    end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        esp.health.Visible = false
        esp.healthOutline.Visible = false
        return
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    if not rootPart then
        esp.health.Visible = false
        esp.healthOutline.Visible = false
        return
    end
    
    local hrp2D, onScreen = camera:WorldToViewportPoint(rootPart.Position)
    if not onScreen then
        esp.health.Visible = false
        esp.healthOutline.Visible = false
        return
    end
    
    local charSize = (camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0)).Y - camera:WorldToViewportPoint(rootPart.Position + Vector3.new(0, 2.6, 0)).Y) / 2
    local boxSize = Vector2.new(math.floor(charSize * 1.8), math.floor(charSize * 1.9))
    local boxPosition = Vector2.new(math.floor(hrp2D.X - charSize * 1.8 / 2), math.floor(hrp2D.Y - charSize * 1.6 / 2))
    
    local healthPercent = humanoid.Health / humanoid.MaxHealth
    
    esp.healthOutline.From = Vector2.new(boxPosition.X - 7, boxPosition.Y + boxSize.Y)
    esp.healthOutline.To = Vector2.new(esp.healthOutline.From.X, esp.healthOutline.From.Y - boxSize.Y)
    esp.healthOutline.Visible = true
    
    esp.health.From = Vector2.new(boxPosition.X - 6, boxPosition.Y + boxSize.Y)
    esp.health.To = Vector2.new(esp.health.From.X, esp.health.From.Y - healthPercent * boxSize.Y)
    esp.health.Color = getHealthColor(player, healthPercent)
    esp.health.Visible = true
end

local function updateBox(player)
    local esp = cache[player]
    if not esp or not esp.boxTop then return end
    
    if not ESP.Enabled or not ESP.ShowBox or not shouldShowPlayer(player) then
        esp.boxTop.Visible = false
        esp.boxBottom.Visible = false
        esp.boxLeft.Visible = false
        esp.boxRight.Visible = false
        return
    end
    
    local character = player.Character
    if not character then
        esp.boxTop.Visible = false
        esp.boxBottom.Visible = false
        esp.boxLeft.Visible = false
        esp.boxRight.Visible = false
        return
    end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        esp.boxTop.Visible = false
        esp.boxBottom.Visible = false
        esp.boxLeft.Visible = false
        esp.boxRight.Visible = false
        return
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    if not rootPart then
        esp.boxTop.Visible = false
        esp.boxBottom.Visible = false
        esp.boxLeft.Visible = false
        esp.boxRight.Visible = false
        return
    end
    
    local hrp2D, onScreen = camera:WorldToViewportPoint(rootPart.Position)
    if not onScreen then
        esp.boxTop.Visible = false
        esp.boxBottom.Visible = false
        esp.boxLeft.Visible = false
        esp.boxRight.Visible = false
        return
    end
    
    local charSize = (camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0)).Y - camera:WorldToViewportPoint(rootPart.Position + Vector3.new(0, 2.6, 0)).Y) / 2
    local boxSize = Vector2.new(math.floor(charSize * 1.8), math.floor(charSize * 1.9))
    local boxPosition = Vector2.new(math.floor(hrp2D.X - charSize * 1.8 / 2), math.floor(hrp2D.Y - charSize * 1.6 / 2))
    
    local boxColor = getBoxColor(player)
    
    esp.boxTop.From = boxPosition
    esp.boxTop.To = Vector2.new(boxPosition.X + boxSize.X, boxPosition.Y)
    esp.boxTop.Color = boxColor
    esp.boxTop.Visible = true
    
    esp.boxBottom.From = Vector2.new(boxPosition.X, boxPosition.Y + boxSize.Y)
    esp.boxBottom.To = Vector2.new(boxPosition.X + boxSize.X, boxPosition.Y + boxSize.Y)
    esp.boxBottom.Color = boxColor
    esp.boxBottom.Visible = true
    
    esp.boxLeft.From = boxPosition
    esp.boxLeft.To = Vector2.new(boxPosition.X, boxPosition.Y + boxSize.Y)
    esp.boxLeft.Color = boxColor
    esp.boxLeft.Visible = true
    
    esp.boxRight.From = Vector2.new(boxPosition.X + boxSize.X, boxPosition.Y)
    esp.boxRight.To = Vector2.new(boxPosition.X + boxSize.X, boxPosition.Y + boxSize.Y)
    esp.boxRight.Color = boxColor
    esp.boxRight.Visible = true
end

local function updateTracer(player)
    local esp = cache[player]
    if not esp or not esp.tracer then 
        return 
    end
    
    if not ESP.Enabled then
        esp.tracer.Visible = false
        return
    end
    
    if not ESP.ShowTracer then
        esp.tracer.Visible = false
        return
    end
    
    local character = player.Character
    if not character then
        esp.tracer.Visible = false
        return
    end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        esp.tracer.Visible = false
        return
    end
    
    if isTeammate(player) then
        esp.tracer.Visible = false
        return
    end
    
    if ESP.WallCheck then
        if not isPlayerVisible(player) or not isPlayerOnScreen(player) then
            esp.tracer.Visible = false
            return
        end
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    if not rootPart then
        esp.tracer.Visible = false
        return
    end
    
    local hrp2D, onScreen = camera:WorldToViewportPoint(rootPart.Position)
    
    if not onScreen then
        esp.tracer.Visible = false
        return
    end
    
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
    
    esp.tracer.From = screenCenter
    esp.tracer.To = Vector2.new(hrp2D.X, hrp2D.Y)
    esp.tracer.Color = getTracerColor(player)
    esp.tracer.Thickness = ESP.TracerThickness
    esp.tracer.Visible = true
end

local function setupPlayer(player)
    if player == localPlayer then return end
    
    createEsp(player)
    
    local function onCharacterAdded(character)
        task.wait(0.1)
        
        local highlight = Instance.new("Highlight")
        highlight.Name = "ESP_Highlight"
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0.5
        highlight.FillColor = ESP.HighlightColor
        highlight.Parent = character
        highlight.Enabled = false
        highlights[player] = highlight
    end
    
    if player.Character then
        onCharacterAdded(player.Character)
    end
    
    player.CharacterAdded:Connect(onCharacterAdded)
    
    player.CharacterRemoving:Connect(function()
        if highlights[player] then
            highlights[player].Enabled = false
        end
    end)
end

local function cleanupPlayer(player)
    if highlights[player] then
        highlights[player]:Destroy()
        highlights[player] = nil
    end
    
    if cache[player] then
        for _, drawing in pairs(cache[player]) do
            if drawing and drawing.Remove then
                drawing:Remove()
            end
        end
        cache[player] = nil
    end
end

function ESP:Init()
    updateRaycastIgnore()
    
    Players.PlayerAdded:Connect(function()
        task.wait(0.5)
        updateRaycastIgnore()
    end)
    
    Players.PlayerRemoving:Connect(function()
        task.wait(0.1)
        updateRaycastIgnore()
    end)
    
    localPlayer.CharacterAdded:Connect(function()
        task.wait(0.5)
        updateRaycastIgnore()
    end)
    
    for _, player in ipairs(Players:GetPlayers()) do
        task.spawn(setupPlayer, player)
    end
    
    connections.PlayerAdded = Players.PlayerAdded:Connect(function(player)
        task.spawn(setupPlayer, player)
    end)
    
    connections.PlayerRemoving = Players.PlayerRemoving:Connect(function(player)
        cleanupPlayer(player)
    end)
    
    connections.RenderStepped = RunService.RenderStepped:Connect(function()
        for player, _ in pairs(cache) do
            updateHighlight(player)
            updateName(player)
            updateHealth(player)
            updateBox(player)
            updateTracer(player)
        end
    end)
end

return ESP
