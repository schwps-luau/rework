local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer
local camera = workspace.CurrentCamera

local highlights = {}
local connections = {}
local cache = {}

local ESP = {
    Enabled = false,
    TeamCheck = false,
    VisibleCheck = false,
    WallCheck = false,
    ShowName = false,
    ShowHealth = false,
    ShowBox = false,
    ShowBoxFill = false,
    ShowTracer = false,
    UseDisplayName = false,
    VisibleColor = Color3.fromRGB(255, 0, 0),
    InvisibleColor = Color3.fromRGB(128, 128, 128),
    HealthLowColor = Color3.fromRGB(255, 0, 0),
    HealthHighColor = Color3.fromRGB(0, 255, 0),
    HealthOutlineColor = Color3.fromRGB(0, 0, 0),
    NameColor = Color3.fromRGB(255, 255, 255),
    BoxColor = Color3.fromRGB(255, 255, 255),
    HighlightColor = Color3.fromRGB(255, 0, 0),
    TracerColor = Color3.fromRGB(255, 0, 0),
    TracerThickness = 1,
    BoxThickness = 1,
    BoxFillTransparency = 0.3
}

local raycastParams = RaycastParams.new()
raycastParams.FilterType = Enum.RaycastFilterType.Blacklist

local function updateRaycastIgnore()
    local ignoreList = {localPlayer.Character, camera}
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= localPlayer and player.Character then
            table.insert(ignoreList, player.Character)
        end
    end
    raycastParams.FilterDescendantsInstances = ignoreList
end

local function isPartVisible(part)
    if not part or not part:IsA("BasePart") then return false end
    local cameraPosition = camera.CFrame.Position
    local direction = (part.Position - cameraPosition)
    local rayResult = workspace:Raycast(cameraPosition, direction, raycastParams)
    
    if rayResult then
        return rayResult.Instance:IsDescendantOf(part.Parent)
    end
    return true
end

local function isPlayerVisible(player)
    local character = player.Character
    if not character then return false end
    local head = character:FindFirstChild("Head")
    if not head then return false end
    
    local _, onScreen = camera:WorldToViewportPoint(head.Position)
    if not onScreen then return false end
    
    return isPartVisible(head)
end

local function isTeammate(player)
    if player.Team and localPlayer.Team then
        return player.Team == localPlayer.Team
    end
    return player.TeamColor == localPlayer.TeamColor
end

local function shouldShowPlayer(player)
    local character = player.Character
    if not character then return false end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    
    if ESP.TeamCheck and isTeammate(player) then
        return false
    end
    
    if ESP.WallCheck and not isPlayerVisible(player) then
        return false
    end
    
    return true
end

local function getColorByVisibility(defaultColor, player)
    if ESP.VisibleCheck then
        return isPlayerVisible(player) and ESP.VisibleColor or ESP.InvisibleColor
    end
    return defaultColor
end

local function createDrawing(class, properties)
    local drawing = Drawing.new(class)
    for property, value in pairs(properties) do
        drawing[property] = value
    end
    return drawing
end

local function createEsp(player)
    local esp = {
        name = createDrawing("Text", {Center = true, Size = 13, Outline = true, Visible = false}),
        healthOutline = createDrawing("Line", {Thickness = 2, Color = ESP.HealthOutlineColor, Visible = false}),
        health = createDrawing("Line", {Thickness = 2, Visible = false}),
        boxFill = createDrawing("Square", {Filled = true, Thickness = 0, Transparency = ESP.BoxFillTransparency, Visible = false}),
        boxTop = createDrawing("Line", {Thickness = ESP.BoxThickness, Visible = false}),
        boxBottom = createDrawing("Line", {Thickness = ESP.BoxThickness, Visible = false}),
        boxLeft = createDrawing("Line", {Thickness = ESP.BoxThickness, Visible = false}),
        boxRight = createDrawing("Line", {Thickness = ESP.BoxThickness, Visible = false}),
        tracer = createDrawing("Line", {Thickness = ESP.TracerThickness, Visible = false, Transparency = 0.6})
    }
    cache[player] = esp
end

local function updateHighlight(player)
    local highlight = highlights[player]
    if not highlight then return end
    
    if not ESP.Enabled or not shouldShowPlayer(player) or ESP.ShowBox then
        highlight.Enabled = false
        return
    end
    
    highlight.Enabled = true
    local color = getColorByVisibility(ESP.HighlightColor, player)
    highlight.FillColor = color
    highlight.OutlineColor = color
end

local function updateName(player)
    local esp = cache[player]
    if not esp then return end
    
    if not ESP.Enabled or not ESP.ShowName or not shouldShowPlayer(player) then
        esp.name.Visible = false
        return
    end
    
    local character = player.Character
    local rootPart = character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Head"))
    if not rootPart then esp.name.Visible = false return end
    
    local hrp2D, onScreen = camera:WorldToViewportPoint(rootPart.Position)
    if not onScreen then esp.name.Visible = false return end
    
    esp.name.Visible = true
    esp.name.Text = ESP.UseDisplayName and player.DisplayName or player.Name
    esp.name.Color = getColorByVisibility(ESP.NameColor, player)
    
    local charSize = (camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0)).Y - camera:WorldToViewportPoint(rootPart.Position + Vector3.new(0, 2.6, 0)).Y) / 2
    esp.name.Position = Vector2.new(hrp2D.X, hrp2D.Y - charSize - 15)
end

local function updateBox(player)
    local esp = cache[player]
    if not esp then return end
    
    local character = player.Character
    local rootPart = character and (character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso"))
    
    if not ESP.Enabled or not ESP.ShowBox or not shouldShowPlayer(player) or not rootPart then
        esp.boxTop.Visible = false
        esp.boxBottom.Visible = false
        esp.boxLeft.Visible = false
        esp.boxRight.Visible = false
        esp.boxFill.Visible = false
        return
    end
    
    local hrp2D, onScreen = camera:WorldToViewportPoint(rootPart.Position)
    
    if not onScreen then 
        esp.boxTop.Visible = false
        esp.boxBottom.Visible = false
        esp.boxLeft.Visible = false
        esp.boxRight.Visible = false
        esp.boxFill.Visible = false
        return 
    end
    
    local charSize = (camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0)).Y - camera:WorldToViewportPoint(rootPart.Position + Vector3.new(0, 2.6, 0)).Y) / 2
    local boxSize = Vector2.new(math.floor(charSize * 1.8), math.floor(charSize * 1.9))
    local boxPos = Vector2.new(math.floor(hrp2D.X - boxSize.X / 2), math.floor(hrp2D.Y - boxSize.Y / 2))
    local color = getColorByVisibility(ESP.BoxColor, player)
    
    esp.boxTop.From = boxPos
    esp.boxTop.To = boxPos + Vector2.new(boxSize.X, 0)
    esp.boxTop.Color = color
    esp.boxTop.Visible = true
    
    esp.boxBottom.From = boxPos + Vector2.new(0, boxSize.Y)
    esp.boxBottom.To = boxPos + boxSize
    esp.boxBottom.Color = color
    esp.boxBottom.Visible = true
    
    esp.boxLeft.From = boxPos
    esp.boxLeft.To = boxPos + Vector2.new(0, boxSize.Y)
    esp.boxLeft.Color = color
    esp.boxLeft.Visible = true
    
    esp.boxRight.From = boxPos + Vector2.new(boxSize.X, 0)
    esp.boxRight.To = boxPos + boxSize
    esp.boxRight.Color = color
    esp.boxRight.Visible = true
    
    if ESP.ShowBoxFill then
        esp.boxFill.Position = boxPos
        esp.boxFill.Size = boxSize
        esp.boxFill.Color = color
        esp.boxFill.Visible = true
    else
        esp.boxFill.Visible = false
    end
end

local function updateTracer(player)
    local esp = cache[player]
    if not esp then return end
    
    if not ESP.Enabled or not ESP.ShowTracer or not shouldShowPlayer(player) then
        esp.tracer.Visible = false
        return
    end
    
    local rootPart = player.Character and (player.Character:FindFirstChild("HumanoidRootPart") or player.Character:FindFirstChild("Torso"))
    if not rootPart then esp.tracer.Visible = false return end
    
    local hrp2D, onScreen = camera:WorldToViewportPoint(rootPart.Position)
    if not onScreen then esp.tracer.Visible = false return end
    
    esp.tracer.Visible = true
    esp.tracer.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
    esp.tracer.To = Vector2.new(hrp2D.X, hrp2D.Y)
    esp.tracer.Color = getColorByVisibility(ESP.TracerColor, player)
end

local function updateHealth(player)
    local esp = cache[player]
    if not esp then return end
    local character = player.Character
    local humanoid = character and character:FindFirstChild("Humanoid")
    
    if not ESP.Enabled or not ESP.ShowHealth or not shouldShowPlayer(player) or not humanoid then
        esp.health.Visible = false; esp.healthOutline.Visible = false
        return
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
    local hrp2D, onScreen = camera:WorldToViewportPoint(rootPart.Position)
    if not onScreen then esp.health.Visible = false return end
    
    local charSize = (camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0)).Y - camera:WorldToViewportPoint(rootPart.Position + Vector3.new(0, 2.6, 0)).Y) / 2
    local boxSize = Vector2.new(math.floor(charSize * 1.8), math.floor(charSize * 1.9))
    local boxPos = Vector2.new(math.floor(hrp2D.X - boxSize.X / 2), math.floor(hrp2D.Y - boxSize.Y / 2))
    
    local healthPct = humanoid.Health / humanoid.MaxHealth
    local color = ESP.HealthLowColor:Lerp(ESP.HealthHighColor, healthPct)
    if ESP.VisibleCheck then color = getColorByVisibility(color, player) end
    
    esp.healthOutline.From = Vector2.new(boxPos.X - 5, boxPos.Y + boxSize.Y)
    esp.healthOutline.To = Vector2.new(boxPos.X - 5, boxPos.Y)
    esp.healthOutline.Visible = true
    
    esp.health.From = Vector2.new(boxPos.X - 5, boxPos.Y + boxSize.Y)
    esp.health.To = Vector2.new(boxPos.X - 5, boxPos.Y + boxSize.Y - (healthPct * boxSize.Y))
    esp.health.Color = color
    esp.health.Visible = true
end

local function setupPlayer(player)
    if player == localPlayer then return end
    createEsp(player)
    
    local function onChar(char)
        task.wait(0.1)
        local h = Instance.new("Highlight")
        h.FillTransparency = 0.5
        h.OutlineTransparency = 0.2
        h.Parent = char
        highlights[player] = h
    end
    
    player.CharacterAdded:Connect(onChar)
    if player.Character then onChar(player.Character) end
end

local function cleanupPlayer(player)
    if highlights[player] then highlights[player]:Destroy(); highlights[player] = nil end
    if cache[player] then
        for _, v in pairs(cache[player]) do v:Remove() end
        cache[player] = nil
    end
end

function ESP:Init()
    updateRaycastIgnore()
    Players.PlayerAdded:Connect(setupPlayer)
    Players.PlayerRemoving:Connect(cleanupPlayer)
    for _, p in ipairs(Players:GetPlayers()) do setupPlayer(p) end
    
    RunService.RenderStepped:Connect(function()
        updateRaycastIgnore()
        for p, _ in pairs(cache) do
            updateHighlight(p)
            updateName(p)
            updateHealth(p)
            updateBox(p)
            updateTracer(p)
        end
    end)
end

return ESP
