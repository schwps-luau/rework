local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local localPlayer = Players.LocalPlayer
local camera = workspace.CurrentCamera

local highlights = {}
local connections = {}
local cache = {}

local ESP = {
    Enabled = false,
    TeamCheck = false,
    VisibleCheck = false,
    WallCheck = false,
    ShowName = false,
    ShowHealth = false,
    ShowBox = false,
    ShowTracer = false,
    UseDisplayName = false,
    VisibleColor = Color3.fromRGB(255, 0, 0),
    InvisibleColor = Color3.fromRGB(128, 128, 128),
    TeammateColor = Color3.fromRGB(0, 255, 0),
    HealthLowColor = Color3.fromRGB(255, 0, 0),
    HealthHighColor = Color3.fromRGB(0, 255, 0),
    HealthOutlineColor = Color3.fromRGB(0, 0, 0),
    NameColor = Color3.fromRGB(255, 255, 255),
    BoxColor = Color3.fromRGB(255, 255, 255),
    TracerColor = Color3.fromRGB(255, 255, 255)
}

local raycastParams = RaycastParams.new()
raycastParams.FilterType = Enum.RaycastFilterType.Blacklist

local visibilityCache = {}
local lastCacheUpdate = 0

local function updateRaycastIgnore()
    local ignoreList = {localPlayer.Character, camera}
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= localPlayer and player.Character then
            table.insert(ignoreList, player.Character)
        end
    end
    raycastParams.FilterDescendantsInstances = ignoreList
end

local function isPartVisible(part)
    if not part or not part:IsA("BasePart") then return false end
    
    local cameraPosition = camera.CFrame.Position
    local direction = (part.Position - cameraPosition).Unit * 1000
    local rayResult = workspace:Raycast(cameraPosition, direction, raycastParams)
    
    if rayResult then
        local hitDistance = (rayResult.Position - cameraPosition).Magnitude
        local targetDistance = (part.Position - cameraPosition).Magnitude
        if hitDistance < targetDistance - 0.5 then
            return false
        end
    end
    
    return true
end

local function isPlayerVisible(player)
    local character = player.Character
    if not character then return false end
    
    local anyOnScreen = false
    for _, part in ipairs(character:GetChildren()) do
        if part:IsA("BasePart") then
            local _, onScreen = camera:WorldToViewportPoint(part.Position)
            if onScreen then
                anyOnScreen = true
                break
            end
        end
    end
    
    if not anyOnScreen then return false end
    
    local partsToCheck = {"Head", "HumanoidRootPart", "UpperTorso", "LowerTorso", "Torso"}
    for _, partName in ipairs(partsToCheck) do
        local part = character:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            if isPartVisible(part) then
                return true
            end
        end
    end
    
    return false
end

local function updateVisibilityCache()
    local currentTime = tick()
    if currentTime - lastCacheUpdate < 0.1 then
        return
    end
    lastCacheUpdate = currentTime
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= localPlayer then
            visibilityCache[player] = isPlayerVisible(player)
        end
    end
end

local function createDrawing(class, properties)
    local drawing = Drawing.new(class)
    for property, value in pairs(properties) do
        drawing[property] = value
    end
    return drawing
end

local function createEsp(player)
    local esp = {
        name = createDrawing("Text", {
            Color = ESP.NameColor,
            Outline = true,
            OutlineColor = Color3.fromRGB(0, 0, 0),
            Center = true,
            Size = 13,
            Visible = false
        }),
        healthOutline = createDrawing("Line", {
            Thickness = 2,
            Color = ESP.HealthOutlineColor,
            Visible = false
        }),
        health = createDrawing("Line", {
            Thickness = 2,
            Visible = false
        }),
        box = {
            top = createDrawing("Line", {Thickness = 1, Visible = false}),
            bottom = createDrawing("Line", {Thickness = 1, Visible = false}),
            left = createDrawing("Line", {Thickness = 1, Visible = false}),
            right = createDrawing("Line", {Thickness = 1, Visible = false})
        },
        tracer = createDrawing("Line", {Thickness = 1, Visible = false})
    }
    cache[player] = esp
end

local function getColorForPlayer(player)
    if ESP.TeamCheck and player.Team and localPlayer.Team and player.Team == localPlayer.Team then
        return ESP.TeammateColor
    end
    
    if ESP.VisibleCheck and visibilityCache[player] == false then
        return ESP.InvisibleColor
    end
    
    return ESP.VisibleColor
end

local function shouldRenderForPlayer(player)
    local character = player.Character
    if not character then return false end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return false end
    
    if ESP.TeamCheck and player.Team and localPlayer.Team and player.Team == localPlayer.Team then
        return false
    end
    
    if ESP.WallCheck and not visibilityCache[player] then
        return false
    end
    
    return true
end

local function getPlayerBox(player)
    local character = player.Character
    if not character then return nil end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    if not rootPart then return nil end
    
    local head = character:FindFirstChild("Head")
    if not head then return nil end
    
    local hrp2D, onScreen = camera:WorldToViewportPoint(rootPart.Position)
    local head2D, headOnScreen = camera:WorldToViewportPoint(head.Position)
    
    if not onScreen and not headOnScreen then return nil end
    
    local headY = head2D.Y
    local footY = hrp2D.Y + (hrp2D.Y - head2D.Y) * 0.8
    
    local width = (headY - footY) * 0.5
    local left = hrp2D.X - width / 2
    local right = hrp2D.X + width / 2
    
    return {
        top = headY,
        bottom = footY,
        left = left,
        right = right,
        centerX = hrp2D.X,
        centerY = (headY + footY) / 2
    }
end

local function updateHighlight(player)
    local highlight = highlights[player]
    if not highlight then return end
    
    if not ESP.Enabled or not shouldRenderForPlayer(player) then
        highlight.Enabled = false
        return
    end
    
    highlight.Enabled = true
    highlight.FillColor = getColorForPlayer(player)
end

local function updateName(player)
    local esp = cache[player]
    if not esp or not esp.name then return end
    
    if not ESP.Enabled or not ESP.ShowName or not shouldRenderForPlayer(player) then
        esp.name.Visible = false
        return
    end
    
    local box = getPlayerBox(player)
    if not box then
        esp.name.Visible = false
        return
    end
    
    local centerX = box.centerX
    local topY = box.top
    
    if topY < 5 or topY > camera.ViewportSize.Y - 5 or centerX < 5 or centerX > camera.ViewportSize.X - 5 then
        esp.name.Visible = false
        return
    end
    
    esp.name.Visible = true
    esp.name.Color = ESP.NameColor
    esp.name.OutlineColor = Color3.fromRGB(0, 0, 0)
    
    if ESP.UseDisplayName then
        esp.name.Text = player.DisplayName or player.Name
    else
        esp.name.Text = player.Name
    end
    
    local nameX = math.clamp(centerX, 5, camera.ViewportSize.X - 5)
    local nameY = math.clamp(topY - 16, 5, camera.ViewportSize.Y - 5)
    esp.name.Position = Vector2.new(nameX, nameY)
end

local function updateHealth(player)
    local esp = cache[player]
    if not esp or not esp.health or not esp.healthOutline then return end
    
    if not ESP.Enabled or not ESP.ShowHealth or not shouldRenderForPlayer(player) then
        esp.health.Visible = false
        esp.healthOutline.Visible = false
        return
    end
    
    local box = getPlayerBox(player)
    if not box then
        esp.health.Visible = false
        esp.healthOutline.Visible = false
        return
    end
    
    local character = player.Character
    if not character then return end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return end
    
    local healthPercent = humanoid.Health / humanoid.MaxHealth
    local boxHeight = box.bottom - box.top
    
    local healthBarX = box.left - 7
    local healthBarTop = box.top
    local healthBarBottom = box.bottom
    
    esp.healthOutline.From = Vector2.new(healthBarX, healthBarBottom)
    esp.healthOutline.To = Vector2.new(healthBarX, healthBarTop)
    esp.healthOutline.Visible = true
    
    local healthBarHeight = boxHeight * healthPercent
    esp.health.From = Vector2.new(healthBarX - 1, healthBarBottom)
    esp.health.To = Vector2.new(healthBarX - 1, healthBarBottom - healthBarHeight)
    esp.health.Color = ESP.HealthLowColor:Lerp(ESP.HealthHighColor, healthPercent)
    esp.health.Visible = true
end

local function updateBox(player)
    local esp = cache[player]
    if not esp or not esp.box then return end
    
    if not ESP.Enabled or not ESP.ShowBox or not shouldRenderForPlayer(player) then
        for _, line in pairs(esp.box) do
            line.Visible = false
        end
        return
    end
    
    local box = getPlayerBox(player)
    if not box then
        for _, line in pairs(esp.box) do
            line.Visible = false
        end
        return
    end
    
    local left = box.left
    local right = box.right
    local top = box.top
    local bottom = box.bottom
    
    local color = ESP.BoxColor
    
    esp.box.top.From = Vector2.new(left, top)
    esp.box.top.To = Vector2.new(right, top)
    esp.box.top.Color = color
    esp.box.top.Visible = true
    
    esp.box.bottom.From = Vector2.new(left, bottom)
    esp.box.bottom.To = Vector2.new(right, bottom)
    esp.box.bottom.Color = color
    esp.box.bottom.Visible = true
    
    esp.box.left.From = Vector2.new(left, top)
    esp.box.left.To = Vector2.new(left, bottom)
    esp.box.left.Color = color
    esp.box.left.Visible = true
    
    esp.box.right.From = Vector2.new(right, top)
    esp.box.right.To = Vector2.new(right, bottom)
    esp.box.right.Color = color
    esp.box.right.Visible = true
end

local function updateTracer(player)
    local esp = cache[player]
    if not esp or not esp.tracer then return end
    
    if not ESP.Enabled or not ESP.ShowTracer or not shouldRenderForPlayer(player) then
        esp.tracer.Visible = false
        return
    end
    
    local character = player.Character
    if not character then
        esp.tracer.Visible = false
        return
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
    if not rootPart then
        esp.tracer.Visible = false
        return
    end
    
    local root2D, onScreen = camera:WorldToViewportPoint(rootPart.Position)
    if not onScreen and root2D.Z < 0 then
        esp.tracer.Visible = false
        return
    end
    
    local screenCenter = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
    local playerPos = Vector2.new(root2D.X, root2D.Y)
    
    if playerPos.Y < 5 or playerPos.Y > camera.ViewportSize.Y - 5 then
        esp.tracer.Visible = false
        return
    end
    
    esp.tracer.From = screenCenter
    esp.tracer.To = playerPos
    esp.tracer.Color = ESP.TracerColor
    esp.tracer.Visible = true
end

local function setupPlayer(player)
    if player == localPlayer then return end
    
    createEsp(player)
    
    local function onCharacterAdded(character)
        task.wait(0.1)
        
        local highlight = Instance.new("Highlight")
        highlight.Name = "ESP_Highlight"
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 0.5
        highlight.FillColor = ESP.VisibleColor
        highlight.Parent = character
        highlight.Enabled = false
        highlights[player] = highlight
    end
    
    if player.Character then
        onCharacterAdded(player.Character)
    end
    
    player.CharacterAdded:Connect(onCharacterAdded)
    
    player.CharacterRemoving:Connect(function()
        if highlights[player] then
            highlights[player].Enabled = false
        end
    end)
end

local function cleanupPlayer(player)
    if highlights[player] then
        highlights[player]:Destroy()
        highlights[player] = nil
    end
    
    if cache[player] then
        if cache[player].name then
            cache[player].name:Remove()
        end
        if cache[player].health then
            cache[player].health:Remove()
        end
        if cache[player].healthOutline then
            cache[player].healthOutline:Remove()
        end
        if cache[player].tracer then
            cache[player].tracer:Remove()
        end
        for _, line in pairs(cache[player].box) do
            if line then
                line:Remove()
            end
        end
        cache[player] = nil
    end
end

function ESP:Init()
    updateRaycastIgnore()
    
    Players.PlayerAdded:Connect(function()
        task.wait(0.5)
        updateRaycastIgnore()
    end)
    
    Players.PlayerRemoving:Connect(function()
        task.wait(0.1)
        updateRaycastIgnore()
    end)
    
    localPlayer.CharacterAdded:Connect(function()
        task.wait(0.5)
        updateRaycastIgnore()
    end)
    
    for _, player in ipairs(Players:GetPlayers()) do
        task.spawn(setupPlayer, player)
    end
    
    connections.PlayerAdded = Players.PlayerAdded:Connect(function(player)
        task.spawn(setupPlayer, player)
    end)
    
    connections.PlayerRemoving = Players.PlayerRemoving:Connect(function(player)
        cleanupPlayer(player)
    end)
    
    connections.RenderStepped = RunService.RenderStepped:Connect(function()
        if ESP.Enabled then
            updateVisibilityCache()
            
            for player, _ in pairs(highlights) do
                updateHighlight(player)
                updateName(player)
                updateHealth(player)
                updateBox(player)
                updateTracer(player)
            end
        else
            for player, esp in pairs(cache) do
                if esp then
                    if esp.name then esp.name.Visible = false end
                    if esp.health then esp.health.Visible = false end
                    if esp.healthOutline then esp.healthOutline.Visible = false end
                    if esp.tracer then esp.tracer.Visible = false end
                    for _, line in pairs(esp.box) do
                        if line then line.Visible = false end
                    end
                end
            end
            for _, highlight in pairs(highlights) do
                if highlight then highlight.Enabled = false end
            end
        end
    end)
end

