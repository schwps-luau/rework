                            })

                            if multichoice then
                                local checkmark = utility.create("TextLabel", {
                                    ZIndex = 4,
                                    Size = UDim2.new(0, 16, 1, 0),
                                    Position = UDim2.new(0, 0, 0, 0),
                                    BackgroundTransparency = 1,
                                    Text = "",
                                    TextColor3 = selectedTheme.text,
                                    TextSize = 12,
                                    Font = Enum.Font.Gotham,
                                    Parent = itemButton
                                })
                                
                                local itemText = utility.create("TextLabel", {
                                    ZIndex = 4,
                                    Size = UDim2.new(1, -20, 1, 0),
                                    Position = UDim2.new(0, 20, 0, 0),
                                    BackgroundTransparency = 1,
                                    Text = item,
                                    TextColor3 = selectedTheme.text,
                                    TextSize = 12,
                                    Font = Enum.Font.Gotham,
                                    TextXAlignment = Enum.TextXAlignment.Left,
                                    Parent = itemButton
                                })
                                
                                itemButton.MouseButton1Click:Connect(function()
                                    if table.find(selectedItems, item) then
                                        for j, v in ipairs(selectedItems) do
                                            if v == item then
                                                table.remove(selectedItems, j)
                                                break
                                            end
                                        end
                                        checkmark.Text = ""
                                    else
                                        table.insert(selectedItems, item)
                                        checkmark.Text = "✓"
                                    end
                                    if flag then
                                        library.flags[flag] = selectedItems
                                    end
                                    callback(selectedItems)
                                    dropdownButton.Text = table.concat(selectedItems, ", ")
                                end)
                            else
                                local itemText = utility.create("TextLabel", {
                                    ZIndex = 4,
                                    Size = UDim2.new(1, 0, 1, 0),
                                    BackgroundTransparency = 1,
                                    Text = item,
                                    TextColor3 = selectedTheme.text,
                                    TextSize = 12,
                                    Font = Enum.Font.Gotham,
                                    Parent = itemButton
                                })
                                
                                itemButton.MouseButton1Click:Connect(function()
                                    selected = item
                                    dropdownButton.Text = selected
                                    if flag then
                                        library.flags[flag] = selected
                                    end
                                    callback(selected)
                                    dropdownMenu.Visible = false
                                    open = false
                                    arrow.Text = "▼"
                                end)
                            end

                            items[i] = itemButton
                        end
                        dropdownMenu.Size = UDim2.new(1, 0, 0, #content * 16)
                    end

                    if flag then
                        if multichoice then
                            flags.multidropdowns[flag] = function(tbl)
                                dropdownTypes:SetValue(tbl)
                            end
                        else
                            flags.dropdowns[flag] = function(str)
                                dropdownTypes:SetValue(str)
                            end
                        end
                    end

                    return dropdownTypes
                end

                -- KEYBIND
                function sectionTypes:Keybind(opts)
                    local options = utility.table(opts)
                    local name = options.name or "Keybind"
                    local default = options.default or Enum.KeyCode.None
                    local flag = options.flag
                    local callback = options.callback or function() end

                    local selected = default
                    local listening = false

                    if flag then
                        library.flags[flag] = selected
                    end
                    callback(selected)

                    local keybindHolder = utility.create("Frame", {
                        Size = UDim2.new(1, 0, 0, 35),
                        BackgroundTransparency = 1,
                        Parent = sectionContent
                    })

                    local keybindButton = utility.create("TextButton", {
                        Size = UDim2.new(1, 0, 0, 16),
                        Position = UDim2.new(0, 0, 1, -16),
                        BackgroundTransparency = 1,
                        Text = selected.Name,
                        TextColor3 = selectedTheme.text,
                        TextSize = 12,
                        Font = Enum.Font.Gotham,
                        Parent = keybindHolder
                    })

                    local bg = utility.create("Frame", {
                        ZIndex = 3,
                        Size = UDim2.new(1, 0, 1, 0),
                        BorderColor3 = selectedTheme.background,
                        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                        Parent = keybindButton
                    })

                    utility.create("UIGradient", {
                        Rotation = 90,
                        Color = ColorSequence.new(selectedTheme.gradient1, selectedTheme.gradient2),
                        Parent = bg
                    })

                    local title = utility.create("TextLabel", {
                        ZIndex = 3,
                        Size = UDim2.new(0, 0, 0, 16),
                        BackgroundTransparency = 1,
                        Text = name,
                        TextColor3 = selectedTheme.text,
                        TextSize = 13,
                        Font = Enum.Font.Gotham,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Parent = keybindHolder
                    })

                    local function startListening()
                        listening = true
                        keybindButton.Text = "..."
                    end

                    local function stopListening()
                        listening = false
                        keybindButton.Text = selected.Name
                    end

                    keybindButton.MouseButton1Click:Connect(function()
                        if listening then
                            stopListening()
                        else
                            startListening()
                        end
                    end)

                    local function onInputBegan(input)
                        if listening then
                            if input.UserInputType == Enum.UserInputType.Keyboard then
                                selected = input.KeyCode
                                keybindButton.Text = selected.Name
                                if flag then
                                    library.flags[flag] = selected
                                end
                                callback(selected)
                                stopListening()
                            elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.MouseButton3 then
                                selected = input.UserInputType
                                keybindButton.Text = selected.Name
                                if flag then
                                    library.flags[flag] = selected
                                end
                                callback(selected)
                                stopListening()
                            end
                        end
                    end

                    inputService.InputBegan:Connect(onInputBegan)

                    local keybindTypes = utility.table()

                    function keybindTypes:Show()
                        keybindHolder.Visible = true
                    end

                    function keybindTypes:Hide()
                        keybindHolder.Visible = false
                    end

                    function keybindTypes:SetName(str)
                        title.Text = str
                    end

                    function keybindTypes:SetKey(key)
                        selected = key
                        keybindButton.Text = selected.Name
                        if flag then
                            library.flags[flag] = selected
                        end
                        callback(selected)
                    end

                    if flag then
                        flags.keybinds[flag] = function(key)
                            keybindTypes:SetKey(key)
                        end
                    end

                    return keybindTypes
                end

                -- COLOR PICKER
                function sectionTypes:ColorPicker(opts)
                    local options = utility.table(opts)
                    local name = options.name or "Color Picker"
                    local default = options.default or Color3.fromRGB(255, 255, 255)
                    local flag = options.flag
                    local callback = options.callback or function() end

                    local selected = default
                    local open = false

                    if flag then
                        library.flags[flag] = selected
                    end
                    callback(selected)

                    local colorHolder = utility.create("Frame", {
                        Size = UDim2.new(1, 0, 0, 35),
                        BackgroundTransparency = 1,
                        Parent = sectionContent
                    })

                    local colorButton = utility.create("TextButton", {
                        Size = UDim2.new(1, 0, 0, 16),
                        Position = UDim2.new(0, 0, 1, -16),
                        BackgroundTransparency = 1,
                        Text = "",
                        Parent = colorHolder
                    })

                    local bg = utility.create("Frame", {
                        ZIndex = 3,
                        Size = UDim2.new(1, 0, 1, 0),
                        BorderColor3 = selectedTheme.background,
                        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                        Parent = colorButton
                    })

                    utility.create("UIGradient", {
                        Rotation = 90,
                        Color = ColorSequence.new(selectedTheme.gradient1, selectedTheme.gradient2),
                        Parent = bg
                    })

                    local colorPreview = utility.create("Frame", {
                        ZIndex = 4,
                        Size = UDim2.new(0, 20, 1, -4),
                        Position = UDim2.new(0, 4, 0, 2),
                        BorderSizePixel = 0,
                        BackgroundColor3 = selected,
                        Parent = colorButton
                    })

                    local colorText = utility.create("TextLabel", {
                        ZIndex = 4,
                        Size = UDim2.new(1, -28, 1, 0),
                        Position = UDim2.new(0, 28, 0, 0),
                        BackgroundTransparency = 1,
                        Text = name,
                        TextColor3 = selectedTheme.text,
                        TextSize = 12,
                        Font = Enum.Font.Gotham,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        Parent = colorButton
                    })

                    local pickerFrame = utility.create("Frame", {
                        Size = UDim2.new(1, 0, 0, 150),
                        Position = UDim2.new(0, 0, 1, 2),
                        BackgroundColor3 = selectedTheme.picker,
                        BorderSizePixel = 0,
                        Visible = false,
                        Parent = colorHolder
                    })

                    local saturationValue = utility.create("ImageButton", {
                        Size = UDim2.new(1, -4, 1, -4),
                        Position = UDim2.new(0, 2, 0, 2),
                        BackgroundColor3 = Color3.fromRGB(255, 0, 0),
                        Image = "rbxassetid://1798450176",
                        Parent = pickerFrame
                    })

                    local hue = utility.create("ImageButton", {
                        Size = UDim2.new(0, 20, 1, -4),
                        Position = UDim2.new(1, -24, 0, 2),
                        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                        Image = "rbxassetid://1798455266",
                        Parent = pickerFrame
                    })

                    local pickerCursor = utility.create("Frame", {
                        ZIndex = 5,
                        Size = UDim2.new(0, 4, 0, 4),
                        Position = UDim2.new(1, -2, 1, -2),
                        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                        BorderSizePixel = 1,
                        BorderColor3 = Color3.fromRGB(0, 0, 0),
                        Visible = false,
                        Parent = saturationValue
                    })

                    local hueCursor = utility.create("Frame", {
                        ZIndex = 5,
                        Size = UDim2.new(0, 20, 0, 4),
                        Position = UDim2.new(0, 0, 0, 0),
                        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                        BorderSizePixel = 1,
                        BorderColor3 = Color3.fromRGB(0, 0, 0),
                        Visible = false,
                        Parent = hue
                    })

                    local r, g, b = utility.get_rgb(selected)
                    local hexBox = utility.create("TextBox", {
                        Size = UDim2.new(1, -30, 0, 20),
                        Position = UDim2.new(0, 2, 1, -22),
                        BackgroundColor3 = selectedTheme.secondary,
                        TextColor3 = selectedTheme.text,
                        Text = string.format("#%02X%02X%02X", r, g, b),
                        TextSize = 10,
                        Font = Enum.Font.Gotham,
                        Parent = pickerFrame
                    })

                    local function updateColor(hueVal, satVal, val)
                        local color = Color3.fromHSV(hueVal, satVal, val)
                        saturationValue.BackgroundColor3 = Color3.fromHSV(hueVal, 1, 1)
                        colorPreview.BackgroundColor3 = color
                        local r, g, b = utility.get_rgb(color)
                        hexBox.Text = string.format("#%02X%02X%02X", r, g, b)
                        selected = color
                        if flag then
                            library.flags[flag] = selected
                        end
                        callback(selected)
                    end

                    local hueVal = 0
                    local satVal = 1
                    local val = 1

                    local function updateFromCursor()
                        local satSize = saturationValue.AbsoluteSize
                        local hueSize = hue.AbsoluteSize
                        local cursorPos = pickerCursor.Position
                        local hueCursorPos = hueCursor.Position
                        
                        satVal = math.clamp(cursorPos.X.Offset / satSize.X, 0, 1)
                        val = 1 - math.clamp(cursorPos.Y.Offset / satSize.Y, 0, 1)
                        hueVal = math.clamp(hueCursorPos.Y.Offset / hueSize.Y, 0, 1)
                        
                        updateColor(hueVal, satVal, val)
                    end

                    local function onSatInput(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            local pos = input.Position
                            local size = saturationValue.AbsoluteSize
                            local relative = pos - saturationValue.AbsolutePosition
                            local x = math.clamp(relative.X / size.X, 0, 1)
                            local y = math.clamp(relative.Y / size.Y, 0, 1)
                            pickerCursor.Position = UDim2.new(x, -2, y, -2)
                            pickerCursor.Visible = true
                            updateFromCursor()
                        end
                    end

                    local function onHueInput(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                            local pos = input.Position
                            local size = hue.AbsoluteSize
                            local relative = pos - hue.AbsolutePosition
                            local y = math.clamp(relative.Y / size.Y, 0, 1)
                            hueCursor.Position = UDim2.new(0, 0, y, -2)
                            hueCursor.Visible = true
                            updateFromCursor()
                        end
                    end

                    saturationValue.InputBegan:Connect(onSatInput)
                    saturationValue.InputChanged:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseMovement then
                            onSatInput(input)
                        end
                    end)

                    hue.InputBegan:Connect(onHueInput)
                    hue.InputChanged:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseMovement then
                            onHueInput(input)
                        end
                    end)

                    hexBox.FocusLost:Connect(function()
                        local hex = hexBox.Text
                        if hex:match("^#%x%x%x%x%x%x$") then
                            selected = utility.hex_to_rgb(hex)
                            colorPreview.BackgroundColor3 = selected
                            if flag then
                                library.flags[flag] = selected
                            end
                            callback(selected)
                            local r, g, b = utility.get_rgb(selected)
                            local h, s, v = Color3.toHSV(selected)
                            satVal = s
                            val = v
                            hueVal = h
                            local satSize = saturationValue.AbsoluteSize
                            local hueSize = hue.AbsoluteSize
                            pickerCursor.Position = UDim2.new(s, -2, 1 - v, -2)
                            hueCursor.Position = UDim2.new(0, 0, h, -2)
                            saturationValue.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                        end
                    end)

                    local function togglePicker()
                        open = not open
                        pickerFrame.Visible = open
                        if open then
                            local h, s, v = Color3.toHSV(selected)
                            satVal = s
                            val = v
                            hueVal = h
                            local satSize = saturationValue.AbsoluteSize
                            local hueSize = hue.AbsoluteSize
                            pickerCursor.Position = UDim2.new(s, -2, 1 - v, -2)
                            hueCursor.Position = UDim2.new(0, 0, h, -2)
                            pickerCursor.Visible = true
                            hueCursor.Visible = true
                            saturationValue.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                        end
                    end

                    colorButton.MouseButton1Click:Connect(togglePicker)

                    local colorPickerTypes = utility.table()

                    function colorPickerTypes:Show()
                        colorHolder.Visible = true
                    end

                    function colorPickerTypes:Hide()
                        colorHolder.Visible = false
                    end

                    function colorPickerTypes:SetName(str)
                        colorText.Text = str
                    end

                    function colorPickerTypes:SetColor(color)
                        selected = color
                        colorPreview.BackgroundColor3 = selected
                        local r, g, b = utility.get_rgb(selected)
                        hexBox.Text = string.format("#%02X%02X%02X", r, g, b)
                        if flag then
                            library.flags[flag] = selected
                        end
                        callback(selected)
                    end

                    if flag then
                        flags.colorpickers[flag] = function(color)
                            colorPickerTypes:SetColor(color)
                        end
                    end

                    return colorPickerTypes
                end

                return sectionTypes
            end

            return tabTypes
        end

        return windowTypes
    end

    return library
end
