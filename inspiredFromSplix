-- Toggle
function AetherUI:Toggle(parent, text, default, callback)
    local container = create(parent, "Frame", {
        Size = UDim2.new(1, 0, 0, 30),
        BackgroundTransparency = 1,
    })
    
    local label = create(container, "TextLabel", {
        Size = UDim2.new(1, -50, 1, 0),
        Position = UDim2.new(0, 5, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Colors.Text,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local toggleFrame = create(container, "Frame", {
        Size = UDim2.new(0, 40, 0, 20),
        Position = UDim2.new(1, -45, 0.5, -10),
        BackgroundColor3 = Colors.Border,
        BorderSizePixel = 0,
    })
    
    addCorner(toggleFrame, 2)
    
    local toggleIndicator = create(toggleFrame, "Frame", {
        Size = UDim2.new(0, 18, 0, 16),
        Position = UDim2.new(0, 2, 0.5, -8),
        BackgroundColor3 = Colors.Text,
        BorderSizePixel = 0,
    })
    
    addCorner(toggleIndicator, 2)
    
    local state = default or false
    
    if state then
        toggleFrame.BackgroundColor3 = Colors.Accent
        toggleIndicator.Position = UDim2.new(1, -20, 0.5, -8)
    end
    
    local button = create(container, "TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        BorderSizePixel = 0,
    })
    
    button.MouseButton1Click:Connect(function()
        state = not state
        if state then
            TweenService:Create(toggleFrame, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Accent}):Play()
            TweenService:Create(toggleIndicator, TweenInfo.new(0.2), {Position = UDim2.new(1, -20, 0.5, -8)}):Play()
        else
            TweenService:Create(toggleFrame, TweenInfo.new(0.2), {BackgroundColor3 = Colors.Border}):Play()
            TweenService:Create(toggleIndicator, TweenInfo.new(0.2), {Position = UDim2.new(0, 2, 0.5, -8)}):Play()
        end
        callback(state)
    end)
    
    return {
        Set = function(v) 
            state = v
            if state then
                toggleFrame.BackgroundColor3 = Colors.Accent
                toggleIndicator.Position = UDim2.new(1, -20, 0.5, -8)
            else
                toggleFrame.BackgroundColor3 = Colors.Border
                toggleIndicator.Position = UDim2.new(0, 2, 0.5, -8)
            end
            callback(state)
        end,
        Get = function() return state end
    }
end

-- Slider
function AetherUI:Slider(parent, text, min, max, default, callback)
    local container = create(parent, "Frame", {
        Size = UDim2.new(1, 0, 0, 50),
        BackgroundTransparency = 1,
    })
    
    local label = create(container, "TextLabel", {
        Size = UDim2.new(0.6, 0, 0, 20),
        Position = UDim2.new(0, 5, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Colors.Text,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    
    local valueLabel = create(container, "TextLabel", {
        Size = UDim2.new(0.3, 0, 0, 20),
        Position = UDim2.new(0.7, 0, 0, 0),
        BackgroundTransparency = 1,
        Text = tostring(default),
        TextColor3 = Colors.Accent,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
    })
    
    local sliderTrack = create(container, "Frame", {
        Size = UDim2.new(1, -10, 0, 4),
        Position = UDim2.new(0, 5, 0, 28),
        BackgroundColor3 = Colors.Border,
        BorderSizePixel = 0,
    })
    
    addCorner(sliderTrack, 2)
    
    local sliderFill = create(sliderTrack, "Frame", {
        Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = Colors.Accent,
        BorderSizePixel = 0,
    })
    
    addCorner(sliderFill, 2)
    
    local sliderHandle = create(container, "TextButton", {
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new((default - min) / (max - min), -6, 0, 24),
        BackgroundColor3 = Colors.Text,
        Text = "",
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    addCorner(sliderHandle, 6)
    
    local value = default
    local dragging = false
    
    local function update(posX)
        local relative = math.clamp((posX - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X, 0, 1)
        value = min + (max - min) * relative
        value = math.floor(value * 100) / 100
        
        sliderFill.Size = UDim2.new(relative, 0, 1, 0)
        sliderHandle.Position = UDim2.new(relative, -6, 0, 24)
        valueLabel.Text = tostring(value)
        
        callback(value)
    end
    
    sliderHandle.MouseButton1Down:Connect(function()
        dragging = true
        local conn
        conn = UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
                update(input.Position.X)
            end
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
                conn:Disconnect()
            end
        end)
    end)
    
    sliderTrack.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            update(input.Position.X)
        end
    end)
    
    return {
        Set = function(v)
            value = math.clamp(v, min, max)
            local relative = (value - min) / (max - min)
            sliderFill.Size = UDim2.new(relative, 0, 1, 0)
            sliderHandle.Position = UDim2.new(relative, -6, 0, 24)
            valueLabel.Text = tostring(value)
            callback(value)
        end,
        Get = function() return value end
    }
end

