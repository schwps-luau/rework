        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local valueLabel = createUIElement(container, "TextLabel", {
        Size = UDim2.new(0, 60, 1, 0),
        Position = UDim2.new(0.5, -30, 0, 0),
        BackgroundTransparency = 1,
        Text = tostring(default),
        TextColor3 = ModernUI.Theme.Primary,
        TextSize = 16,
        Font = Enum.Font.GothamBold,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local minusButton = createUIElement(container, "TextButton", {
        Size = UDim2.new(0, 35, 0, 35),
        Position = UDim2.new(1, -85, 0.5, -17.5),
        BackgroundColor3 = ModernUI.Theme.Danger,
        Text = "-",
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 20,
        Font = Enum.Font.GothamBold,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    local minusCorner = createUIElement(minusButton, "UICorner", {
        CornerRadius = UDim.new(0, 6)
    })
    
    local plusButton = createUIElement(container, "TextButton", {
        Size = UDim2.new(0, 35, 0, 35),
        Position = UDim2.new(1, -40, 0.5, -17.5),
        BackgroundColor3 = ModernUI.Theme.Success,
        Text = "+",
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 20,
        Font = Enum.Font.GothamBold,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    local plusCorner = createUIElement(plusButton, "UICorner", {
        CornerRadius = UDim.new(0, 6)
    })
    
    local value = math.clamp(default or 0, min or 0, max or 100)
    
    local function updateCounter(newValue)
        value = math.clamp(newValue, min or -1e9, max or 1e9)
        valueLabel.Text = tostring(value)
        if callback then callback(value) end
    end
    
    minusButton.MouseButton1Click:Connect(function() 
        TweenService:Create(minusButton, TweenSettings.In, {BackgroundColor3 = ModernUI.Theme.Danger:lerp(Color3.new(0,0,0), 0.3)}):Play()
        updateCounter(value - 1)
        task.wait(0.1)
        TweenService:Create(minusButton, TweenSettings.Out, {BackgroundColor3 = ModernUI.Theme.Danger}):Play()
    end)
    
    plusButton.MouseButton1Click:Connect(function() 
        TweenService:Create(plusButton, TweenSettings.In, {BackgroundColor3 = ModernUI.Theme.Success:lerp(Color3.new(0,0,0), 0.3)}):Play()
        updateCounter(value + 1)
        task.wait(0.1)
        TweenService:Create(plusButton, TweenSettings.Out, {BackgroundColor3 = ModernUI.Theme.Success}):Play()
    end)
    
    table.insert(self.Elements, {Type = "Counter", Object = container, Value = value})
    return {
        SetValue = updateCounter, 
        GetValue = function() 
            return value 
        end
    }
end

-- Label component
function ModernUI:Label(text, order, isHeader)
    order = order or #self.Elements + 1
    local container = self:createElementContainer(order)
    container.Size = UDim2.new(1, -20, 0, isHeader and 40 or 30)
    container.BackgroundTransparency = 1
    
    local label = createUIElement(container, "TextLabel", {
        Size = UDim2.new(1, -20, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = isHeader and ModernUI.Theme.Primary or ModernUI.Theme.TextSecondary,
        TextSize = isHeader and 14 or 12,
        Font = isHeader and Enum.Font.GothamBold or Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    if isHeader then
        local line = createUIElement(container, "Frame", {
            Size = UDim2.new(1, -20, 0, 1),
            Position = UDim2.new(0, 10, 0, 35),
            BackgroundColor3 = ModernUI.Theme.Primary,
            BorderSizePixel = 0,
        })
    end
    
    table.insert(self.Elements, {Type = "Label", Object = label})
    return label
end

-- Method to clear all elements
function ModernUI:Clear()
    for _, element in ipairs(self.Elements) do
        if element.Object and element.Object.Parent then
            local parent = element.Object.Parent
            if parent and parent.Parent == self.ScrollFrame then
                parent:Destroy()
            elseif element.Object.Parent then
                element.Object:Destroy()
            end
        end
    end
    self.Elements = {}
    
    task.wait()
    self.ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, self.UIList.AbsoluteContentSize.Y)
end

-- Method to destroy entire UI
function ModernUI:Destroy()
    if self.ScreenGui then
        self.ScreenGui:Destroy()
    end
end

-- Method to update canvas size
function ModernUI:UpdateCanvas()
    self.ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, self.UIList.AbsoluteContentSize.Y)
end

return ModernUI
