        {Color3.fromRGB(0, 0, 255), "Blue"},
        {Color3.fromRGB(255, 255, 0), "Yellow"},
        {Color3.fromRGB(255, 0, 255), "Purple"},
        {Color3.fromRGB(0, 255, 255), "Cyan"},
        {Color3.fromRGB(255, 165, 0), "Orange"},
        {Color3.fromRGB(255, 192, 203), "Pink"},
        {Color3.fromRGB(128, 0, 128), "Dark Purple"},
        Color3.fromRGB(88, 101, 242), -- Default
    }
    
    local colorPickerOpen = false
    local colorFrame
    
    colorDisplay.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if colorPickerOpen then
                if colorFrame then colorFrame:Destroy() end
                colorPickerOpen = false
            else
                colorFrame = createRoundedFrame(self.ScrollFrame, UDim2.new(0, 200, 0, 250), UDim2.new(0, 10, 0, container.AbsolutePosition.Y - self.ScrollFrame.AbsolutePosition.Y + 55), ModernUI.Theme.Surface, 0)
                colorFrame.ZIndex = 10
                colorFrame.BackgroundTransparency = 0
                
                local colorList = createUIElement(colorFrame, "UIListLayout", {
                    Padding = UDim.new(0, 5),
                    SortOrder = Enum.SortOrder.LayoutOrder,
                })
                
                for i, color in ipairs(colors) do
                    local colorButton = createRoundedFrame(colorFrame, UDim2.new(1, -20, 0, 35), UDim2.new(0, 10, 0, 0), type(color) == "table" and color[1] or color, 0)
                    colorButton.LayoutOrder = i
                    colorButton.BackgroundTransparency = 0
                    
                    local colorText = createUIElement(colorButton, "TextLabel", {
                        Size = UDim2.new(1, 0, 1, 0),
                        BackgroundTransparency = 1,
                        Text = type(color) == "table" and color[2] or "",
                        TextColor3 = ModernUI.Theme.Text,
                        TextSize = 12,
                        Font = Enum.Font.GothamMedium,
                        Visible = type(color) == "table",
                    })
                    
                    colorButton.InputBegan:Connect(function(input)
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then
                            currentColor = type(color) == "table" and color[1] or color
                            colorDisplay.BackgroundColor3 = currentColor
                            if callback then callback(currentColor) end
                            colorFrame:Destroy()
                            colorPickerOpen = false
                        end
                    end)
                end
                
                colorPickerOpen = true
            end
        end
    end)
    
    table.insert(self.Elements, {Type = "ColorPicker", Object = colorDisplay, Color = currentColor})
    return {
        SetColor = function(newColor) 
            currentColor = newColor 
            colorDisplay.BackgroundColor3 = newColor 
            if callback then callback(newColor) end
        end, 
        GetColor = function() 
            return currentColor 
        end
    }
end

