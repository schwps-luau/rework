            btn.MouseButton1Click:Connect(function()
                colorBox.BackgroundColor3 = col
                if callback then callback(col) end
                picker:Destroy()
                open = false
            end)
        end
        
        open = true
    end)
    
    table.insert(self.Elements, frame)
    return {
        Set = function(col) colorBox.BackgroundColor3 = col if callback then callback(col) end end,
        Get = function() return colorBox.BackgroundColor3 end
    }
end

