    minusButton.MouseButton1Click:Connect(function() updateCounter(value - 1) end)
    plusButton.MouseButton1Click:Connect(function() updateCounter(value + 1) end)
    
    table.insert(self.Elements, {Type = "Counter", Object = container, Value = value})
    return {SetValue = updateCounter, GetValue = function() return value end}
end

