        Text = "-",
        TextColor3 = ModernUI.Colors.Text,
        TextSize = 16,
        Font = Enum.Font.GothamBold,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    local plus = create(frame, "TextButton", {
        Size = UDim2.new(0, 32, 0, 28),
        Position = UDim2.new(1, -20, 0.5, -14),
        BackgroundColor3 = ModernUI.Colors.Success,
        Text = "+",
        TextColor3 = ModernUI.Colors.Text,
        TextSize = 16,
        Font = Enum.Font.GothamBold,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    local value = math.clamp(default or 0, min or 0, max or 100)
    
    local function update(v)
        value = math.clamp(v, min or -1e9, max or 1e9)
        valueLabel.Text = tostring(value)
        if callback then callback(value) end
    end
    
    minus.MouseButton1Click:Connect(function() update(value - 1) end)
    plus.MouseButton1Click:Connect(function() update(value + 1) end)
    
    table.insert(self.Elements, frame)
    return {
        Set = update,
        Get = function() return value end
    }
end

-- Label
function ModernUI:Label(text, order, isSection)
    order = order or #self.Elements + 1
    local height = isSection and 32 or 28
    local frame = create(self.Container, "Frame", {
        Size = UDim2.new(1, 0, 0, height),
        BackgroundColor3 = isSection and ModernUI.Colors.Background or ModernUI.Colors.Surface,
        BorderSizePixel = 0,
        LayoutOrder = order,
    })
    
    local label = create(frame, "TextLabel", {
        Size = UDim2.new(1, -24, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        BackgroundTransparency = 1,
        Text = text:upper(),
        TextColor3 = isSection and ModernUI.Colors.Primary or ModernUI.Colors.TextSecondary,
        TextSize = isSection and 11 or 10,
        Font = isSection and Enum.Font.GothamBold or Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    table.insert(self.Elements, frame)
    return label
end

-- Clear all
function ModernUI:Clear()
    for _, elem in ipairs(self.Elements) do
        if elem and elem.Parent then
            elem:Destroy()
        end
    end
    self.Elements = {}
end

-- Destroy UI
function ModernUI:Destroy()
    if self.Gui then
        self.Gui:Destroy()
    end
end

return ModernUI
