-- Dropdown component
function ModernUI:Dropdown(text, options, callback, order)
    order = order or #self.Elements + 1
    local container = self:createElementContainer(order)
    container.Size = UDim2.new(1, -20, 0, 50)
    container.BackgroundTransparency = 0.8
    
    local dropdownButton = createUIElement(container, "TextButton", {
        Size = UDim2.new(1, -20, 1, -10),
        Position = UDim2.new(0, 10, 0, 5),
        BackgroundColor3 = ModernUI.Theme.Background,
        Text = text .. ": " .. options[1],
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 14,
        Font = Enum.Font.GothamMedium,
        BorderSizePixel = 0,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd,
    })
    
    local corner = createUIElement(dropdownButton, "UICorner", {
        CornerRadius = UDim.new(0, 6)
    })
    
    local dropdownOpen = false
    local dropdownFrame
    
    dropdownButton.MouseButton1Click:Connect(function()
        if dropdownOpen then
            if dropdownFrame then dropdownFrame:Destroy() end
            dropdownOpen = false
        else
            dropdownFrame = createRoundedFrame(self.ScrollFrame, UDim2.new(1, -20, 0, #options * 40), UDim2.new(0, 10, 0, container.AbsolutePosition.Y - self.ScrollFrame.AbsolutePosition.Y + 55), ModernUI.Theme.Surface, 0)
            dropdownFrame.ZIndex = 10
            dropdownFrame.BackgroundTransparency = 0
            
            local dropdownList = createUIElement(dropdownFrame, "UIListLayout", {
                Padding = UDim.new(0, 2),
                SortOrder = Enum.SortOrder.LayoutOrder,
            })
            
            for i, option in ipairs(options) do
                local optionButton = createUIElement(dropdownFrame, "TextButton", {
                    Size = UDim2.new(1, -10, 0, 38),
                    Position = UDim2.new(0, 5, 0, 0),
                    BackgroundColor3 = ModernUI.Theme.Background,
                    Text = option,
                    TextColor3 = ModernUI.Theme.Text,
                    TextSize = 14,
                    Font = Enum.Font.GothamMedium,
                    BorderSizePixel = 0,
                    LayoutOrder = i,
                })
                
                local optionCorner = createUIElement(optionButton, "UICorner", {
                    CornerRadius = UDim.new(0, 4)
                })
                
                optionButton.MouseButton1Click:Connect(function()
                    dropdownButton.Text = text .. ": " .. option
                    if callback then callback(option) end
                    dropdownFrame:Destroy()
                    dropdownOpen = false
                end)
            end
            
            dropdownOpen = true
        end
    end)
    
    table.insert(self.Elements, {Type = "Dropdown", Object = dropdownButton})
    return dropdownButton
end

-- Slider component
function ModernUI:Slider(text, min, max, default, callback, order)
    order = order or #self.Elements + 1
    local container = self:createElementContainer(order)
    container.Size = UDim2.new(1, -20, 0, 80)
    container.BackgroundTransparency = 0.8
    
    local label = createUIElement(container, "TextLabel", {
        Size = UDim2.new(1, -20, 0, 25),
        Position = UDim2.new(0, 10, 0, 5),
        BackgroundTransparency = 1,
        Text = text .. ": " .. tostring(default),
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 14,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    
    local valueDisplay = createUIElement(container, "TextLabel", {
        Size = UDim2.new(0, 50, 0, 25),
        Position = UDim2.new(1, -60, 0, 5),
        BackgroundTransparency = 1,
        Text = tostring(default),
        TextColor3 = ModernUI.Theme.Primary,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
    })
    
    local sliderFrame = createRoundedFrame(container, UDim2.new(1, -20, 0, 30), UDim2.new(0, 10, 0, 40), ModernUI.Theme.Background, 0)
    
    local fill = createRoundedFrame(sliderFrame, UDim2.new((default - min) / (max - min), 0, 1, 0), UDim2.new(0, 0, 0, 0), ModernUI.Theme.Primary, 0)
    fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    
    local value = default
    
    local function updateSlider(mouseX)
        local relativeX = math.clamp((mouseX - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
        value = min + (max - min) * relativeX
        value = math.floor(value * 100) / 100
        
        fill.Size = UDim2.new(relativeX, 0, 1, 0)
        label.Text = text .. ": " .. tostring(value)
        valueDisplay.Text = tostring(value)
        
        if callback then callback(value) end
    end
    
    sliderFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            updateSlider(input.Position.X)
            
            local connection
            connection = UserInputService.InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement then
                    updateSlider(input.Position.X)
                end
            end)
            
            local endedConn
            endedConn = UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    connection:Disconnect()
                    endedConn:Disconnect()
                end
            end)
        end
    end)
    
    table.insert(self.Elements, {Type = "Slider", Object = sliderFrame, Value = value})
    return {
        SetValue = function(newValue) 
            local relativeX = (newValue - min) / (max - min)
            fill.Size = UDim2.new(relativeX, 0, 1, 0)
            value = newValue
            label.Text = text .. ": " .. tostring(value)
            valueDisplay.Text = tostring(value)
            if callback then callback(value) end
        end, 
        GetValue = function() 
            return value 
        end
    }
end

-- Keybind component
function ModernUI:Keybind(text, defaultKey, callback, order)
    order = order or #self.Elements + 1
    local container = self:createElementContainer(order)
    container.Size = UDim2.new(1, -20, 0, 50)
    container.BackgroundTransparency = 0.8
    
    local label = createUIElement(container, "TextLabel", {
        Size = UDim2.new(0.6, -20, 1, 0),
        Position = UDim2.new(0, 15, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 14,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local keybindButton = createUIElement(container, "TextButton", {
        Size = UDim2.new(0, 100, 0, 35),
        Position = UDim2.new(1, -110, 0.5, -17.5),
        BackgroundColor3 = ModernUI.Theme.Background,
        Text = defaultKey and tostring(defaultKey):gsub("Enum.KeyCode.", "") or "None",
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 13,
        Font = Enum.Font.GothamMedium,
        BorderSizePixel = 0,
    })
    
    local corner = createUIElement(keybindButton, "UICorner", {
        CornerRadius = UDim.new(0, 6)
    })
    
    local listening = false
    local currentKey = defaultKey
    
    keybindButton.MouseButton1Click:Connect(function()
        listening = true
        keybindButton.Text = "..."
        
        local connection
        connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            
            if listening and input.KeyCode ~= Enum.KeyCode.Unknown then
                currentKey = input.KeyCode
                keybindButton.Text = tostring(currentKey):gsub("Enum.KeyCode.", "")
                listening = false
                connection:Disconnect()
                if callback then callback(currentKey) end
            end
        end)
        
        task.wait(3)
        if listening then
            listening = false
            keybindButton.Text = currentKey and tostring(currentKey):gsub("Enum.KeyCode.", "") or "None"
            connection:Disconnect()
        end
    end)
    
    table.insert(self.Elements, {Type = "Keybind", Object = keybindButton, Key = currentKey})
    return {
        SetKey = function(newKey) 
            currentKey = newKey 
            keybindButton.Text = tostring(newKey):gsub("Enum.KeyCode.", "")
        end, 
        GetKey = function() 
            return currentKey 
        end
    }
end

