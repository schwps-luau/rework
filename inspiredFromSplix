    colorBox.MouseButton1Click:Connect(function()
        if open then
            if picker then picker:Destroy() end
            open = false
            return
        end
        
        picker = create(self.Container, "Frame", {
            Size = UDim2.new(0, 160, 0, 160),
            Position = UDim2.new(0, 0, 0, frame.AbsolutePosition.Y - self.Container.AbsolutePosition.Y + 40),
            BackgroundColor3 = ModernUI.Colors.Surface,
            BorderSizePixel = 0,
            ZIndex = 10,
        })
        
        local grid = create(picker, "UIListLayout", {
            Padding = UDim.new(0, 4),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Wrap = true,
        })
        
        for _, col in ipairs(colors) do
            local btn = create(picker, "TextButton", {
                Size = UDim2.new(0, 32, 0, 32),
                BackgroundColor3 = col,
                Text = "",
                BorderSizePixel = 0,
                AutoButtonColor = false,
