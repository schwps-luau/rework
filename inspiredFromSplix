    })
    
    local colorDisplay = create(container, "Frame", {
        Size = UDim2.new(0, 30, 0, 24),
        Position = UDim2.new(1, -35, 0.5, -12),
        BackgroundColor3 = default or Colors.Accent,
        BorderSizePixel = 1,
        BorderColor3 = Colors.Border,
    })
    
    local currentColor = default or Colors.Accent
    
    local colors = {
        Color3.fromRGB(225, 58, 81),
        Color3.fromRGB(70, 190, 90),
        Color3.fromRGB(70, 130, 200),
        Color3.fromRGB(230, 70, 70),
        Color3.fromRGB(255, 200, 70),
        Color3.fromRGB(200, 70, 255),
        Color3.fromRGB(70, 200, 200),
        Color3.fromRGB(255, 255, 255),
    }
    
    local open = false
    local pickerFrame
    
    local function closePicker()
        if pickerFrame then
            pickerFrame:Destroy()
            open = false
        end
    end
    
    local function openPicker()
        closePicker()
        
        pickerFrame = create(container, "Frame", {
            Size = UDim2.new(0, 150, 0, 100),
            Position = UDim2.new(1, -185, 0, 35),
            BackgroundColor3 = Colors.BorderDark,
            BorderSizePixel = 1,
            BorderColor3 = Colors.Border,
            ZIndex = 10,
        })
        
        local inner = create(pickerFrame, "Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            Size = UDim2.new(1, -4, 1, -4),
            BackgroundColor3 = Colors.Background,
            BorderSizePixel = 1,
            BorderColor3 = Colors.Border,
            ZIndex = 10,
        })
        
        local grid = create(inner, "UIListLayout", {
            FillDirection = Enum.FillDirection.Horizontal,
            HorizontalAlignment = Enum.HorizontalAlignment.Center,
            Padding = UDim.new(0, 5),
            SortOrder = Enum.SortOrder.LayoutOrder,
            Wrap = true,
        })
        
        for _, col in ipairs(colors) do
            local colorBtn = create(inner, "TextButton", {
                Size = UDim2.new(0, 30, 0, 30),
                BackgroundColor3 = col,
                Text = "",
                BorderSizePixel = 1,
                BorderColor3 = Colors.Border,
                AutoButtonColor = false,
            })
            
            colorBtn.MouseButton1Click:Connect(function()
                currentColor = col
                colorDisplay.BackgroundColor3 = col
                callback(col)
                closePicker()
            end)
        end
        
        open = true
    end
    
    local button = create(container, "TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        BorderSizePixel = 0,
    })
    
    button.MouseButton1Click:Connect(function()
        if open then
            closePicker()
        else
            openPicker()
        end
    end)
    
    return {
        Set = function(col)
            currentColor = col
            colorDisplay.BackgroundColor3 = col
            callback(col)
        end,
        Get = function() return currentColor end
    }
end

