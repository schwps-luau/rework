        Size = UDim2.new(1, -25, 1, 0),
        Position = UDim2.new(0, 5, 0, 0),
        BackgroundTransparency = 1,
        Text = default or options[1],
        TextColor3 = Colors.Text,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local arrow = create(innerBorder, "TextLabel", {
        Size = UDim2.new(0, 20, 1, 0),
        Position = UDim2.new(1, -5, 0, 0),
        BackgroundTransparency = 1,
        Text = "▼",
        TextColor3 = Colors.TextSecondary,
        TextSize = 10,
        Font = Enum.Font.Gotham,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local dropdownOpen = false
    local dropdownFrame
    
    local function closeDropdown()
        if dropdownFrame then
            dropdownFrame:Destroy()
            dropdownOpen = false
        end
    end
    
    local function openDropdown()
        closeDropdown()
        
        dropdownFrame = create(container, "Frame", {
            Size = UDim2.new(1, 0, 0, #options * 28),
            Position = UDim2.new(0, 0, 0, 55),
            BackgroundColor3 = Colors.BorderDark,
            BorderSizePixel = 1,
            BorderColor3 = Colors.Border,
            ZIndex = 10,
        })
        
        local inner = create(dropdownFrame, "Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, 0, 0.5, 0),
            Size = UDim2.new(1, -4, 1, -4),
            BackgroundColor3 = Colors.Background,
            BorderSizePixel = 1,
            BorderColor3 = Colors.Border,
            ZIndex = 10,
        })
        
        local listLayout = create(inner, "UIListLayout", {
            Padding = UDim.new(0, 0),
        })
        
        for _, opt in ipairs(options) do
            local optBtn = create(inner, "TextButton", {
                Size = UDim2.new(1, 0, 0, 28),
                BackgroundColor3 = Colors.Background,
                Text = opt,
                TextColor3 = Colors.Text,
                TextSize = 12,
                Font = Enum.Font.Gotham,
                BorderSizePixel = 0,
                AutoButtonColor = false,
            })
            
            optBtn.MouseButton1Click:Connect(function()
                valueLabel.Text = opt
                callback(opt)
                closeDropdown()
            end)
        end
        
        dropdownOpen = true
    end
    
    local button = create(container, "TextButton", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "",
        BorderSizePixel = 0,
    })
    
    button.MouseButton1Click:Connect(function()
        if dropdownOpen then
            closeDropdown()
        else
            openDropdown()
        end
    end)
    
    return {
        Set = function(v)
            if table.find(options, v) then
                valueLabel.Text = v
                callback(v)
            end
        end,
        Get = function() return valueLabel.Text end
    }
end

