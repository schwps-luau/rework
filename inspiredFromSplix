local AetherUI = loadstring(game:HttpGet("your-url.lua"))()

-- Create main window
local ui = AetherUI.new("AETHER", UDim2.new(0, 550, 0, 650))

-- Create tabs
local combatTab = ui:Tab("COMBAT")
local visualsTab = ui:Tab("VISUALS")
local playerTab = ui:Tab("PLAYER")
local settingsTab = ui:Tab("SETTINGS")

-- Combat Section (Left panel)
local combatLeft = AetherUI:Section(combatTab, "Aimbot", "left")
local combatRight = AetherUI:Section(combatTab, "Triggerbot", "right")

-- Toggle
local aimbotEnabled = AetherUI:Toggle(combatLeft, "Aimbot", true, function(state)
    print("Aimbot:", state)
end)

-- Slider
local fovSlider = AetherUI:Slider(combatLeft, "FOV", 0, 360, 120, function(val)
    print("FOV:", val)
end)

-- Dropdown
local aimPart = AetherUI:Dropdown(combatLeft, "Aim Part", {"Head", "Torso", "HumanoidRootPart"}, "Head", function(opt)
    print("Aim part:", opt)
end)

-- Keybind
local aimKey = AetherUI:Keybind(combatLeft, "Aimbot Key", Enum.KeyCode.RightShift, function(key)
    print("Keybind set:", key)
end)

-- Visuals Tab
local espLeft = AetherUI:Section(visualsTab, "ESP", "left")
local worldLeft = AetherUI:Section(visualsTab, "World", "right")

AetherUI:Toggle(espLeft, "Box ESP", true, function(state) end)
AetherUI:Toggle(espLeft, "Skeleton ESP", false, function(state) end)
AetherUI:ColorPicker(espLeft, "ESP Color", Color3.fromRGB(225, 58, 81), function(col) end)

AetherUI:Toggle(worldLeft, "Chams", true, function(state) end)
AetherUI:Slider(worldLeft, "Transparency", 0, 1, 0.5, function(val) end)

-- Player Tab
local movementLeft = AetherUI:Section(playerTab, "Movement", "left")
local miscLeft = AetherUI:Section(playerTab, "Misc", "right")

local walkSpeed = AetherUI:Slider(movementLeft, "Walk Speed", 16, 100, 16, function(val)
    game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = val
end)

local jumpPower = AetherUI:Counter(movementLeft, "Jump Power", 50, 200, 50, function(val)
    game.Players.LocalPlayer.Character.Humanoid.JumpPower = val
end)

AetherUI:Toggle(movementLeft, "Noclip", false, function(state) end)

-- Settings Tab
local configLeft = AetherUI:Section(settingsTab, "Config", "left")
AetherUI:TextBox(configLeft, "Config Name", function(text) print("Config:", text) end)

AetherUI:Button(configLeft, "Save Config", function() print("Saved") end)
AetherUI:Button(configLeft, "Load Config", function() print("Loaded") end)

-- Close UI with Insert key
UserInputService.InputBegan:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.Insert then
        ui.Window.Visible = not ui.Window.Visible
    end
end)
