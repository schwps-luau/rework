-- Keybind
function AetherUI:Keybind(parent, text, default, callback)
    local container = create(parent, "Frame", {
        Size = UDim2.new(1, 0, 0, 30),
        BackgroundTransparency = 1,
    })
    
    local label = create(container, "TextLabel", {
        Size = UDim2.new(0.7, 0, 1, 0),
        Position = UDim2.new(0, 5, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Colors.Text,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local bindBtn = create(container, "TextButton", {
        Size = UDim2.new(0, 80, 0, 24),
        Position = UDim2.new(1, -85, 0.5, -12),
        BackgroundColor3 = Colors.Surface,
        Text = default and tostring(default):gsub("Enum.KeyCode.", "") or "None",
        TextColor3 = Colors.Text,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    local listening = false
    local currentKey = default
    
    bindBtn.MouseButton1Click:Connect(function()
        listening = true
        bindBtn.Text = "..."
        
        local conn
        conn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            
            if listening and input.KeyCode ~= Enum.KeyCode.Unknown then
                currentKey = input.KeyCode
                bindBtn.Text = tostring(currentKey):gsub("Enum.KeyCode.", "")
                listening = false
                conn:Disconnect()
                callback(currentKey)
            end
        end)
        
        task.wait(3)
        if listening then
            listening = false
            bindBtn.Text = currentKey and tostring(currentKey):gsub("Enum.KeyCode.", "") or "None"
            conn:Disconnect()
        end
    end)
    
    return {
        Set = function(k)
            currentKey = k
            bindBtn.Text = tostring(k):gsub("Enum.KeyCode.", "")
            callback(k)
        end,
        Get = function() return currentKey end
    }
end

