--[[
    Modern UI Library - Splix/Yun Style
    Clean, minimal, flat design
    No rounded corners, no shadows, no animations
]]

local ModernUI = {}
ModernUI.__index = ModernUI

-- Services
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Flat color palette (Splix/Yun style)
ModernUI.Colors = {
    Background = Color3.fromRGB(18, 18, 22),
    Surface = Color3.fromRGB(26, 26, 30),
    Primary = Color3.fromRGB(64, 128, 255),
    PrimaryHover = Color3.fromRGB(84, 148, 255),
    Danger = Color3.fromRGB(230, 70, 70),
    DangerHover = Color3.fromRGB(250, 90, 90),
    Success = Color3.fromRGB(70, 190, 90),
    Text = Color3.fromRGB(235, 235, 240),
    TextSecondary = Color3.fromRGB(140, 140, 150),
    Border = Color3.fromRGB(38, 38, 44),
    Checkmark = Color3.fromRGB(64, 128, 255),
}

-- Utility function
local function create(parent, className, props)
    local obj = Instance.new(className)
    for k, v in pairs(props) do
        obj[k] = v
    end
    obj.Parent = parent
    return obj
end

-- Main constructor
function ModernUI.new(title, size)
    local self = setmetatable({}, ModernUI)
    
    -- Create ScreenGui
    local gui = Instance.new("ScreenGui")
    gui.Name = "ModernUI"
    gui.Parent = game:GetService("CoreGui")
    gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    
    local windowSize = size or UDim2.new(0, 380, 0, 520)
    local window = create(gui, "Frame", {
        Size = windowSize,
        Position = UDim2.new(0.5, -windowSize.X.Offset/2, 0.5, -windowSize.Y.Offset/2),
        BackgroundColor3 = ModernUI.Colors.Background,
        BorderSizePixel = 0,
    })
    
    -- Title bar
    local titleBar = create(window, "Frame", {
        Size = UDim2.new(1, 0, 0, 44),
        BackgroundColor3 = ModernUI.Colors.Surface,
        BorderSizePixel = 0,
    })
    
    create(titleBar, "TextLabel", {
        Size = UDim2.new(1, -40, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        BackgroundTransparency = 1,
        Text = title or "ui",
        TextColor3 = ModernUI.Colors.Text,
        TextSize = 13,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    -- Close button
    local closeBtn = create(titleBar, "TextButton", {
        Size = UDim2.new(0, 44, 1, 0),
        Position = UDim2.new(1, -44, 0, 0),
        BackgroundColor3 = ModernUI.Colors.Surface,
        Text = "×",
        TextColor3 = ModernUI.Colors.TextSecondary,
        TextSize = 20,
        Font = Enum.Font.Gotham,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    closeBtn.MouseButton1Click:Connect(function()
        gui:Destroy()
    end)
    
    -- Minimize button
    local minBtn = create(titleBar, "TextButton", {
        Size = UDim2.new(0, 44, 1, 0),
        Position = UDim2.new(1, -88, 0, 0),
        BackgroundColor3 = ModernUI.Colors.Surface,
        Text = "—",
        TextColor3 = ModernUI.Colors.TextSecondary,
        TextSize = 20,
        Font = Enum.Font.Gotham,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    local minimized = false
    local originalHeight = windowSize.Y.Offset
    
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        window.Size = UDim2.new(windowSize.X.Scale, windowSize.X.Offset, 0, minimized and 44 or originalHeight)
    end)
    
    -- Dragging
    local dragStart, startPos
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragStart = input.Position
            startPos = window.Position
        end
    end)
    
    titleBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragStart then
            local delta = input.Position - dragStart
            window.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragStart = nil
        end
    end)
    
    -- Content container
    local container = create(window, "ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, -44),
        Position = UDim2.new(0, 0, 0, 44),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = ModernUI.Colors.Border,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
    })
    
    local layout = create(container, "UIListLayout", {
        Padding = UDim.new(0, 0),
        SortOrder = Enum.SortOrder.LayoutOrder,
    })
    
    self.Gui = gui
    self.Window = window
    self.Container = container
    self.Layout = layout
    self.Elements = {}
    
    return self
end

-- Button
function ModernUI:Button(text, callback, order)
    order = order or #self.Elements + 1
    local frame = create(self.Container, "Frame", {
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = ModernUI.Colors.Surface,
        BorderSizePixel = 0,
        LayoutOrder = order,
    })
    
    local btn = create(frame, "TextButton", {
        Size = UDim2.new(1, -24, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        BackgroundColor3 = ModernUI.Colors.Primary,
        Text = text:upper(),
        TextColor3 = ModernUI.Colors.Text,
        TextSize = 12,
        Font = Enum.Font.GothamSemibold,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    btn.MouseButton1Click:Connect(callback)
    
    table.insert(self.Elements, frame)
    return btn
end

-- Toggle
function ModernUI:Toggle(text, default, callback, order)
    order = order or #self.Elements + 1
    local frame = create(self.Container, "Frame", {
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = ModernUI.Colors.Surface,
        BorderSizePixel = 0,
        LayoutOrder = order,
    })
    
    local label = create(frame, "TextLabel", {
        Size = UDim2.new(1, -60, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = ModernUI.Colors.Text,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local toggle = create(frame, "TextButton", {
        Size = UDim2.new(0, 36, 0, 20),
        Position = UDim2.new(1, -48, 0.5, -10),
        BackgroundColor3 = default and ModernUI.Colors.Primary or ModernUI.Colors.Border,
        Text = "",
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    local state = default or false
    
    local function update()
        toggle.BackgroundColor3 = state and ModernUI.Colors.Primary or ModernUI.Colors.Border
        if callback then callback(state) end
    end
    
    toggle.MouseButton1Click:Connect(function()
        state = not state
        update()
    end)
    
    update()
    
    table.insert(self.Elements, frame)
    return {
        Set = function(v) state = v update() end,
        Get = function() return state end
    }
end

