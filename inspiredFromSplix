-- Загрузка библиотеки
local ModernUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/your-repo/modern-ui.lua"))()

-- Создание UI
local ui = ModernUI.new("My Exploit GUI", UDim2.new(0, 500, 0, 650))

-- Combat Section
ui:Label("COMBAT", nil, true)

ui:Button("Aimbot", function()
    print("Aimbot toggled")
    -- Ваш код для аимбота
end)

local silentAim = ui:Toggle("Silent Aim", false, function(state)
    print("Silent Aim:", state)
end)

ui:Slider("Aimbot FOV", 0, 360, 120, function(value)
    print("FOV:", value)
end)

-- Visuals Section
ui:Label("VISUALS", nil, true)

ui:Toggle("ESP", true, function(state)
    print("ESP:", state)
end)

ui:Dropdown("ESP Type", {"Box", "Chams", "Outline", "Glow"}, function(option)
    print("ESP Type:", option)
end)

ui:ColorPicker("ESP Color", Color3.fromRGB(255, 0, 0), function(color)
    print("ESP Color:", color)
end)

-- Player Section
ui:Label("PLAYER", nil, true)

local speed = ui:Slider("Walk Speed", 16, 100, 16, function(value)
    game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = value
end)

ui:Keybind("Speed Key", Enum.KeyCode.LeftControl, function(key)
    print("Speed bind set to:", key)
end)

ui:Counter("Jump Power", 50, 200, 50, function(value)
    game.Players.LocalPlayer.Character.Humanoid.JumpPower = value
end)

-- Settings Section
ui:Label("SETTINGS", nil, true)

ui:TextBox("Save Config Name", function(text)
    print("Save config:", text)
end)

ui:Button("Save Config", function()
    print("Config saved")
end)

ui:Button("Load Config", function()
    print("Config loaded")
end)

-- Update canvas after adding all elements
ui:UpdateCanvas()

-- Закрытие UI по нажатию клавиши Insert
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.Insert then
        ui.MainFrame.Visible = not ui.MainFrame.Visible
    end
end)
