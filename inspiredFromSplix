        TextColor3 = ModernUI.Colors.Primary,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local minus = create(frame, "TextButton", {
        Size = UDim2.new(0, 32, 0, 28),
        Position = UDim2.new(1, -56, 0.5, -14),
