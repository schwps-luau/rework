-- Tween settings
local TweenSettings = {
    InOut = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut),
    Out = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
    In = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
    Bounce = TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
}

-- Utility function for creating UI elements
local function createUIElement(parent, className, properties)
    local element = Instance.new(className)
    for prop, value in pairs(properties) do
        element[prop] = value
    end
    element.Parent = parent
    return element
end

-- Create a rounded frame with shadow effect
local function createRoundedFrame(parent, size, position, color, transparency)
    local frame = createUIElement(parent, "Frame", {
        Size = size,
        Position = position,
        BackgroundColor3 = color,
        BackgroundTransparency = transparency or 0,
        BorderSizePixel = 0,
        ClipsDescendants = true,
    })
    
    local corner = createUIElement(frame, "UICorner", {
        CornerRadius = UDim.new(0, 8)
    })
    
    return frame
end

-- Dragging functionality
local function makeDraggable(frame)
    local dragging = false
    local dragInput
    local dragStart
    local startPos
    
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- Main library constructor
function ModernUI.new(title, size, theme)
    local self = setmetatable({}, ModernUI)
    
    -- Apply custom theme if provided
    if theme then
        for k, v in pairs(theme) do
            ModernUI.Theme[k] = v
        end
    end
    
    -- Create main container
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "ModernUI"
    screenGui.Parent = game:GetService("CoreGui")
    
    local mainSize = size or UDim2.new(0, 450, 0, 600)
    local mainPos = UDim2.new(0.5, -mainSize.X.Offset/2, 0.5, -mainSize.Y.Offset/2)
    
    self.MainFrame = createRoundedFrame(screenGui, mainSize, mainPos, ModernUI.Theme.Background, 0)
    self.MainFrame.BackgroundTransparency = 0
    self.ScreenGui = screenGui
    
    -- Make window draggable
    makeDraggable(self.MainFrame)
    
    -- Add shadow effect
    local shadow = createUIElement(self.MainFrame, "UIStroke", {
        Color = ModernUI.Theme.Border,
        Thickness = 1,
        Transparency = 0.5,
    })
    
    -- Title bar
    local titleBar = createRoundedFrame(self.MainFrame, UDim2.new(1, 0, 0, 50), UDim2.new(0, 0, 0, 0), ModernUI.Theme.Surface, 0)
    titleBar.ZIndex = 2
    
    local titleLabel = createUIElement(titleBar, "TextLabel", {
        Size = UDim2.new(1, -50, 1, 0),
        Position = UDim2.new(0, 15, 0, 0),
        BackgroundTransparency = 1,
        Text = title or "Modern UI",
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 18,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    -- Close button
    local closeButton = createUIElement(titleBar, "TextButton", {
        Size = UDim2.new(0, 30, 0, 30),
        Position = UDim2.new(1, -40, 0.5, -15),
        BackgroundColor3 = ModernUI.Theme.Danger,
        Text = "✕",
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 18,
        Font = Enum.Font.GothamBold,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    local closeCorner = createUIElement(closeButton, "UICorner", {
        CornerRadius = UDim.new(0, 6)
    })
    
    closeButton.MouseButton1Click:Connect(function()
        self:Destroy()
    end)
    
    -- Minimize button
    local minimizeButton = createUIElement(titleBar, "TextButton", {
        Size = UDim2.new(0, 30, 0, 30),
        Position = UDim2.new(1, -80, 0.5, -15),
        BackgroundColor3 = ModernUI.Theme.Surface,
        Text = "─",
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 18,
        Font = Enum.Font.GothamBold,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    local minimizeCorner = createUIElement(minimizeButton, "UICorner", {
        CornerRadius = UDim.new(0, 6)
    })
    
    local minimized = false
    local originalSize = mainSize
    
    minimizeButton.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            TweenService:Create(self.MainFrame, TweenSettings.Out, {Size = UDim2.new(mainSize.X.Scale, mainSize.X.Offset, 0, 50)}):Play()
        else
            TweenService:Create(self.MainFrame, TweenSettings.Out, {Size = originalSize}):Play()
        end
    end)
    
    -- Scrolling frame for content
    local scrollFrame = createUIElement(self.MainFrame, "ScrollingFrame", {
        Size = UDim2.new(1, -20, 1, -70),
        Position = UDim2.new(0, 10, 0, 60),
        BackgroundTransparency = 1,
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = ModernUI.Theme.Primary,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        BorderSizePixel = 0,
    })
    
    local uiList = createUIElement(scrollFrame, "UIListLayout", {
        Padding = UDim.new(0, 10),
        SortOrder = Enum.SortOrder.LayoutOrder,
        HorizontalAlignment = Enum.HorizontalAlignment.Center,
    })
    
    self.ScrollFrame = scrollFrame
    self.UIList = uiList
    self.Elements = {}
    
    return self
end

-- Helper function to create element container
function ModernUI:createElementContainer(order)
    local container = createRoundedFrame(self.ScrollFrame, UDim2.new(1, -20, 0, 50), UDim2.new(0, 10, 0, 0), ModernUI.Theme.Surface, 0)
    container.LayoutOrder = order
    container.BackgroundTransparency = 0.8
    
    return container
end

-- Button component
function ModernUI:Button(text, callback, order)
    order = order or #self.Elements + 1
    local container = self:createElementContainer(order)
    container.Size = UDim2.new(1, -20, 0, 45)
    container.BackgroundTransparency = 0
    
    local button = createUIElement(container, "TextButton", {
        Size = UDim2.new(1, -20, 1, -10),
        Position = UDim2.new(0, 10, 0, 5),
        BackgroundColor3 = ModernUI.Theme.Primary,
        Text = text,
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 15,
        Font = Enum.Font.GothamSemibold,
        AutoButtonColor = false,
        BorderSizePixel = 0,
    })
    
    local corner = createUIElement(button, "UICorner", {
        CornerRadius = UDim.new(0, 6)
    })
    
    -- Hover effect
    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenSettings.InOut, {BackgroundColor3 = ModernUI.Theme.PrimaryDark}):Play()
    end)
    
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenSettings.InOut, {BackgroundColor3 = ModernUI.Theme.Primary}):Play()
    end)
    
    button.MouseButton1Click:Connect(function()
        TweenService:Create(button, TweenSettings.In, {BackgroundColor3 = ModernUI.Theme.PrimaryDark}):Play()
        task.wait(0.05)
        TweenService:Create(button, TweenSettings.Out, {BackgroundColor3 = ModernUI.Theme.Primary}):Play()
        if callback then callback() end
    end)
    
    table.insert(self.Elements, {Type = "Button", Object = button})
    return button
end

-- Toggle component
function ModernUI:Toggle(text, default, callback, order)
    order = order or #self.Elements + 1
    local container = self:createElementContainer(order)
    container.Size = UDim2.new(1, -20, 0, 50)
    container.BackgroundTransparency = 0.8
    
    local label = createUIElement(container, "TextLabel", {
        Size = UDim2.new(0.7, -20, 1, 0),
        Position = UDim2.new(0, 15, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 14,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local toggleFrame = createRoundedFrame(container, UDim2.new(0, 55, 0, 30), UDim2.new(1, -70, 0.5, -15), ModernUI.Theme.Background, 0)
    toggleFrame.BackgroundColor3 = default and ModernUI.Theme.Primary or ModernUI.Theme.Background
    
    local toggleCircle = createRoundedFrame(toggleFrame, UDim2.new(0, 26, 0, 26), default and UDim2.new(1, -28, 0.5, -13) or UDim2.new(0, 2, 0.5, -13), ModernUI.Theme.Text, 0)
    toggleCircle.BackgroundColor3 = ModernUI.Theme.Text
    
    local state = default or false
    
    local function updateToggle()
        local targetPos = state and UDim2.new(1, -28, 0.5, -13) or UDim2.new(0, 2, 0.5, -13)
        local targetColor = state and ModernUI.Theme.Primary or ModernUI.Theme.Background
        
        TweenService:Create(toggleCircle, TweenSettings.InOut, {Position = targetPos}):Play()
        TweenService:Create(toggleFrame, TweenSettings.InOut, {BackgroundColor3 = targetColor}):Play()
        
        if callback then callback(state) end
    end
    
    toggleFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            state = not state
            updateToggle()
        end
    end)
    
    table.insert(self.Elements, {Type = "Toggle", Object = toggleFrame, State = state})
    return {
        SetState = function(newState) 
            state = newState 
            updateToggle() 
        end, 
        GetState = function() 
            return state 
        end
    }
end

