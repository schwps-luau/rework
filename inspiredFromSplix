-- Dropdown
function ModernUI:Dropdown(text, options, callback, order)
    order = order or #self.Elements + 1
    local frame = create(self.Container, "Frame", {
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = ModernUI.Colors.Surface,
        BorderSizePixel = 0,
        LayoutOrder = order,
    })
    
    local btn = create(frame, "TextButton", {
        Size = UDim2.new(1, -24, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        BackgroundColor3 = ModernUI.Colors.Background,
        Text = text .. ": " .. options[1],
        TextColor3 = ModernUI.Colors.Text,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        BorderSizePixel = 0,
        TextXAlignment = Enum.TextXAlignment.Left,
        AutoButtonColor = false,
    })
    
    local dropdownOpen = false
    local dropdownFrame
    
    btn.MouseButton1Click:Connect(function()
        if dropdownOpen then
            if dropdownFrame then dropdownFrame:Destroy() end
            dropdownOpen = false
            return
        end
        
        dropdownFrame = create(self.Container, "Frame", {
            Size = UDim2.new(1, 0, 0, #options * 36),
            Position = UDim2.new(0, 0, 0, frame.AbsolutePosition.Y - self.Container.AbsolutePosition.Y + 40),
            BackgroundColor3 = ModernUI.Colors.Surface,
            BorderSizePixel = 0,
            ZIndex = 10,
        })
        
        local list = create(dropdownFrame, "UIListLayout", {
            Padding = UDim.new(0, 0),
        })
        
        for i, opt in ipairs(options) do
            local optBtn = create(dropdownFrame, "TextButton", {
                Size = UDim2.new(1, 0, 0, 36),
                BackgroundColor3 = ModernUI.Colors.Background,
                Text = opt,
                TextColor3 = ModernUI.Colors.Text,
                TextSize = 12,
                Font = Enum.Font.Gotham,
                BorderSizePixel = 0,
                AutoButtonColor = false,
                LayoutOrder = i,
            })
            
            optBtn.MouseButton1Click:Connect(function()
                btn.Text = text .. ": " .. opt
                if callback then callback(opt) end
                dropdownFrame:Destroy()
                dropdownOpen = false
            end)
        end
        
        dropdownOpen = true
    end)
    
    table.insert(self.Elements, frame)
    return btn
end

-- Slider
function ModernUI:Slider(text, min, max, default, callback, order)
    order = order or #self.Elements + 1
    local frame = create(self.Container, "Frame", {
        Size = UDim2.new(1, 0, 0, 68),
        BackgroundColor3 = ModernUI.Colors.Surface,
        BorderSizePixel = 0,
        LayoutOrder = order,
    })
    
    local label = create(frame, "TextLabel", {
        Size = UDim2.new(1, -24, 0, 20),
        Position = UDim2.new(0, 12, 0, 8),
        BackgroundTransparency = 1,
        Text = text .. ": " .. tostring(default),
        TextColor3 = ModernUI.Colors.Text,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    
    local valueLabel = create(frame, "TextLabel", {
        Size = UDim2.new(0, 50, 0, 20),
        Position = UDim2.new(1, -62, 0, 8),
        BackgroundTransparency = 1,
        Text = tostring(default),
        TextColor3 = ModernUI.Colors.Primary,
        TextSize = 12,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Right,
    })
    
    local sliderTrack = create(frame, "Frame", {
        Size = UDim2.new(1, -24, 0, 2),
        Position = UDim2.new(0, 12, 0, 38),
        BackgroundColor3 = ModernUI.Colors.Border,
        BorderSizePixel = 0,
    })
    
    local sliderFill = create(sliderTrack, "Frame", {
        Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
        BackgroundColor3 = ModernUI.Colors.Primary,
        BorderSizePixel = 0,
    })
    
    local sliderHandle = create(frame, "TextButton", {
        Size = UDim2.new(0, 12, 0, 12),
        Position = UDim2.new((default - min) / (max - min), -6, 0, 33),
        BackgroundColor3 = ModernUI.Colors.Primary,
        Text = "",
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    local value = default
    
    local function update(posX)
        local relative = math.clamp((posX - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X, 0, 1)
        value = min + (max - min) * relative
        value = math.floor(value * 100) / 100
        
        sliderFill.Size = UDim2.new(relative, 0, 1, 0)
        sliderHandle.Position = UDim2.new(relative, -6, 0, 33)
        label.Text = text .. ": " .. tostring(value)
        valueLabel.Text = tostring(value)
        
        if callback then callback(value) end
    end
    
    sliderHandle.MouseButton1Down:Connect(function()
        local conn
        conn = UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement then
                update(input.Position.X)
            end
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                conn:Disconnect()
            end
        end)
    end)
    
    sliderTrack.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            update(input.Position.X)
        end
    end)
    
    table.insert(self.Elements, frame)
    return {
        Set = function(v) 
            value = math.clamp(v, min, max)
            local relative = (value - min) / (max - min)
            sliderFill.Size = UDim2.new(relative, 0, 1, 0)
            sliderHandle.Position = UDim2.new(relative, -6, 0, 33)
            label.Text = text .. ": " .. tostring(value)
            valueLabel.Text = tostring(value)
            if callback then callback(value) end
        end,
        Get = function() return value end
    }
end

-- Keybind
function ModernUI:Keybind(text, default, callback, order)
    order = order or #self.Elements + 1
    local frame = create(self.Container, "Frame", {
        Size = UDim2.new(1, 0, 0, 40),
        BackgroundColor3 = ModernUI.Colors.Surface,
        BorderSizePixel = 0,
        LayoutOrder = order,
    })
    
    local label = create(frame, "TextLabel", {
        Size = UDim2.new(1, -110, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = ModernUI.Colors.Text,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local bindBtn = create(frame, "TextButton", {
        Size = UDim2.new(0, 90, 0, 28),
        Position = UDim2.new(1, -102, 0.5, -14),
        BackgroundColor3 = ModernUI.Colors.Background,
        Text = default and tostring(default):gsub("Enum.KeyCode.", "") or "none",
        TextColor3 = ModernUI.Colors.Text,
        TextSize = 11,
        Font = Enum.Font.Gotham,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    local listening = false
    local currentKey = default
    
    bindBtn.MouseButton1Click:Connect(function()
        listening = true
        bindBtn.Text = "..."
        
        local conn
        conn = UserInputService.InputBegan:Connect(function(input)
            if listening and input.KeyCode ~= Enum.KeyCode.Unknown then
                currentKey = input.KeyCode
                bindBtn.Text = tostring(currentKey):gsub("Enum.KeyCode.", "")
                listening = false
                conn:Disconnect()
                if callback then callback(currentKey) end
            end
        end)
        
        task.wait(3)
        if listening then
            listening = false
            bindBtn.Text = currentKey and tostring(currentKey):gsub("Enum.KeyCode.", "") or "none"
            conn:Disconnect()
        end
    end)
    
    table.insert(self.Elements, frame)
    return {
        Set = function(k) 
            currentKey = k 
            bindBtn.Text = tostring(k):gsub("Enum.KeyCode.", "")
        end,
        Get = function() return currentKey end
    }
end

