-- Dropdown component
function ModernUI:Dropdown(text, options, callback, order)
    order = order or #self.Elements + 1
    local container = self:createElementContainer(order)
    container.Size = UDim2.new(1, -20, 0, 45)
    
    local dropdownButton = createUIElement(container, "TextButton", {
        Size = UDim2.new(1, -20, 1, -10),
        Position = UDim2.new(0, 10, 0, 5),
        BackgroundColor3 = ModernUI.Theme.Background,
        Text = text .. ": " .. options[1],
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 14,
        Font = Enum.Font.GothamMedium,
        BorderSizePixel = 0,
    })
    
    local corner = createUIElement(dropdownButton, "UICorner", {
        CornerRadius = UDim.new(0, 6)
    })
    
    local dropdownOpen = false
    local dropdownFrame
    
    dropdownButton.MouseButton1Click:Connect(function()
        if dropdownOpen then
            if dropdownFrame then dropdownFrame:Destroy() end
            dropdownOpen = false
        else
            dropdownFrame = createRoundedFrame(self.ScrollFrame, UDim2.new(1, -20, 0, #options * 35), UDim2.new(0, 10, 0, container.Position.Y.Offset + 50), ModernUI.Theme.Surface, 0)
            dropdownFrame.ZIndex = 10
            
            local dropdownList = createUIElement(dropdownFrame, "UIListLayout", {
                Padding = UDim.new(0, 2),
                SortOrder = Enum.SortOrder.LayoutOrder,
            })
            
            for i, option in ipairs(options) do
                local optionButton = createUIElement(dropdownFrame, "TextButton", {
                    Size = UDim2.new(1, 0, 0, 35),
                    BackgroundColor3 = ModernUI.Theme.Background,
                    Text = option,
                    TextColor3 = ModernUI.Theme.Text,
                    TextSize = 14,
                    Font = Enum.Font.GothamMedium,
                    BorderSizePixel = 0,
                    LayoutOrder = i,
                })
                
                local optionCorner = createUIElement(optionButton, "UICorner", {
                    CornerRadius = UDim.new(0, 4)
                })
                
                optionButton.MouseButton1Click:Connect(function()
                    dropdownButton.Text = text .. ": " .. option
                    if callback then callback(option) end
                    dropdownFrame:Destroy()
                    dropdownOpen = false
                end)
            end
            
            dropdownOpen = true
            
            -- Close dropdown when clicking outside
            local function onInputBegan(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    local mousePos = UserInputService:GetMouseLocation()
                    local framePos = dropdownFrame.AbsolutePosition
                    local frameSize = dropdownFrame.AbsoluteSize
                    
                    if mousePos.X < framePos.X or mousePos.X > framePos.X + frameSize.X or
                       mousePos.Y < framePos.Y or mousePos.Y > framePos.Y + frameSize.Y then
                        if dropdownFrame then dropdownFrame:Destroy() end
                        dropdownOpen = false
                        UserInputService.InputBegan:Disconnect()
                    end
                end
            end
            
            UserInputService.InputBegan:Connect(onInputBegan)
        end
    end)
    
    table.insert(self.Elements, {Type = "Dropdown", Object = dropdownButton})
    return dropdownButton
end

-- Slider component
function ModernUI:Slider(text, min, max, default, callback, order)
    order = order or #self.Elements + 1
    local container = self:createElementContainer(order)
    container.Size = UDim2.new(1, -20, 0, 65)
    
    local label = createUIElement(container, "TextLabel", {
        Size = UDim2.new(1, -20, 0, 20),
        Position = UDim2.new(0, 10, 0, 5),
        BackgroundTransparency = 1,
        Text = text .. ": " .. tostring(default),
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 14,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    
    local sliderFrame = createRoundedFrame(container, UDim2.new(1, -20, 0, 30), UDim2.new(0, 10, 0, 30), ModernUI.Theme.Background, 0)
    
    local fill = createRoundedFrame(sliderFrame, UDim2.new((default - min) / (max - min), 0, 1, 0), UDim2.new(0, 0, 0, 0), ModernUI.Theme.Primary, 0)
    fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    
    local value = default
    
    local function updateSlider(mouseX)
        local relativeX = math.clamp((mouseX - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
        value = min + (max - min) * relativeX
        value = math.round(value * 100) / 100
        
        fill.Size = UDim2.new(relativeX, 0, 1, 0)
        label.Text = text .. ": " .. tostring(value)
        
        if callback then callback(value) end
    end
    
    sliderFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            updateSlider(input.Position.X)
            
            local connection
            connection = UserInputService.InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement then
                    updateSlider(input.Position.X)
                end
            end)
            
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    connection:Disconnect()
                end
            end)
        end
    end)
    
    table.insert(self.Elements, {Type = "Slider", Object = sliderFrame, Value = value})
    return {SetValue = function(newValue) updateSlider(sliderFrame.AbsolutePosition.X + (newValue - min) / (max - min) * sliderFrame.AbsoluteSize.X) end, GetValue = function() return value end}
end

-- Keybind component
function ModernUI:Keybind(text, defaultKey, callback, order)
    order = order or #self.Elements + 1
    local container = self:createElementContainer(order)
    container.Size = UDim2.new(1, -20, 0, 45)
    
    local label = createUIElement(container, "TextLabel", {
        Size = UDim2.new(0.6, -20, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 14,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local keybindButton = createUIElement(container, "TextButton", {
        Size = UDim2.new(0, 80, 0, 35),
        Position = UDim2.new(1, -90, 0.5, -17.5),
        BackgroundColor3 = ModernUI.Theme.Background,
        Text = defaultKey and tostring(defaultKey):gsub("Enum.KeyCode.", "") or "None",
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 14,
        Font = Enum.Font.GothamMedium,
        BorderSizePixel = 0,
    })
    
    local corner = createUIElement(keybindButton, "UICorner", {
        CornerRadius = UDim.new(0, 6)
    })
    
    local listening = false
    local currentKey = defaultKey
    
    keybindButton.MouseButton1Click:Connect(function()
        listening = true
        keybindButton.Text = "Press any key..."
        
        local connection
        connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            
            if listening and input.KeyCode ~= Enum.KeyCode.Unknown then
                currentKey = input.KeyCode
                keybindButton.Text = tostring(currentKey):gsub("Enum.KeyCode.", "")
                listening = false
                connection:Disconnect()
                if callback then callback(currentKey) end
            end
        end)
    end)
    
    table.insert(self.Elements, {Type = "Keybind", Object = keybindButton, Key = currentKey})
    return {SetKey = function(newKey) currentKey = newKey keybindButton.Text = tostring(newKey):gsub("Enum.KeyCode.", "") end, GetKey = function() return currentKey end}
end

-- ColorPicker component
function ModernUI:ColorPicker(text, defaultColor, callback, order)
    order = order or #self.Elements + 1
    local container = self:createElementContainer(order)
    container.Size = UDim2.new(1, -20, 0, 45)
    
    local label = createUIElement(container, "TextLabel", {
        Size = UDim2.new(0.6, -20, 1, 0),
        Position = UDim2.new(0, 10, 0, 0),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = ModernUI.Theme.Text,
        TextSize = 14,
        Font = Enum.Font.GothamMedium,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local colorDisplay = createRoundedFrame(container, UDim2.new(0, 30, 0, 30), UDim2.new(1, -40, 0.5, -15), defaultColor or ModernUI.Theme.Primary, 0)
    
    local currentColor = defaultColor or ModernUI.Theme.Primary
    
    colorDisplay.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            -- Simplified color picker dialog (in a real implementation, this would be more complex)
            local hue = 0
            local sat = 1
            local val = 1
            
            -- For simplicity, cycle through colors on click
            local colors = {
                Color3.fromRGB(255, 0, 0),
                Color3.fromRGB(0, 255, 0),
                Color3.fromRGB(0, 0, 255),
                Color3.fromRGB(255, 255, 0),
                Color3.fromRGB(255, 0, 255),
                Color3.fromRGB(0, 255, 255),
            }
            
            local currentIndex = 1
            for i, color in ipairs(colors) do
                if color == currentColor then
                    currentIndex = i
                    break
                end
            end
            
            currentIndex = currentIndex % #colors + 1
            currentColor = colors[currentIndex]
            colorDisplay.BackgroundColor3 = currentColor
            if callback then callback(currentColor) end
        end
    end)
    
    table.insert(self.Elements, {Type = "ColorPicker", Object = colorDisplay, Color = currentColor})
    return {SetColor = function(newColor) currentColor = newColor colorDisplay.BackgroundColor3 = newColor if callback then callback(newColor) end end, GetColor = function() return currentColor end}
end

