-- Tab Creation
function AetherUI:Tab(name)
    local tab = {}
    
    local tabButton = create(self.TabsContainer or self:GetTabContainer(), "TextButton", {
        Size = UDim2.new(0, 80, 1, 0),
        BackgroundColor3 = Colors.Surface,
        Text = name,
        TextColor3 = Colors.Text,
        TextSize = 12,
        Font = Enum.Font.Gotham,
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    local tabContent = create(self.ContentArea or self:GetContentArea(), "ScrollingFrame", {
        Size = UDim2.new(1, 0, 1, 0),
        Position = UDim2.new(0, 0, 0, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Visible = false,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = Colors.Border,
    })
    
    local contentLayout = create(tabContent, "UIListLayout", {
        Padding = UDim.new(0, 8),
    })
    
    tabButton.MouseButton1Click:Connect(function()
        for _, t in pairs(self.Tabs) do
            t.Content.Visible = false
        end
        tabContent.Visible = true
    end)
    
    tab.Button = tabButton
    tab.Content = tabContent
    tab.Layout = contentLayout
    
    table.insert(self.Tabs, tab)
    
    if not self.CurrentTab then
        tabContent.Visible = true
        self.CurrentTab = tab
    end
    
    return tabContent, contentLayout
end

