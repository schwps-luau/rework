        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    
    local colorBox = create(frame, "TextButton", {
        Size = UDim2.new(0, 32, 0, 24),
        Position = UDim2.new(1, -44, 0.5, -12),
        BackgroundColor3 = default or ModernUI.Colors.Primary,
        Text = "",
        BorderSizePixel = 0,
        AutoButtonColor = false,
    })
    
    local colors = {
        Color3.fromRGB(255, 70, 70),   -- Red
        Color3.fromRGB(70, 255, 70),   -- Green
        Color3.fromRGB(70, 70, 255),   -- Blue
        Color3.fromRGB(255, 255, 70),  -- Yellow
        Color3.fromRGB(255, 70, 255),  -- Magenta
        Color3.fromRGB(70, 255, 255),  -- Cyan
        Color3.fromRGB(255, 140, 70),  -- Orange
        Color3.fromRGB(200, 70, 255),  -- Purple
        Color3.fromRGB(255, 255, 255), -- White
        Color3.fromRGB(64, 128, 255),  -- Primary
    }
    
    local open = false
